import std.db_row.{Row}
import std.db_error.{DBError}

pub effect DB {
    effect Read {
        fn query(sql: Str) -> Result[List[Row], DBError]
        fn query_one(sql: Str) -> Result[Row, DBError]
    }
    effect Write {
        fn exec(sql: Str) -> Result[Void, DBError]
        fn execute(sql: Str) -> Result[Int, DBError]
        fn begin() -> Result[Void, DBError]
        fn commit() -> Result[Void, DBError]
        fn rollback() -> Result[Void, DBError]
    }
}
