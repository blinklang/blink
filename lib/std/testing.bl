import std.float.{fabs, is_nan}

let mut _capture_log_target: List[Str] = []
let mut _capture_print_target: List[Str] = []
let mut _capture_eprint_target: List[Str] = []

pub fn capture_log(messages: List[Str]) -> Handler[IO.Log] {
    _capture_log_target = messages
    handler IO.Log {
        fn log(msg: Str) {
            _capture_log_target.push(msg)
        }
    }
}

pub fn capture_print(messages: List[Str]) -> Handler[IO.Print] {
    _capture_print_target = messages
    handler IO.Print {
        fn print(msg: Str) {
            _capture_print_target.push(msg)
        }
        fn print_no_nl(msg: Str) {
            _capture_print_target.push(msg)
        }
    }
}

pub fn capture_eprint(messages: List[Str]) -> Handler[IO.Eprint] {
    _capture_eprint_target = messages
    handler IO.Eprint {
        fn eprint(msg: Str) {
            _capture_eprint_target.push(msg)
        }
        fn eprint_no_nl(msg: Str) {
            _capture_eprint_target.push(msg)
        }
    }
}

/// `BlockHandler` that runs a closure on every catchable unwind out of a
/// `with cleanup(fn) { ... }` block (normal exit, `?`, `return`, assert
/// failure, `skip()`). For non-`Closeable` cleanup — temp paths, env-var
/// resets, mock restores. For resources that already implement `Closeable`,
/// use `with x = acquire() as x { ... }` directly.
pub type Cleanup {
    action: fn() -> Void
}

impl BlockHandler for Cleanup {
    type Context = Void
    fn enter(self) -> Void {
        let _ = self
    }
    fn exit(self, ok: Bool) {
        let _ = ok
        (self.action)()
    }
}

pub fn cleanup(action: fn() -> Void) -> Cleanup {
    Cleanup { action: action }
}

@ffi("blink_set_case_label")
@trusted
fn set_case_label(label: Str) ! FFI {}

pub fn for_each[T](cases: List[(Str, T)], body: fn(T) -> Void) {
    let mut _seen: List[Str] = []
    let mut _i = 0
    while _i < cases.len() {
        let _case = cases.get(_i).unwrap()
        let (_label, _value) = _case
        let mut _j = 0
        while _j < _seen.len() {
            let _prev = _seen.get(_j).unwrap()
            assert(_prev != _label, "for_each: duplicate case label \"{_label}\" at indices {_j} and {_i}")
            _j = _j + 1
        }
        _seen.push(_label)
        set_case_label(_label)
        body(_value)
        set_case_label("")
        _i = _i + 1
    }
}

/// Assert that two floats are within `tol` of each other (absolute tolerance).
/// Panics on failure. Panics if any input is NaN. Panics if `tol` is negative.
/// Identical infinities pass; opposite-sign or mixed Inf/finite fail.
pub fn assert_close(left: Float, right: Float, tol: Float) {
    assert(!is_nan(left), "assert_close: left is NaN")
    assert(!is_nan(right), "assert_close: right is NaN")
    assert(!is_nan(tol), "assert_close: tol is NaN")
    assert(tol >= 0.0, "assert_close: tolerance must be non-negative, got {tol}")
    if left == right { return }
    let diff = fabs(left - right)
    assert(diff <= tol, "assert_close failed: |{left} - {right}| = {diff} exceeds tol {tol}")
}

/// Assert that two floats agree within a relative tolerance.
/// Predicate: |left - right| <= rel_tol * max(|left|, |right|).
/// Panics on failure, on any NaN input, and on negative `rel_tol`.
/// Both exactly 0.0 passes vacuously. Identical infinities pass.
pub fn assert_close_rel(left: Float, right: Float, rel_tol: Float) {
    assert(!is_nan(left), "assert_close_rel: left is NaN")
    assert(!is_nan(right), "assert_close_rel: right is NaN")
    assert(!is_nan(rel_tol), "assert_close_rel: rel_tol is NaN")
    assert(rel_tol >= 0.0, "assert_close_rel: tolerance must be non-negative, got {rel_tol}")
    if left == right { return }
    let abs_l = fabs(left)
    let abs_r = fabs(right)
    let scale = if abs_l > abs_r { abs_l } else { abs_r }
    let bound = scale * rel_tol
    let diff = fabs(left - right)
    assert(diff <= bound, "assert_close_rel failed: |{left} - {right}| = {diff} exceeds {scale} * {rel_tol} = {bound}")
}
