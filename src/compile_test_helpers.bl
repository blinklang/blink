import std.path.{path_join}

fn resolve_blink_root() -> Str {
    env.var("BLINK_ROOT") ?? ""
}

fn blinkc_path() -> Str {
    let root = resolve_blink_root()
    if root != "" {
        let p = path_join(root, "build/blinkc")
        if file_exists(p) == 1 {
            return p
        }
    }
    "build/blinkc"
}

fn archive_dir() -> Str {
    let root = resolve_blink_root()
    if root != "" {
        let candidate = path_join(root, "build/libblink_std.a")
        if file_exists(candidate) == 1 {
            return path_join(root, "build")
        }
    }
    "build"
}

fn run_compile(path: Str, src: Str) -> Str {
    write_file(path, src)
    let args = [path, "/dev/null", "--format", "json"]
    let result = process_run(blinkc_path(), args)
    let output = "{result.out}{result.err_out}"
    fs.remove(path)
    output
}

pub fn compile_and_capture(source: Str, tag: Str) -> Str {
    run_compile(".tmp/{tag}.bl", source)
}

pub fn expect_error(output: Str, code: Str, label: Str) {
    if output.contains(code) {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected {code} in output")
    }
}

pub fn expect_clean(output: Str, label: Str) {
    if output.contains("E0900") || output.contains("E0901") || output.contains("E0902") || output.contains("E0903") || output.contains("E0905") {
        io.println("FAIL: {label} — unexpected trait contract error in output")
    } else {
        io.println("PASS: {label}")
    }
}

pub fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    let output = run_compile(".tmp/_test_{tag}.bl", src)
    assert(output.contains(error_code))
}

pub fn expect_no_error(src: Str, tag: Str, error_code: Str) {
    let output = run_compile(".tmp/_test_{tag}.bl", src)
    assert(!output.contains(error_code))
}

// Compile `src` to a real .c file and return the emitted C source. Used
// to inspect what codegen produced for a given construct without running
// the compiled binary.
pub fn compile_and_emit_c(src: Str, tag: Str) -> Str {
    let bl_path = ".tmp/{tag}.bl"
    let c_path = ".tmp/{tag}.c"
    write_file(bl_path, src)
    let args = [bl_path, c_path]
    let _result = process_run(blinkc_path(), args)
    let c_src = read_file(c_path)
    fs.remove(bl_path)
    fs.remove(c_path)
    c_src
}

// Compile `src` to a binary, run it, and return (exit_code, stderr).
pub type RunResult {
    exit_code: Int
    out: Str
    err_out: Str
}

pub fn compile_and_run(src: Str, tag: Str) -> RunResult {
    let bl_path = ".tmp/{tag}.bl"
    let c_path = ".tmp/{tag}.c"
    let bin_path = ".tmp/{tag}_bin"
    write_file(bl_path, src)
    let arc_dir = archive_dir()
    let cargs = ["--link-archive", path_join(arc_dir, "libblink_std.h"), bl_path, c_path]
    let cresult = process_run(blinkc_path(), cargs)
    if cresult.exit_code != 0 {
        fs.remove(bl_path)
        return RunResult { exit_code: cresult.exit_code, out: cresult.out, err_out: cresult.err_out }
    }
    let lnk = process_run("cc", ["-I{arc_dir}", "-o", bin_path, c_path, path_join(arc_dir, "libblink_std.a"), "-lm", "-lgc", "-pthread", "-Wl,--gc-sections"])
    if lnk.exit_code != 0 {
        fs.remove(bl_path)
        fs.remove(c_path)
        return RunResult { exit_code: lnk.exit_code, out: lnk.out, err_out: lnk.err_out }
    }
    let r = process_run(bin_path, [])
    fs.remove(bl_path)
    fs.remove(c_path)
    fs.remove(bin_path)
    RunResult { exit_code: r.exit_code, out: r.out, err_out: r.err_out }
}
