effect Counter {
    effect Ops {
        fn get_value() -> Int
    }
}

fn make_handler(val: Int) -> Handler[Counter] {
    handler Counter {
        fn get_value() -> Int {
            val
        }
    }
}

fn make_handler_multi(a: Int, b: Int) -> Handler[Counter] {
    handler Counter {
        fn get_value() -> Int {
            a + b
        }
    }
}
