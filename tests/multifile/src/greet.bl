import math.{id, box_make, box_get}

pub fn hello(name: Str) -> Str {
    "Hello, {id(name)}!"
}

pub fn goodbye(name: Str) -> Str {
    "Goodbye, {name}!"
}

pub fn lucky_int() -> Int {
    id(7)
}

// Cross-module instantiation: greet.o emits Box[Int] and box_make[Int].
// main.bl also instantiates Box[Int] from main.o — under per-module .o,
// both translation units must agree on the symbol storage class so the
// linker can merge / discard the duplicates.
pub fn boxed_seven() -> Int {
    let b = box_make(7)
    box_get(b)
}
