import math.{add, id, box_make, box_get}
import greet.{hello, goodbye, lucky_int, boxed_seven}

fn main() {
    io.println(hello("World"))
    io.println(goodbye("World"))
    io.println("2 + 3 = {add(2, 3)}")
    io.println("id(Int)={id(42)} lucky={lucky_int()}")
    let echoed = id("echo")
    io.println("id(Str)={echoed}")
    // Box[Int] instantiated here AND in greet.bl — duplicate across .o files.
    let bi = box_make(99)
    io.println("box(99)={box_get(bi)} greet_box={boxed_seven()}")
    // Box[Str] instantiated only here — unique to main.o.
    let bs = box_make("ok")
    io.println("box(str)={box_get(bs)}")
}
