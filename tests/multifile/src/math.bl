pub fn add(a: Int, b: Int) -> Int {
    a + b
}

pub fn multiply(a: Int, b: Int) -> Int {
    a * b
}

pub fn id[T](x: T) -> T {
    x
}

pub type Box[T] { value: T }

pub fn box_make[T](v: T) -> Box[T] {
    Box { value: v }
}

pub fn box_get[T](b: Box[T]) -> T {
    b.value
}

fn internal_helper() -> Int {
    42
}
