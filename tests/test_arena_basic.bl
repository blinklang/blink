// Arena effect + with-arena block handler.
// Escape analysis lives in a later subtask; these tests cover only the
// non-escaping surface: parsing, typecheck of ! Arena, and runtime
// create/swap/restore/destroy of the arena block.

fn pure_in_arena(x: Int) -> Int ! Arena {
    x + 1
}

fn early_return_helper(flag: Int) -> Int {
    with arena {
        if flag == 1 {
            return 7
        }
    }
    return 0
}

test "! Arena effect parses and typechecks on a standalone fn" {
    assert_eq(pure_in_arena(41), 42)
}

test "with arena runs body and restores afterwards" {
    let mut before = 0
    let mut during = 0
    let mut after = 0
    before = 1
    with arena {
        during = 2
        let msg = "inside arena"
        assert_eq(msg, "inside arena")
    }
    after = 3
    assert_eq(before, 1)
    assert_eq(during, 2)
    assert_eq(after, 3)
}

test "nested with arena creates independent arenas" {
    let mut outer_seen = 0
    let mut inner_seen = 0
    with arena {
        outer_seen = 1
        with arena {
            inner_seen = 2
        }
        assert_eq(inner_seen, 2)
    }
    assert_eq(outer_seen, 1)
    assert_eq(inner_seen, 2)
}

test "early return inside with arena restores TLS" {
    assert_eq(early_return_helper(1), 7)
    assert_eq(early_return_helper(0), 0)
}
