// Arena bulk-free pressure: many iterations each enter `with arena { }`,
// allocate a working set, and exit. If the region were not reclaimed at `}`,
// cumulative footprint across iterations would OOM.
//
// The inner int list is sized so repeated doubling crosses bdwgc's
// large-block threshold (~1 MB on 64-bit). See k6s1nc: before the arena
// chunk header was split from its atomic data payload, growing past that
// threshold hid the `next` pointer from the GC scan and triggered a
// duplicate-large-block-deallocation / SIGSEGV on arena teardown.

import std.arena.{bytes_used}

fn fill_arena_once(iter: Int) -> Int {
    with arena {
        let mut acc = 0
        let mut xs: List[Int] = []
        let mut i = 0
        while i < 10000 {
            xs.push(i)
            acc = acc + i
            i = i + 1
        }
        let mut strs: List[Str] = []
        let mut j = 0
        while j < 100 {
            strs.push("iter_{iter}_item_{j}")
            j = j + 1
        }
        assert_eq(xs.len(), 10000)
        assert_eq(strs.len(), 100)
        acc
    }
    49995000
}

test "arena bulk-free survives repeated allocation pressure" {
    let mut k = 0
    while k < 200 {
        let sum = fill_arena_once(k)
        assert_eq(sum, 49995000)
        assert_eq(bytes_used(), 0)
        k = k + 1
    }
    assert_eq(k, 200)
}
