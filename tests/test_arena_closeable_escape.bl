// E0700 negative tests for §5.2.1 clause 6: the promoted arena tail must not
// retain references into a Closeable's buffers. Tracked by br r0y5m2.

fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "assigning Closeable-owned field to outer binding emits E0700" {
    let src = "let mut saved: List[Int] = []\ntype Bufx \{ buf: List[Int] }\nimpl Closeable for Bufx \{ fn close(self) \{} }\nfn main() \{\n    with arena \{\n        with Bufx \{ buf: [1, 2, 3] } as b \{\n            saved = b.buf\n        \}\n    \}\n\}\n"
    expect_compile_error(src, "arena_closeable_field_escape", "E0700")
}

test "nested field chain on Closeable binding emits E0700" {
    let src = "let mut saved: List[Int] = []\ntype Inner \{ data: List[Int] }\ntype Bufy \{ inner: Inner }\nimpl Closeable for Bufy \{ fn close(self) \{} }\nfn main() \{\n    with arena \{\n        with Bufy \{ inner: Inner \{ data: [9, 9, 9] } } as b \{\n            saved = b.inner.data\n        \}\n    \}\n\}\n"
    expect_compile_error(src, "arena_closeable_nested_escape", "E0700")
}
