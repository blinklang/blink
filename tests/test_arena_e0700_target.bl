// E0700 prints the resolved promotion target: "GC heap" from an outermost
// `with arena { }` or "outer arena" from a nested block.

import compile_test_helpers

test "E0700 nested escape prints 'outer arena' target" {
    let src = "let mut saved: List[Int] = []\nfn main() \{\n    with arena \{\n        with arena \{\n            let xs = [1, 2, 3]\n            saved = xs\n        \}\n    \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "arena_e0700_outer_target", "outer arena")
}

test "E0700 nested escape still reports ArenaValueEscapes code" {
    let src = "let mut saved: List[Int] = []\nfn main() \{\n    with arena \{\n        with arena \{\n            let xs = [1, 2, 3]\n            saved = xs\n        \}\n    \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "arena_e0700_outer_code", "E0700")
}
