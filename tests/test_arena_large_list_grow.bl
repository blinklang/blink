// Regression for k6s1nc: growing a List[Int] past bdwgc's large-block
// threshold inside `with arena { }` used to crash on arena teardown
// (duplicate large block deallocation / SIGSEGV). The chunk header was
// allocated with GC_MALLOC_ATOMIC, hiding the intra-chunk `next` pointer
// from the GC scan; a collection that fired mid-growth would reclaim
// earlier chunks behind the arena's back, so destroy-time GC_FREE hit
// already-freed blocks.

fn grow_large_list(n: Int) -> Int {
    let mut result = 0
    with arena {
        let mut xs: List[Int] = []
        let mut i = 0
        while i < n {
            xs.push(i * 2)
            i = i + 1
        }
        result = xs.len()
    }
    result
}

test "list grown past 1MB inside arena tears down cleanly" {
    let len = grow_large_list(200000)
    assert_eq(len, 200000)
}

test "arena reused across large-list growth cycles" {
    let mut k = 0
    while k < 10 {
        let len = grow_large_list(150000)
        assert_eq(len, 150000)
        k = k + 1
    }
    assert_eq(k, 10)
}
