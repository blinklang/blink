// Regression: mutating a List inside `with arena { }` must not trigger a
// bdwgc duplicate-free. Previously, list.push crossed a growth boundary
// while the arena was active, which routed GC_REALLOC on an arena-interior
// pointer and freed the enclosing arena chunk.
// Ticket: e9wb7n (bridge).

test "arena scope A then arena scope B with 100 list pushes is stable" {
    with arena {
        let mut warmup: List[Int] = []
        warmup.push(1)
        assert_eq(warmup.len(), 1)
    }
    with arena {
        let mut items: List[Int] = []
        let mut i = 0
        while i < 100 {
            items.push(i)
            i += 1
        }
        assert_eq(items.len(), 100)
        assert_eq(items.get(0) ?? -1, 0)
        assert_eq(items.get(99) ?? -1, 99)
    }
}

test "arena-owned list grows many times without corruption" {
    with arena {
        let mut items: List[Int] = []
        let mut i = 0
        while i < 1000 {
            items.push(i * 2)
            i += 1
        }
        assert_eq(items.len(), 1000)
        assert_eq(items.get(0) ?? -1, 0)
        assert_eq(items.get(500) ?? -1, 1000)
        assert_eq(items.get(999) ?? -1, 1998)
    }
}

test "nested arena inner list growth does not corrupt outer arena" {
    with arena {
        let mut outer: List[Int] = []
        outer.push(10)
        outer.push(20)
        with arena {
            let mut inner: List[Int] = []
            let mut i = 0
            while i < 200 {
                inner.push(i)
                i += 1
            }
            assert_eq(inner.len(), 200)
            assert_eq(inner.get(150) ?? -1, 150)
        }
        outer.push(30)
        assert_eq(outer.len(), 3)
        assert_eq(outer.get(0) ?? -1, 10)
        assert_eq(outer.get(1) ?? -1, 20)
        assert_eq(outer.get(2) ?? -1, 30)
    }
}
