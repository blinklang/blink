// Arena promotion: a scalar struct yielded from `with arena { expr }`
// survives after the inner arena is destroyed.
type Point {
    x: Int
    y: Int
}

type Labeled {
    name: Str
    value: Int
}

test "int tail promotes out of with-arena" {
    let n = with arena {
        let a = 10
        let b = 32
        a + b
    }
    assert_eq(n, 42)
}

test "str tail promotes out of with-arena" {
    let s = with arena {
        "hello_{40 + 2}"
    }
    assert_eq(s, "hello_42")
}

test "scalar struct tail promotes out of with-arena" {
    let p = with arena {
        Point { x: 3, y: 4 }
    }
    assert_eq(p.x, 3)
    assert_eq(p.y, 4)
}

test "struct with Str field promotes out of with-arena" {
    let lbl = with arena {
        Labeled { name: "answer_{42}", value: 42 }
    }
    assert_eq(lbl.name, "answer_42")
    assert_eq(lbl.value, 42)
}
