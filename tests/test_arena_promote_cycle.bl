import compile_test_helpers

test "self-referential struct returned from arena emits E0701" {
    let src = "type Node \{\n    next: Node\n    value: Int\n}\nfn main() \{\n    with arena \{\n        Node \{ next: Node \{ next: Node \{ value: 0 }, value: 1 }, value: 2 }\n    \}\n}\n"
    compile_test_helpers.expect_compile_error(src, "arena_cycle_self", "E0701")
}

test "mutually recursive types returned from arena emit E0701" {
    let src = "type A \{\n    b: B\n}\ntype B \{\n    a: A\n}\nfn main() \{\n    with arena \{\n        A \{ b: B \{ a: A \{ b: B \{ a: A \{ b: B \{ } } } } } }\n    \}\n}\n"
    compile_test_helpers.expect_compile_error(src, "arena_cycle_mutual", "E0701")
}
