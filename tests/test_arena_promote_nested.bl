// Arena promotion: List and Map tails cross the `with arena { }`
// boundary intact and are readable after the inner arena is destroyed.

test "List[Int] tail promotes out of with-arena" {
    let xs = with arena {
        let mut l: List[Int] = []
        l.push(1)
        l.push(2)
        l.push(3)
        l
    }
    assert_eq(xs.len(), 3)
    assert_eq(xs.get(0).unwrap(), 1)
    assert_eq(xs.get(1).unwrap(), 2)
    assert_eq(xs.get(2).unwrap(), 3)
}

test "List[Str] tail promotes out of with-arena" {
    let xs = with arena {
        let mut l: List[Str] = []
        l.push("hello_{1}")
        l.push("hello_{2}")
        l
    }
    assert_eq(xs.len(), 2)
    assert_eq(xs.get(0).unwrap(), "hello_1")
    assert_eq(xs.get(1).unwrap(), "hello_2")
}

test "Map[Str, Int] tail promotes out of with-arena" {
    let m = with arena {
        let mut m: Map[Str, Int] = Map()
        m.insert("a_{1}", 10)
        m.insert("b_{2}", 20)
        m
    }
    assert_eq(m.len(), 2)
    assert_eq(m.get("a_1").unwrap(), 10)
    assert_eq(m.get("b_2").unwrap(), 20)
}
