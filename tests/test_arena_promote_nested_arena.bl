// Arena promotion across nested `with arena { }` blocks: the inner
// tail promotes into the outer arena, then the outer tail promotes
// into the caller's heap.

type Pair { a: Int, b: Int }

test "int tail promotes through nested with-arena" {
    let n = with arena {
        let inner = with arena {
            10 + 11
        }
        inner + 21
    }
    assert_eq(n, 42)
}

test "str tail promotes through nested with-arena" {
    let s = with arena {
        let inner = with arena {
            "hi_{42}"
        }
        inner
    }
    assert_eq(s, "hi_42")
}

test "struct tail promotes through nested with-arena" {
    let p = with arena {
        let inner = with arena {
            Pair { a: 1, b: 2 }
        }
        inner
    }
    assert_eq(p.a, 1)
    assert_eq(p.b, 2)
}

test "list tail promotes through nested with-arena" {
    let xs = with arena {
        let inner = with arena {
            let mut l: List[Int] = []
            l.push(7)
            l.push(8)
            l.push(9)
            l
        }
        inner
    }
    assert_eq(xs.len(), 3)
    assert_eq(xs.get(0).unwrap(), 7)
    assert_eq(xs.get(1).unwrap(), 8)
    assert_eq(xs.get(2).unwrap(), 9)
}
