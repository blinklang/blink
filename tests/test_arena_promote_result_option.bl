// §5.2.1 clause 1/2: Result and Option tail values from `with arena { expr }`
// must be deep-copied via blink_promote_<T> into the enclosing target.

type Point {
    x: Int
    y: Int
}

type Labeled {
    name: Str
}

fn mk_point(a: Int, b: Int) -> Point {
    Point { x: a, y: b }
}

test "Ok(Int) tail promotes out of with-arena" {
    let r = with arena { Ok(5) }
    match r {
        Ok(v) => assert_eq(v, 5)
        Err(_) => assert_eq(0, 1)
    }
}

test "Err(Str) tail promotes out of with-arena" {
    let r: Result[Int, Str] = with arena { Err("bad_{1 + 1}") }
    match r {
        Ok(_) => assert_eq(0, 1)
        Err(e) => assert_eq(e, "bad_2")
    }
}

test "Ok(Str) tail promotes string payload" {
    let r: Result[Str, Str] = with arena { Ok("hello_{40 + 2}") }
    match r {
        Ok(s) => assert_eq(s, "hello_42")
        Err(_) => assert_eq(0, 1)
    }
}

test "Ok(struct) tail promotes struct payload" {
    let r: Result[Point, Str] = with arena { Ok(mk_point(1, 2)) }
    match r {
        Ok(p) => {
            assert_eq(p.x, 1)
            assert_eq(p.y, 2)
        }
        Err(_) => assert_eq(0, 1)
    }
}

test "Ok(struct with str field) chains through struct walker" {
    let r: Result[Labeled, Str] = with arena { Ok(Labeled { name: "hi_{7}" }) }
    match r {
        Ok(l) => assert_eq(l.name, "hi_7")
        Err(_) => assert_eq(0, 1)
    }
}

test "Ok(list) tail promotes list payload" {
    let r: Result[List[Int], Str] = with arena { Ok([1, 2, 3]) }
    match r {
        Ok(xs) => {
            assert_eq(xs.len(), 3)
            assert_eq(xs.get(0).unwrap(), 1)
            assert_eq(xs.get(2).unwrap(), 3)
        }
        Err(_) => assert_eq(0, 1)
    }
}

test "Some(Int) tail promotes out of with-arena" {
    let o = with arena { Some(5) }
    match o {
        Some(v) => assert_eq(v, 5)
        None => assert_eq(0, 1)
    }
}

test "Some(Str) tail promotes string payload" {
    let o: Option[Str] = with arena { Some("opt_{42}") }
    match o {
        Some(s) => assert_eq(s, "opt_42")
        None => assert_eq(0, 1)
    }
}

test "let-binding form with Ok payload" {
    let x = with arena { Ok(5) }
    match x {
        Ok(v) => assert_eq(v, 5)
        Err(_) => assert_eq(0, 1)
    }
}

test "let-binding form with Some payload" {
    let x = with arena { Some(7) }
    match x {
        Some(v) => assert_eq(v, 7)
        None => assert_eq(0, 1)
    }
}
