// Q5 escape boundary: `with arena { }` discharges `! Arena` on the enclosing fn.
// An ! Arena callee inside a `with arena` block must NOT force ! Arena onto the enclosing fn.

fn consume(xs: List[Int]) -> Int ! Arena {
    xs.len()
}

fn wrapper() -> Int {
    let n = with arena {
        let xs = [1, 2, 3]
        consume(xs)
    }
    n
}

fn main() {
    assert_eq(wrapper(), 3)
}
