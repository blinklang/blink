let mut counter = 0

fn bump() -> Int {
    counter = counter + 1
    counter
}

test "assert passing does not evaluate msg" {
    counter = 0
    assert(true, "would be {bump()}")
    assert_eq(counter, 0)
}

test "assert passing does not evaluate interpolated msg with value and fn call" {
    counter = 0
    let x = 42
    assert(true, "v={x} counter={bump()}")
    assert_eq(counter, 0)
}
