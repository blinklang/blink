import compile_test_helpers

fn main() {
    // --- Positive: trait with associated type + impl providing it ---
    let src_ok = "trait Describe \{\n    type Output\n    fn describe(self) -> Str\n}\ntype Dog \{ name: Str }\nimpl Describe for Dog \{\n    type Output = Str\n    fn describe(self) -> Str \{ self.name }\n}\nfn main() \{\n}\n"
    let out_ok = compile_test_helpers.compile_and_capture(src_ok, "_at_ok")
    compile_test_helpers.expect_clean(out_ok, "assoc type impl compiles")

    // --- Negative: impl missing associated type → E0905 ---
    let src_missing = "trait Describe \{\n    type Output\n    fn describe(self) -> Str\n}\ntype Dog \{ name: Str }\nimpl Describe for Dog \{\n    fn describe(self) -> Str \{ self.name }\n}\nfn main() \{\n}\n"
    let out_missing = compile_test_helpers.compile_and_capture(src_missing, "_at_missing")
    compile_test_helpers.expect_error(out_missing, "E0905", "missing assoc type detected")

    // --- Negative: missing one of multiple associated types → E0905 ---
    let src_partial = "trait Transform \{\n    type Input\n    type Output\n    fn run(self) -> Str\n}\ntype T \{ x: Int }\nimpl Transform for T \{\n    type Input = Int\n    fn run(self) -> Str \{ \"ok\" }\n}\nfn main() \{\n}\n"
    let out_partial = compile_test_helpers.compile_and_capture(src_partial, "_at_partial")
    compile_test_helpers.expect_error(out_partial, "E0905", "partially missing assoc types detected")
}
