type Dog {
    name: Str
}

type Cat {
    name: Str
    lives: Int
}

trait Describe {
    type Output

    fn describe(self) -> Self.Output
}

impl Describe for Dog {
    type Output = Str

    fn describe(self) -> Str {
        "dog: {self.name}"
    }
}

impl Describe for Cat {
    type Output = Str

    fn describe(self) -> Str {
        "cat: {self.name} ({self.lives} lives)"
    }
}

trait Transform {
    type Input
    type Output

    fn transform(self, input: Self.Input) -> Self.Output
}

type Doubler {
    factor: Int
}

impl Transform for Doubler {
    type Input = Int
    type Output = Int

    fn transform(self, input: Int) -> Int {
        input * self.factor
    }
}

fn main() {
    let d = Dog { name: "Rex" }
    let s = d.describe()
    io.println(s)
    assert_eq(s, "dog: Rex")

    let c = Cat { name: "Whiskers", lives: 9 }
    let s2 = c.describe()
    io.println(s2)
    assert_eq(s2, "cat: Whiskers (9 lives)")

    let dbl = Doubler { factor: 3 }
    let result = dbl.transform(7)
    io.println(result)
    assert_eq(result, 21)

    io.println("all assoc type tests passed")
}
