// Test: blink build/run auto-resolves dependencies when blink.lock is missing or stale.
// Sets up a project with blink.toml + path dep, no lockfile, and verifies
// that bin/blink build auto-generates blink.lock and compiles successfully.

fn main() {
    let base = ".tmp/_test_auto_resolve"
    shell_exec("rm -rf {base}")
    shell_exec("mkdir -p {base}/src")
    shell_exec("mkdir -p {base}/deps/mylib/src")

    // Write the dependency source
    write_file("{base}/deps/mylib/src/mylib.bl", "pub fn greet() -> Str \{\n    \"hello-auto\"\n\}\n")
    write_file("{base}/deps/mylib/blink.toml", "[package]\nname = \"mylib\"\nversion = \"0.1.0\"\n")

    // Write blink.toml with a path dependency — NO blink.lock
    write_file("{base}/blink.toml", "[package]\nname = \"testproj\"\nversion = \"0.1.0\"\n\n[dependencies]\nmylib = \{ path = \"deps/mylib\" \}\n")

    // Write main source that imports the dependency
    write_file("{base}/src/main.bl", "import mylib.\{greet\}\n\nfn main() \{\n    io.println(greet())\n\}\n")

    // Verify no lock file exists yet
    if file_exists("{base}/blink.lock") == 1 || file_exists("{base}/blink.lock") == 1 {
        io.println("FAIL: lock file should not exist before build")
        shell_exec("rm -rf {base}")
        return
    }

    // Build using bin/blink — should auto-resolve deps
    let build_rc = shell_exec("cd {base} && ../../bin/blink build src/main.bl -o build/main > build_log.txt 2>&1")
    let build_log = read_file("{base}/build_log.txt")

    if build_rc != 0 {
        io.println("FAIL: build failed (rc={build_rc})")
        io.println(build_log)
        shell_exec("rm -rf {base}")
        return
    }

    // Verify lock file was auto-created
    if file_exists("{base}/blink.lock") == 1 || file_exists("{base}/blink.lock") == 1 {
        io.println("PASS: lock file auto-created by build")
    } else {
        io.println("FAIL: lock file was not created by build")
        shell_exec("rm -rf {base}")
        return
    }

    // Verify binary runs correctly
    shell_exec("{base}/build/main > {base}/run_output.txt 2>&1 || true")
    let output = read_file("{base}/run_output.txt")
    if output.starts_with("hello-auto") {
        io.println("PASS: binary output correct after auto-resolve")
    } else {
        io.println("FAIL: expected 'hello-auto', got: {output}")
    }

    // --- Test stale lockfile: touch blink.toml to make it newer ---
    shell_exec("sleep 1 && touch {base}/blink.toml")

    // Add a second dep to blink.toml
    shell_exec("mkdir -p {base}/deps/otherlib/src")
    write_file("{base}/deps/otherlib/src/otherlib.bl", "pub fn other() -> Str \{\n    \"other-auto\"\n\}\n")
    write_file("{base}/deps/otherlib/blink.toml", "[package]\nname = \"otherlib\"\nversion = \"0.1.0\"\n")
    write_file("{base}/blink.toml", "[package]\nname = \"testproj\"\nversion = \"0.1.0\"\n\n[dependencies]\nmylib = \{ path = \"deps/mylib\" \}\notherlib = \{ path = \"deps/otherlib\" \}\n")
    write_file("{base}/src/main2.bl", "import mylib.\{greet\}\nimport otherlib.\{other\}\n\nfn main() \{\n    io.println(greet())\n    io.println(other())\n\}\n")

    let build2_rc = shell_exec("cd {base} && ../../bin/blink build src/main2.bl -o build/main2 > build_log2.txt 2>&1")
    let build2_log = read_file("{base}/build_log2.txt")

    if build2_rc != 0 {
        io.println("FAIL: stale lockfile rebuild failed (rc={build2_rc})")
        io.println(build2_log)
        shell_exec("rm -rf {base}")
        return
    }

    shell_exec("{base}/build/main2 > {base}/run_output2.txt 2>&1 || true")
    let output2 = read_file("{base}/run_output2.txt")
    if output2.starts_with("hello-auto") {
        io.println("PASS: stale lockfile re-resolved correctly")
    } else {
        io.println("FAIL: expected 'hello-auto', got: {output2}")
    }

    // Cleanup
    shell_exec("rm -rf {base}")
}
