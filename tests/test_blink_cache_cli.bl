// `blink cache` subcommand surface: info / clean / clean --older-than.
// Tests run against a scratch BLINK_CACHE_DIR.

import std.process.{ProcessResult}

fn make_scratch() -> Str {
    let r = process_run("sh", ["-c", "mktemp -d"])
    r.out.trim()
}

fn in_cache(scratch: Str, args: Str) -> ProcessResult {
    process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch} bin/blink cache {args}"])
}

test "cache info on empty dir reports zero entries" {
    let scratch = make_scratch()
    let r = in_cache(scratch, "info")
    assert_eq(r.exit_code, 0)
    assert(r.out.contains("entries: 0") || r.out.contains("0 entries"))
    process_run("sh", ["-c", "rm -rf {scratch}"])
}

test "cache info reports the BLINK_CACHE_DIR location" {
    let scratch = make_scratch()
    let r = in_cache(scratch, "info")
    assert_eq(r.exit_code, 0)
    assert(r.out.contains(scratch))
    process_run("sh", ["-c", "rm -rf {scratch}"])
}

test "cache clean wipes all entries" {
    let scratch = make_scratch()
    process_run("sh", ["-c", "echo o > {scratch}/x.o"])
    in_cache(scratch, "__store 3333333333333333 {scratch}/x.o mod sha")
    let before = in_cache(scratch, "info")
    assert(before.out.contains("entries: 1") || before.out.contains("1 entries"))
    let clean = in_cache(scratch, "clean")
    assert_eq(clean.exit_code, 0)
    let after = in_cache(scratch, "info")
    assert(after.out.contains("entries: 0") || after.out.contains("0 entries"))
    process_run("sh", ["-c", "rm -rf {scratch}"])
}

test "cache clean --older-than honors the duration" {
    let scratch = make_scratch()
    process_run("sh", ["-c", "echo o > {scratch}/x.o"])
    in_cache(scratch, "__store 4444444444444444 {scratch}/x.o mod sha")
    // Cache stores under {scratch}; backdate the meta to 2 days old.
    process_run("sh", ["-c", "touch -d '2 days ago' {scratch}/4444444444444444.meta"])
    let r = in_cache(scratch, "clean --older-than 1d")
    assert_eq(r.exit_code, 0)
    let info = in_cache(scratch, "info")
    assert(info.out.contains("entries: 0") || info.out.contains("0 entries"))
    process_run("sh", ["-c", "rm -rf {scratch}"])
}
