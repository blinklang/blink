import std.db_sqlite.{sqlite_handler, sqlite_open, sqlite_close, sqlite_transaction}
import std.db_error.{DBError}

fn do_work(handle: Handle) -> Result[Int, DBError] ! DB {
    with sqlite_transaction(handle) {
        db.exec("CREATE TABLE bh_test (v INT)")?
    }
    Ok(0)
}

fn main() ! IO {
    let h = sqlite_open(":memory:")
    with sqlite_handler(h) {
        let r = do_work(h)
        assert(r.is_ok())
        io.println("blockhandler in effect fn: ok")
    }
    sqlite_close(h)
}
