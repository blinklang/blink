import compile_test_helpers

test "if/else: else-branch concrete Err payload preserved" {
    let src = "fn main() \{\n    let b = true\n    let _r: Result[Int, Str] = if b \{ Ok(1) \} else \{ Err(false) \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "branch_else_concrete", "Result[Int, Bool]")
}

test "if/else: then-branch concrete Err payload preserved" {
    let src = "fn main() \{\n    let b = true\n    let _r: Result[Int, Str] = if b \{ Err(false) \} else \{ Ok(1) \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "branch_then_concrete", "Result[Int, Bool]")
}

test "if/else: then-branch concrete Ok payload preserved" {
    // Ok payload merged from then-branch; Str declared annotation must reject inferred Int.
    let src = "fn main() \{\n    let b = true\n    let _r: Result[Str, Int] = if b \{ Ok(1) \} else \{ Err(2) \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "branch_ok_concrete", "Result[Int, Int]")
}

test "if/else: merged payload accepted by matching annotation" {
    let src = "fn main() \{\n    let b = true\n    let _r: Result[Int, Bool] = if b \{ Ok(1) \} else \{ Err(false) \}\n\}\n"
    compile_test_helpers.expect_no_error(src, "branch_merged_ok", "TypeError")
}

test "match: arm payloads merged across arms" {
    let src = "fn main() \{\n    let n: Int = 0\n    let _r: Result[Int, Str] = match n \{\n        0 => Ok(1)\n        _ => Err(false)\n    \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "match_arm_merged", "Result[Int, Bool]")
}

test "Option: branch unification preserves concrete inner" {
    let src = "fn main() \{\n    let b = true\n    let _o: Option[Str] = if b \{ Some(1) \} else \{ None \}\n\}\n"
    compile_test_helpers.expect_compile_error(src, "branch_option_concrete", "Option[Int]")
}
