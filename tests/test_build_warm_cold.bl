// End-to-end: a small program built twice into a fresh BLINK_CACHE_DIR.
// Second run must produce the same binary AND populate the cache. We
// don't gate on absolute timing — only that the cache lands entries.

import std.process.{ProcessResult}

let HELLO_SRC: Str = "fn main() ! IO \{ io.println(\"hi\") }\n"

fn make_scratch() -> Str {
    let r = process_run("sh", ["-c", "mktemp -d"])
    r.out.trim()
}

test "warm rebuild produces the same output as the cold build" {
    let scratch = make_scratch()
    let src = "{scratch}/hello.bl"
    write_file(src, HELLO_SRC)
    let out1 = "{scratch}/cold"
    let out2 = "{scratch}/warm"
    process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch}/cache bin/blink build {src} -o {out1}"])
    process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch}/cache bin/blink build {src} -o {out2}"])
    let cold_run = process_run(out1, [])
    let warm_run = process_run(out2, [])
    assert_eq(cold_run.out.trim(), "hi")
    assert_eq(cold_run.out, warm_run.out)
    process_run("sh", ["-c", "rm -rf {scratch}"])
}

test "warm rebuild populates the cache with at least one entry" {
    let scratch = make_scratch()
    let src = "{scratch}/hello.bl"
    write_file(src, HELLO_SRC)
    process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch}/cache bin/blink build {src} -o {scratch}/out"])
    let info = process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch}/cache bin/blink cache info"])
    assert_eq(info.exit_code, 0)
    assert(!info.out.contains("entries: 0") && !info.out.contains("0 entries"))
    process_run("sh", ["-c", "rm -rf {scratch}"])
}

test "no-cache flag bypasses cache" {
    let scratch = make_scratch()
    let src = "{scratch}/hello.bl"
    write_file(src, HELLO_SRC)
    process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch}/cache bin/blink build --no-cache {src} -o {scratch}/out"])
    let info = process_run("sh", ["-c", "BLINK_CACHE_DIR={scratch}/cache bin/blink cache info"])
    assert_eq(info.exit_code, 0)
    assert(info.out.contains("entries: 0") || info.out.contains("0 entries"))
    process_run("sh", ["-c", "rm -rf {scratch}"])
}
