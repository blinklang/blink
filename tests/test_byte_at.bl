fn main() {
    let s = "abc"
    assert(s.byte_at(0) == 97, "byte_at(0) of 'abc' should be 97 ('a')")
    assert(s.byte_at(1) == 98, "byte_at(1) of 'abc' should be 98 ('b')")
    assert(s.byte_at(2) == 99, "byte_at(2) of 'abc' should be 99 ('c')")

    // "héllo": h=0x68, é=0xC3 0xA9, l=0x6C, l=0x6C, o=0x6F
    let u = "héllo"
    assert(u.byte_at(0) == 104, "byte_at(0) of 'héllo' should be 104 ('h')")
    assert(u.byte_at(1) == 195, "byte_at(1) of 'héllo' should be 195 (0xC3, first byte of é)")
    assert(u.byte_at(2) == 169, "byte_at(2) of 'héllo' should be 169 (0xA9, second byte of é)")
    assert(u.byte_at(3) == 108, "byte_at(3) of 'héllo' should be 108 ('l')")

    // byte_at never panics across full byte range
    let mut i = 0
    loop {
        if i >= u.len() { break }
        let _ = u.byte_at(i)
        i = i + 1
    }

    io.println("All byte_at tests passed!")
}
