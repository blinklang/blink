import std.net.{TcpSocket, tcp_connect}

type Timer {
    ms: Int
}

trait TimerOps {
    fn elapsed(self) -> Int
}

impl TimerOps for Timer {
    fn elapsed(self) -> Int {
        self.ms
    }
}

fn make_timer() -> Result[Timer, Str] {
    Ok(Timer { ms: 100 })
}

test "struct method on variable named socket (C reserved word)" {
    let socket = TcpSocket { fd: -1 }
    socket.close()
}

test "struct field access on variable named socket" {
    let socket = TcpSocket { fd: 42 }
    assert_eq(socket.fd, 42)
}

test "match Ok binding with C reserved name socket" {
    let result = tcp_connect("192.0.2.1", 1)
    if result.is_ok() {
        match result {
            Ok(socket) => {
                assert(socket.fd >= 0)
                socket.close()
            }
            Err(_e) => {}
        }
    }
}

test "match Ok binding with C reserved name time" {
    let result = make_timer()
    match result {
        Ok(time) => {
            assert_eq(time.elapsed(), 100)
        }
        Err(_e) => {
            assert(false)
        }
    }
}

test "let binding with C reserved name time" {
    let time = Timer { ms: 200 }
    assert_eq(time.elapsed(), 200)
}

test "let binding with C reserved name log" {
    let log = Timer { ms: 300 }
    assert_eq(log.ms, 300)
}
