fn main() {
    let s = "abc"
    let c0 = s.char_at(0)
    assert(c0.is_some(), "char_at(0) on 'abc' should be Some")
    assert(c0.unwrap() == 'a', "char_at(0) should be 'a'")
    let c1 = s.char_at(1)
    assert(c1.unwrap() == 'b', "char_at(1) should be 'b'")
    let c2 = s.char_at(2)
    assert(c2.unwrap() == 'c', "char_at(2) should be 'c'")
    let out_of_bounds = s.char_at(3)
    assert(out_of_bounds.is_none(), "char_at(3) on length-3 string should be None")
    let neg = s.char_at(-1)
    assert(neg.is_none(), "char_at(-1) should be None")
    let empty = ""
    let empty_c = empty.char_at(0)
    assert(empty_c.is_none(), "char_at(0) on empty string should be None")
    io.println("All char_at tests passed!")
}
