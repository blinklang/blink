fn main() {
    let s = "abc"
    let c0 = s.char_at(0)
    assert(c0.is_some(), "char_at(0) on 'abc' should be Some")
    assert(c0.unwrap() == 'a', "char_at(0) should be 'a'")
    let c2 = s.char_at(2)
    assert(c2.unwrap() == 'c', "char_at(2) should be 'c'")

    let oob = s.char_at(3)
    assert(oob.is_none(), "char_at(3) on length-3 string should be None")

    // "héllo": h=byte 0x68, é=bytes 0xC3 0xA9 (U+00E9), l, l, o
    let u = "héllo"
    let h = u.char_at(0)
    assert(h.is_some(), "char_at(0) of multi-byte string should be Some")
    assert(h.unwrap() == 'h', "char_at(0) should be 'h'")

    // é starts at byte index 1; U+00E9 = 233
    let e_accent = u.char_at(1)
    assert(e_accent.is_some(), "char_at(1) should be Some (start of e-acute)")
    assert(e_accent.unwrap().to_int() == 233, "char_at(1) should have code point 233 (U+00E9)")

    // byte index 2 is a UTF-8 continuation byte — returns None
    let continuation = u.char_at(2)
    assert(continuation.is_none(), "char_at(2) on UTF-8 continuation byte should be None")

    io.println("All char_at Unicode tests passed!")
}
