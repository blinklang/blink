fn main() {
    let c = 'A'
    let i = c.to_int()
    assert(i == 65, "Char.to_int() should return codepoint")
    let s = c.to_str()
    assert(s == "A", "Char.to_str() should return single-char string")
    let ok = Char.from_code_point(65)
    assert(ok.is_ok(), "65 should be a valid codepoint")
    let recovered = ok.unwrap()
    assert(recovered == 'A', "from_code_point(65) should be 'A'")
    let surrogate = Char.from_code_point(55296)
    assert(surrogate.is_err(), "surrogate 55296 (0xD800) should fail")
    let high_surrogate = Char.from_code_point(57343)
    assert(high_surrogate.is_err(), "surrogate 57343 (0xDFFF) should fail")
    let overflow = Char.from_code_point(1114112)
    assert(overflow.is_err(), "1114112 (0x110000) is above max codepoint")
    let negative = Char.from_code_point(-1)
    assert(negative.is_err(), "negative codepoint should fail")
    let max_valid = Char.from_code_point(1114111)
    assert(max_valid.is_ok(), "1114111 (0x10FFFF) should be valid")
    let max_ascii = Char.from_code_point(127)
    assert(max_ascii.is_ok(), "127 should be valid")
    io.println("All char conversion tests passed!")
}
