fn main() {
    let a = 'a'
    assert(a.to_int() == 97, "char 'a' should have codepoint 97")
    let z = 'z'
    assert(z.to_int() == 122, "char 'z' should have codepoint 122")
    let newline = '\n'
    assert(newline.to_int() == 10, "char '\\n' should have codepoint 10")
    let tab = '\t'
    assert(tab.to_int() == 9, "char '\\t' should have codepoint 9")
    let cr = '\r'
    assert(cr.to_int() == 13, "char '\\r' should have codepoint 13")
    let backslash = '\\'
    assert(backslash.to_int() == 92, "char '\\\\' should have codepoint 92")
    let squote = '\''
    assert(squote.to_int() == 39, "char '\\'' should have codepoint 39")
    let nul = '\0'
    assert(nul.to_int() == 0, "char '\\0' should have codepoint 0")
    let space = ' '
    assert(space.to_int() == 32, "char ' ' should have codepoint 32")
    let excl: Char = '!'
    assert(excl.to_int() == 33, "char '!' should have codepoint 33")
    let c1: Char = 'a'
    let c2: Char = 'a'
    assert(c1 == c2, "equal chars should compare equal")
    let c3: Char = 'b'
    assert(c1 < c3, "'a' should be less than 'b'")
    assert(c3 > c1, "'b' should be greater than 'a'")
    io.println("All char literal tests passed!")
}
