// End-to-end CLI workflow: blink init → create git lib → blink add --git → build → run
// Tests the full package management user journey through the CLI.

fn trim_newlines(s: Str) -> Str {
    let mut end = s.len()
    while end > 0 {
        let ch = s.char_at(end - 1)
        if ch == 10 || ch == 13 {
            end = end - 1
        } else {
            return s.substring(0, end)
        }
    }
    ""
}

fn main() {
    let base = ".tmp/_test_cli_pkg"
    shell_exec("rm -rf {base}")
    shell_exec("mkdir -p {base}")

    // Step 1: Create a git library
    shell_exec("mkdir -p {base}/mathlib/src")
    write_file("{base}/mathlib/blink.toml", "[package]\nname = \"mathlib\"\nversion = \"0.1.0\"\n\n[dependencies]\n")
    write_file("{base}/mathlib/src/lib.bl", "pub fn add(a: Int, b: Int) -> Int \{\n    a + b\n\}\n")
    shell_exec("cd {base}/mathlib && git init && git add -A && git commit -m 'init' > /dev/null 2>&1")
    shell_exec("cd {base}/mathlib && git tag v0.1.0")

    let abs_result = process_run("sh", ["-c", "cd {base}/mathlib && pwd -P"])
    let lib_path = trim_newlines(abs_result.out)
    let git_url = "file://{lib_path}"

    // Get absolute path to blink binary
    let blink_abs = process_run("sh", ["-c", "pwd -P"])
    let blink_root = trim_newlines(blink_abs.out)

    // Step 2: Create a consumer project using blink init
    // blink init creates files in CWD, so make a subdir first
    let proj = "{base}/myapp"
    shell_exec("mkdir -p {proj}")
    let init_result = process_run("sh", ["-c", "cd {proj} && {blink_root}/build/blink init myapp 2>&1"])
    if init_result.exit_code != 0 {
        io.println("FAIL: blink init failed: {init_result.out}")
        shell_exec("rm -rf {base}")
        return
    }
    io.println("PASS: blink init created project")

    if file_exists("{proj}/blink.toml") == 0 && file_exists("{proj}/blink.toml") == 0 {
        io.println("FAIL: blink init did not create blink.toml")
        shell_exec("rm -rf {base}")
        return
    }
    if file_exists("{proj}/src/main.bl") == 0 {
        io.println("FAIL: blink init did not create src/main.bl")
        shell_exec("rm -rf {base}")
        return
    }

    // Step 3: Add git dependency
    let add_result = process_run("sh", ["-c", "cd {proj} && {blink_root}/build/blink add mathlib --git {git_url} --tag v0.1.0 2>&1"])
    if add_result.out.starts_with("error") {
        io.println("FAIL: blink add failed: {add_result.out}")
        shell_exec("rm -rf {base}")
        return
    }
    io.println("PASS: blink add --git succeeded")

    if file_exists("{proj}/blink.lock") == 0 && file_exists("{proj}/blink.lock") == 0 {
        io.println("FAIL: blink add did not create lock file")
        shell_exec("rm -rf {base}")
        return
    }
    io.println("PASS: lock file created")

    // Step 4: Write main.bl that uses the dependency
    write_file("{proj}/src/main.bl", "import mathlib.\{add\}\n\nfn main() \{\n    if add(2, 3) == 5 \{\n        io.println(\"correct\")\n    \} else \{\n        io.println(\"wrong\")\n    \}\n\}\n")

    // Step 5: Build using blink build
    let build_result = process_run("sh", ["-c", "cd {proj} && {blink_root}/build/blink build src/main.bl 2>&1"])
    if build_result.exit_code != 0 {
        io.println("FAIL: blink build failed: {build_result.out}")
        shell_exec("rm -rf {base}")
        return
    }
    io.println("PASS: blink build succeeded")

    // Step 6: Run the built binary
    let run_result = process_run("sh", ["-c", "cd {proj} && ./build/main 2>&1"])
    let output = trim_newlines(run_result.out)
    if output == "correct" {
        io.println("PASS: built binary produced correct output")
    } else {
        io.println("FAIL: expected 'correct', got: '{output}'")
    }

    // Cleanup
    shell_exec("rm -rf {base}")
}
