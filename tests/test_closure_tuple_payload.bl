fn dispatch_tuple3(t: (Int, Int, Int), body: fn((Int, Int, Int)) -> Void) {
    body(t)
}

test "closure with annotated tuple-3 payload destructures inside body" {
    let mut sum = 0
    dispatch_tuple3((1, 2, 3), fn(case: (Int, Int, Int)) {
        let (a, b, expected) = case
        assert_eq(a, 1)
        assert_eq(b, 2)
        assert_eq(expected, 3)
        sum = a + b + expected
    })
    assert_eq(sum, 6)
}

fn dispatch_pair(t: (Str, Int), body: fn((Str, Int)) -> Void) {
    body(t)
}

test "closure with annotated (Str, Int) payload binds both fields" {
    let mut label = ""
    let mut value = 0
    dispatch_pair(("alpha", 7), fn(case: (Str, Int)) {
        let (l, v) = case
        label = l
        value = v
    })
    assert_eq(label, "alpha")
    assert_eq(value, 7)
}
