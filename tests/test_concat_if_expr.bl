test "concat in if-expression" {
    let a = "hello"
    let b = " world"
    let x = if true { a.concat(b) } else { "fallback" }
    assert_eq(x, "hello world")
}

test "concat in else branch" {
    let a = "foo"
    let b = "bar"
    let x = if false { "fallback" } else { a.concat(b) }
    assert_eq(x, "foobar")
}

test "method call in if-expression" {
    let s = "HELLO"
    let x = if true { s.to_lower() } else { "nope" }
    assert_eq(x, "hello")
}
