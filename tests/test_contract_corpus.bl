// Phase 7: differential-test corpus driver.
//
// Each corpus fixture exercises a single predicate against a hand-picked
// environment, with a known expected outcome. Today these are pure runtime
// checks — but the corpus is the conformance bar that any future SMT
// backend (3fnthw) must reproduce identically. If SMT and runtime ever
// diverge on any of these fixtures, that's a hard failure.

import compile_test_helpers

// ── @requires fixtures ───────────────────────────────────────────────

test "corpus: requires(x > 0) holds at x=1" {
    let src = "@requires(x > 0)\nfn pos(x: Int) -> Int \{ x }\nfn main() \{ pos(1) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_pos_1")
    assert(r.exit_code == 0)
}

test "corpus: requires(x > 0) fails at x=0" {
    let src = "@requires(x > 0)\nfn pos(x: Int) -> Int \{ x }\nfn main() \{ pos(0) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_pos_0")
    assert(r.exit_code != 0)
}

test "corpus: requires(x > 0) fails at x=-5" {
    let src = "@requires(x > 0)\nfn pos(x: Int) -> Int \{ x }\nfn main() \{ pos(0 - 5) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_pos_neg")
    assert(r.exit_code != 0)
}

test "corpus: requires(a + b == c) holds for 2+3==5" {
    let src = "@requires(a + b == c)\nfn add_eq(a: Int, b: Int, c: Int) -> Int \{ c }\nfn main() \{ add_eq(2, 3, 5) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_addeq_pass")
    assert(r.exit_code == 0)
}

test "corpus: requires(a + b == c) fails for 2+3==6" {
    let src = "@requires(a + b == c)\nfn add_eq(a: Int, b: Int, c: Int) -> Int \{ c }\nfn main() \{ add_eq(2, 3, 6) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_addeq_fail")
    assert(r.exit_code != 0)
}

// ── @ensures fixtures ────────────────────────────────────────────────

test "corpus: ensures(result == x) holds for identity" {
    let src = "@ensures(result == x)\nfn id(x: Int) -> Int \{ x }\nfn main() \{ id(42) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_ens_id")
    assert(r.exit_code == 0)
}

test "corpus: ensures(result >= x) holds for x+1" {
    let src = "@ensures(result >= x)\nfn inc(x: Int) -> Int \{ x + 1 }\nfn main() \{ inc(7) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_ens_inc")
    assert(r.exit_code == 0)
}

test "corpus: ensures(result == old(x)) holds when fn returns input" {
    let src = "@ensures(result == old(x))\nfn echo(x: Int) -> Int \{ x }\nfn main() \{ echo(99) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_ens_old_id")
    assert(r.exit_code == 0)
}

test "corpus: ensures(result > old(x)) fails when result == old(x)" {
    let src = "@ensures(result > old(x))\nfn bad_id(x: Int) -> Int \{ x }\nfn main() \{ bad_id(5) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_ens_old_strict")
    assert(r.exit_code != 0)
}

// ── @where fixtures ─────────────────────────────────────────────────

test "corpus: where(self > 0 && self <= 65535) holds at 80" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn id_port(p: Port) -> Port \{ p }\nfn main() \{ id_port(80) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_where_port_ok")
    assert(r.exit_code == 0)
}

test "corpus: where(self > 0 && self <= 65535) fails at 0" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn id_port(p: Port) -> Port \{ p }\nfn main() \{ id_port(0) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_where_port_zero")
    assert(r.exit_code != 0)
}

test "corpus: where(self > 0 && self <= 65535) fails at 70000" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn id_port(p: Port) -> Port \{ p }\nfn main() \{ id_port(70000) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_where_port_high")
    assert(r.exit_code != 0)
}

// ── Boolean composition ──────────────────────────────────────────────

test "corpus: requires(x > 0 && x < 100) holds at 50" {
    let src = "@requires(x > 0 && x < 100)\nfn mid(x: Int) -> Int \{ x }\nfn main() \{ mid(50) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_and_pass")
    assert(r.exit_code == 0)
}

test "corpus: requires(x > 0 && x < 100) fails at 100 (boundary)" {
    let src = "@requires(x > 0 && x < 100)\nfn mid(x: Int) -> Int \{ x }\nfn main() \{ mid(100) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_and_boundary")
    assert(r.exit_code != 0)
}

test "corpus: requires(x == 0 || x == 1) holds at 0" {
    let src = "@requires(x == 0 || x == 1)\nfn bit(x: Int) -> Int \{ x }\nfn main() \{ bit(0) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_or_zero")
    assert(r.exit_code == 0)
}

test "corpus: requires(x == 0 || x == 1) fails at 2" {
    let src = "@requires(x == 0 || x == 1)\nfn bit(x: Int) -> Int \{ x }\nfn main() \{ bit(2) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_corpus_req_or_two")
    assert(r.exit_code != 0)
}
