import test_cross_module_effects_helper { Telemetry, emit_metric }

test "cross-module user effect with handler" {
    with handler Telemetry {
        fn record(name: Str, value: Int) {
            io.println("[CAPTURED] {name}={value}")
        }
    } {
        emit_metric("cpu", 99)
    }
    assert(true)
}

test "cross-module user effect default handler" {
    telemetry.record("mem", 42)
    assert(true)
}
