import std.term.{is_tty}
import std.args.{argparser_new, add_flag, generate_help}

test "importing std.term and std.args together works" {
    let tty = is_tty()
    assert(tty == 0 || tty == 1)

    let mut p = argparser_new("test", "A test tool")
    p = add_flag(p, "--verbose", "-v", "Verbose output")
    let help = generate_help(p)
    assert(help.contains("--verbose"))
}
