import std.db.{DB}

test "db.connect creates scoped handler" {
    with db.connect(":memory:") {
        db.exec("CREATE TABLE t (v INT)").unwrap()
        db.exec("INSERT INTO t VALUES (42)").unwrap()
        let rows = db.query("SELECT v FROM t").unwrap()
        assert_eq(rows.len(), 1)
        assert_eq(rows.get(0).unwrap().get_int("v").unwrap(), 42)
    }
}

test "db.exec handles PRAGMA statements" {
    with db.connect(":memory:") {
        db.exec("PRAGMA busy_timeout=5000").unwrap()
        let rows = db.query("PRAGMA busy_timeout").unwrap()
        assert_eq(rows.len(), 1)
        assert_eq(rows.get(0).unwrap().get_int("timeout").unwrap(), 5000)
    }
}

test "db.connect with query_one" {
    with db.connect(":memory:") {
        db.exec("CREATE TABLE items (name TEXT, price INT)").unwrap()
        db.exec("INSERT INTO items VALUES ('Widget', 99)").unwrap()
        let item = db.query_one("SELECT price FROM items WHERE name = 'Widget'").unwrap().unwrap()
        assert_eq(item.get_int("price").unwrap(), 99)
    }
}
