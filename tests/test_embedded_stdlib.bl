// Regression guard: lib/std modules must stay importable through the embedded stdlib registry.

import std.libc.{POLL_EVT_IN}
import std.arena.{bytes_used}
import std.float.{fabs, is_nan}

test "std.libc / std.arena / std.float remain importable" {
    assert_eq(POLL_EVT_IN, 1)
    assert_eq(bytes_used(), 0)
    assert_eq(fabs(0.0 - 1.5), 1.5)
    assert_eq(is_nan(0.0), false)
}
