// Phase 3 of the runtime-contracts project: @ensures runtime codegen.
//
// At every function-return site we bind `result` to the return value,
// evaluate the postcondition, and abort with E1308 on failure. `old(_)`
// expressions are snapshotted at function entry into per-occurrence
// temporaries so the postcondition can compare entry-state to result.

import compile_test_helpers

// ── Codegen sanity: emitted C contains the postcondition check ────────

test "@ensures: emitted C contains a postcondition assert" {
    let src = "@ensures(result > x)\nfn ev_inc(x: Int) -> Int \{ x + 1 }\nfn main() \{ ev_inc(1) }\n"
    let c = compile_test_helpers.compile_and_emit_c(src, "_ens_emit_inc")
    assert(c.contains("postcondition failed"))
}

test "@ensures: snapshot var declared at fn entry for old(_)" {
    let src = "@ensures(result == old(x))\nfn ev_id(x: Int) -> Int \{ x }\nfn main() \{ ev_id(1) }\n"
    let c = compile_test_helpers.compile_and_emit_c(src, "_ens_emit_old")
    assert(c.contains("__old_"))
}

// ── Acceptance: passing @ensures runs cleanly to exit 0 ───────────────

test "@ensures runtime: satisfied postcondition exits 0" {
    let src = "@ensures(result > x)\nfn ev_inc(x: Int) -> Int \{ x + 1 }\nfn main() \{\n    let r = ev_inc(2)\n    assert(r == 3)\n}\n"
    let r = compile_test_helpers.compile_and_run(src, "_ens_run_ok")
    assert(r.exit_code == 0)
}

test "@ensures runtime: result binds to actual return value" {
    let src = "@ensures(result == old(x) + 1)\nfn ev_inc(x: Int) -> Int \{ x + 1 }\nfn main() \{\n    let r = ev_inc(5)\n    assert(r == 6)\n}\n"
    let r = compile_test_helpers.compile_and_run(src, "_ens_run_old")
    assert(r.exit_code == 0)
}

test "@ensures runtime: multiple @ensures all enforced (passing)" {
    let src = "@ensures(result >= 0)\n@ensures(result == old(x))\nfn ev_id(x: Int) -> Int \{ x }\nfn main() \{ ev_id(7) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_ens_run_multi")
    assert(r.exit_code == 0)
}

test "@ensures runtime: composed with @requires (passing)" {
    let src = "@requires(x > 0)\n@ensures(result > x)\nfn ev_inc(x: Int) -> Int \{ x + 1 }\nfn main() \{ ev_inc(3) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_ens_run_with_req")
    assert(r.exit_code == 0)
}

// ── Rejection: violated @ensures aborts at runtime ────────────────────

test "@ensures runtime: violated postcondition aborts non-zero" {
    let src = "@ensures(result > 100)\nfn ev_bad(x: Int) -> Int \{ x }\nfn main() \{ ev_bad(1) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_ens_run_fail")
    assert(r.exit_code != 0)
    assert(r.err_out.contains("postcondition failed"))
}

test "@ensures runtime: old() captures entry-state, not exit-state" {
    // result == old(x) + 1 where x is unmodified: holds.
    let src = "@ensures(result == old(x) + 1)\nfn ev_inc(x: Int) -> Int \{ x + 1 }\nfn main() \{ ev_inc(10) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_ens_run_old_ok")
    assert(r.exit_code == 0)
}
