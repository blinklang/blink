// Tests E1008 InvalidModuleAnnotation on the package entry file:
// when src/<pkg>.bl declares @module(X) where X != [package].name, reject.

fn main() {
    let base = ".tmp/_test_entry_module_mismatch"
    shell_exec("rm -rf {base}")
    let blink = "../../../bin/blink"

    shell_exec("mkdir -p {base}/mismatchlib/src")
    shell_exec("mkdir -p {base}/app/src")
    // [package].name = "mismatchlib" but @module says "wrong"
    write_file("{base}/mismatchlib/blink.toml", "[package]\nname = \"mismatchlib\"\nversion = \"0.1.0\"\n")
    write_file("{base}/mismatchlib/src/mismatchlib.bl", "@module(\"wrong\")\n\npub fn hi() -> Str \{\n    \"hi\"\n}\n")

    write_file("{base}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n\n[dependencies]\nmismatchlib = \{ path = \"../mismatchlib\" \}\n")
    write_file("{base}/app/src/main.bl", "import mismatchlib.\{hi\}\n\nfn main() \{\n    io.println(hi())\n}\n")

    shell_exec("cd {base}/app && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err = read_file("{base}/app/err.txt")
    if err.contains("InvalidModuleAnnotation") {
        io.println("PASS: entry-file @module mismatch with [package].name emits InvalidModuleAnnotation/E1008")
    } else {
        io.println("FAIL: expected InvalidModuleAnnotation for entry-file @module mismatch, got: {err}")
    }

    // --- Test 2: matching @module on entry is accepted ---
    let base2 = ".tmp/_test_entry_module_match"
    shell_exec("rm -rf {base2}")
    shell_exec("mkdir -p {base2}/matchlib/src")
    shell_exec("mkdir -p {base2}/app/src")
    write_file("{base2}/matchlib/blink.toml", "[package]\nname = \"matchlib\"\nversion = \"0.1.0\"\n")
    write_file("{base2}/matchlib/src/matchlib.bl", "@module(\"matchlib\")\n\npub fn hi() -> Str \{\n    \"hello-match\"\n}\n")

    write_file("{base2}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n\n[dependencies]\nmatchlib = \{ path = \"../matchlib\" \}\n")
    write_file("{base2}/app/src/main.bl", "import matchlib.\{hi\}\n\nfn main() \{\n    io.println(hi())\n}\n")

    shell_exec("cd {base2}/app && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err2 = read_file("{base2}/app/err.txt")
    if err2.contains("InvalidModuleAnnotation") {
        io.println("FAIL: matching entry @module should not emit InvalidModuleAnnotation, got: {err2}")
    } else {
        io.println("PASS: matching entry @module accepted")
    }

    shell_exec("rm -rf {base}")
    shell_exec("rm -rf {base2}")
}
