// Tests for struct-style enum variant declaration, construction, and matching.
// Bug: parser/typecheck did not support `Variant { field: Type }` syntax.

type Shape {
    Circle(radius: Float)
    Rect { width: Float, height: Float }
    Point
}

fn describe(s: Shape) -> Str {
    match s {
        Shape.Circle(r) => "circle:{r}"
        Shape.Rect { width, height } => "rect:{width}x{height}"
        Shape.Point => "point"
    }
}

type Msg {
    Simple(text: Str)
    Rich { code: Int, message: Str }
}

fn format_msg(m: Msg) -> Str {
    match m {
        Msg.Simple(t) => t
        Msg.Rich { code, message } => "{code}: {message}"
    }
}

test "struct variant construction and match" {
    let r = Shape.Rect { width: 3.0, height: 4.0 }
    assert_eq(describe(r), "rect:3x4")
}

test "tuple variant still works alongside struct variant" {
    let c = Shape.Circle(5.0)
    assert_eq(describe(c), "circle:5")
}

test "unit variant still works alongside struct variant" {
    let p = Shape.Point
    assert_eq(describe(p), "point")
}

test "struct variant with Str and Int fields" {
    let m = Msg.Rich { code: 42, message: "hello" }
    assert_eq(format_msg(m), "42: hello")
}

test "tuple variant alongside struct variant (Msg)" {
    let m = Msg.Simple("world")
    assert_eq(format_msg(m), "world")
}
