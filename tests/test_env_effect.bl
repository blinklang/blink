test "env.var reads PATH" {
    let path = env.var("PATH") ?? "not set"
    assert_ne(path, "not set")
}

test "env.var returns None for missing var" {
    let missing = env.var("__BLINK_NONEXISTENT_VAR__") ?? "fallback"
    assert_eq(missing, "fallback")
}

test "env.cwd returns a directory" {
    let cwd = env.cwd()
    assert(cwd.len() > 0)
}

test "env.set_var and env.var round-trip" {
    env.set_var("__BLINK_TEST_VAR__", "hello")
    let val = env.var("__BLINK_TEST_VAR__") ?? "missing"
    assert_eq(val, "hello")
}

test "env.remove_var removes variable" {
    env.set_var("__BLINK_REMOVE_TEST__", "present")
    env.remove_var("__BLINK_REMOVE_TEST__")
    let val = env.var("__BLINK_REMOVE_TEST__") ?? "gone"
    assert_eq(val, "gone")
}

test "env.args returns at least one element" {
    let args = env.args()
    assert(args.len() > 0)
}
