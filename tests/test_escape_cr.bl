fn main() {
    let crlf = "\r\n"
    let cr_code = crlf.byte_at(0)
    let lf_code = crlf.byte_at(1)
    assert_eq(cr_code, 13)
    assert_eq(lf_code, 10)
    assert_eq(crlf.len(), 2)

    let cr_only = "\r"
    assert_eq(cr_only.byte_at(0), 13)
    assert_eq(cr_only.len(), 1)

    io.println("PASS: \\r escape sequence produces CR (0x0D)")
}
