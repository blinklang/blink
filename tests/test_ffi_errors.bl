fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "pub on FFI function emits E0801" {
    let src = "@ffi(\"strlen\")\npub fn c_strlen(s: Ptr[U8]) -> Int ! FFI \{ \}\nfn main() \{ \}\n"
    expect_compile_error(src, "ffi_pub", "E0801")
}

test "FFI without effects emits E0802" {
    let src = "@ffi(\"strlen\")\n@trusted\nfn c_strlen(s: Ptr[U8]) -> Int \{ \}\nfn main() \{ \}\n"
    expect_compile_error(src, "ffi_noeff", "E0802")
}

test "contract on FFI emits E0803" {
    let src = "@ffi(\"strlen\")\n@trusted\n@requires(true)\nfn c_strlen(s: Ptr[U8]) -> Int ! FFI \{ \}\nfn main() \{ \}\n"
    expect_compile_error(src, "ffi_contract", "E0803")
}

test "Ptr with invalid inner type emits E0810" {
    let src = "@ffi(\"test\")\n@trusted\nfn bad(p: Ptr[Str]) -> Int ! FFI \{ \}\nfn main() \{ \}\n"
    expect_compile_error(src, "ffi_ptrtype", "E0810")
}

test "Ptr outside FFI emits E0811" {
    let src = "fn bad(_p: Ptr[U8]) -> Int \{ 0 \}\nfn main() \{ \}\n"
    expect_compile_error(src, "ffi_ptrout", "E0811")
}
