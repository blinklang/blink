// Tests that an FFI function taking I32 (a sized int) compiles and runs correctly.
// isatty(fd) returns 1 if fd is a terminal, 0 otherwise.
// In CI, fd 0 (stdin) is typically not a tty, so result will be 0.
// Either outcome (0 or 1) is valid — we just verify it doesn't crash and
// returns a sensible value.

@ffi("isatty")
@trusted
fn c_isatty(fd: I32) -> I32 ! FFI { }

fn main() {
    // fd 0 = stdin; result is 0 (not a tty) or 1 (is a tty)
    let result: I32 = c_isatty(0)
    assert(result == 0 || result == 1)

    // fd 1 = stdout
    let result_stdout: I32 = c_isatty(1)
    assert(result_stdout == 0 || result_stdout == 1)

    // fd 999 = invalid fd; isatty returns 0
    let result_invalid: I32 = c_isatty(999)
    assert(result_invalid == 0)

    io.println("FFI isatty tests passed!")
}
