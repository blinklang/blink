// Regression (br wsvenm): formatter must preserve escaped quotes inside a
// test-block name. Input `test "a\"b" {}` was being re-emitted as
// `test "a"b" {}` (unparseable) because format_test_block emitted the
// parser-decoded name without routing through fmt_escape_str_literal.

fn main() {
    let blink_root = process_run("sh", ["-c", "pwd -P"]).out.trim_right()
    let blinkc = "{blink_root}/build/blinkc"

    let base = ".tmp/_test_fmt_test_name_quote_escape"
    shell_exec("rm -rf {base}")
    shell_exec("mkdir -p {base}")

    let src_path = "{base}/in.bl"
    let src_body = "test \"a\\\"b\" \{\n    assert_eq(1, 1)\n\}\n"
    write_file(src_path, src_body)

    let fmt1_path = "{base}/fmt1.bl"
    let r1 = process_run(blinkc, [src_path, fmt1_path, "--emit", "blink"])
    if r1.exit_code != 0 {
        io.println("FAIL: blinkc --emit blink (pass 1) exited {r1.exit_code}: {r1.out}")
        shell_exec("rm -rf {base}")
        return
    }
    let fmt1 = read_file(fmt1_path)

    if !fmt1.contains("\\\"") {
        io.println("FAIL: formatted output dropped `\\\"` escape — got: {fmt1}")
        shell_exec("rm -rf {base}")
        return
    }

    let fmt2_path = "{base}/fmt2.bl"
    let r2 = process_run(blinkc, [fmt1_path, fmt2_path, "--emit", "blink"])
    if r2.exit_code != 0 {
        io.println("FAIL: blinkc --emit blink (pass 2) exited {r2.exit_code}: {r2.out}")
        shell_exec("rm -rf {base}")
        return
    }
    let fmt2 = read_file(fmt2_path)
    if fmt1 != fmt2 {
        io.println("FAIL: formatter not idempotent")
        io.println("pass 1: {fmt1}")
        io.println("pass 2: {fmt2}")
        shell_exec("rm -rf {base}")
        return
    }

    io.println("PASS: formatter preserves test-name quote escape and round-trips")
    shell_exec("rm -rf {base}")
}
