/// User-defined `connect` must not shadow net.connect intrinsic
fn connect(_host: Str, _port: Int) -> Int {
    42
}

/// User-defined `close` must not shadow net.close intrinsic
fn close(_fd: Int) {
}

fn use_net_connect() -> Int {
    net.connect("localhost", 1)
}

fn use_net_close(fd: Int) {
    net.close(fd)
}

test "net.connect intrinsic not shadowed by user connect" {
    let fd = use_net_connect()
    assert(fd < 0)
}

test "user connect is still callable" {
    let r = connect("localhost", 80)
    assert_eq(r, 42)
}

test "user close is still callable" {
    close(5)
    assert(true)
}
