// Test that user functions named after builtin types/runtime identifiers
// don't collide with blink_* C runtime struct typedefs

fn set() -> Int {
    42
}

fn map() -> Str {
    "mapped"
}

fn list() -> Int {
    99
}

fn bytes() -> Int {
    7
}

fn channel() -> Str {
    "chan"
}

test "user fn named set alongside Set type" {
    let result = set()
    assert_eq(result, 42)
    let s: Set[Str] = Set()
    s.insert("hello")
    assert_eq(s.len(), 1)
}

test "user fn named map alongside Map type" {
    let result = map()
    assert_eq(result, "mapped")
    let m: Map[Str, Int] = Map()
    m.set("key", 10)
    assert_eq(m.get("key"), 10)
}

test "user fn named list alongside List type" {
    let result = list()
    assert_eq(result, 99)
    let items: List[Int] = [1, 2, 3]
    assert_eq(items.len(), 3)
}

test "user fn named bytes alongside Bytes type" {
    let result = bytes()
    assert_eq(result, 7)
    let b = Bytes()
    b.push(65)
    assert_eq(b.len(), 1)
}

test "user fn named channel" {
    let result = channel()
    assert_eq(result, "chan")
}
