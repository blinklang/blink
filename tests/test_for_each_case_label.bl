// When a for_each case fails, the test runner JSON output must include the
// active case label as a "case" field so consumers can tell which case failed
// (not just the parent test name). We shell out to `bin/blink test --json` on
// a fixture file that contains a failing for_each, then inspect the JSON for
// "case":"<label>".

test "for_each case label appears in JSON failure record" {
    let fixture = ".tmp/_test_for_each_label_fail.bl"
    let src = "import std.testing.\{for_each\}\n\ntest \"failing_for_each\" \{\n    for_each([\n        (\"alpha\", 1),\n        (\"bravo\", 2),\n    ], fn(v: Int) \{\n        assert_eq(v, 1)\n    \})\n\}\n"
    write_file(fixture, src)
    let result = process_run("bin/blink", ["test", "--json", fixture])
    let output = result.out.concat(result.err_out)
    let needle_fail = "\"status\":\"fail\""
    let needle_bravo = "\"case\":\"bravo\""
    assert(output.contains(needle_fail), "expected status:fail in JSON output")
    assert(output.contains(needle_bravo), "expected case:bravo in JSON failure record")
    shell_exec("rm -f {fixture}")
}

test "for_each passing case does not emit stale label in fail records" {
    let fixture = ".tmp/_test_for_each_label_pass.bl"
    let src = "import std.testing.\{for_each\}\n\ntest \"passing_for_each\" \{\n    for_each([\n        (\"first\", 1),\n        (\"second\", 2),\n    ], fn(v: Int) \{\n        assert(v > 0)\n    \})\n\}\n"
    write_file(fixture, src)
    let result = process_run("bin/blink", ["test", "--json", fixture])
    let output = result.out.concat(result.err_out)
    let needle_pass = "\"status\":\"pass\""
    assert(output.contains(needle_pass), "expected status:pass in JSON")
    shell_exec("rm -f {fixture}")
}
