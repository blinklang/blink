test "for in map.keys() inline" {
    let m: Map[Str, Int] = Map()
    m.set("a", 1)
    m.set("b", 2)
    m.set("c", 3)

    let mut count = 0
    for k in m.keys() {
        assert(k.len() > 0, "key should be a string")
        count = count + 1
    }
    assert_eq(count, 3)
}

test "for in map.values() inline" {
    let m: Map[Str, Int] = Map()
    m.set("x", 10)
    m.set("y", 20)

    let mut total = 0
    for v in m.values() {
        total = total + v
    }
    assert_eq(total, 30)
}
