fn main() {
    let ok = Char.try_from_code_point(65)
    assert(ok.is_ok(), "65 is valid")
    assert(ok.unwrap() == 'A', "should be 'A'")
    let err1 = Char.try_from_code_point(55296)
    assert(err1.is_err(), "55296 (0xD800) is a surrogate")
    let err2 = Char.try_from_code_point(57343)
    assert(err2.is_err(), "57343 (0xDFFF) is a surrogate")
    let err3 = Char.try_from_code_point(1114112)
    assert(err3.is_err(), "1114112 (0x110000) exceeds max codepoint")
    let err4 = Char.try_from_code_point(-1)
    assert(err4.is_err(), "-1 is invalid")
    let ok2 = Char.try_from_code_point(1114111)
    assert(ok2.is_ok(), "1114111 (0x10FFFF) is the max valid codepoint")
    let ok3 = Char.try_from_code_point(0)
    assert(ok3.is_ok(), "NUL codepoint 0 is valid")
    io.println("All try_from_code_point tests passed!")
}
