test "fuzz: random input does not crash compiler" {
    let result = process_run("sh", ["scripts/fuzz.sh", "build/blinkc", "50", "42", "3", "--ignore-timeouts"])
    let output = "{result.out}{result.err_out}"
    if output.contains("CRASH") {
        io.eprintln(output)
        assert(false)
    }
}
