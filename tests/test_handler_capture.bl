effect Counter {
    effect Ops {
        fn get_value() -> Int
    }
}

fn read_counter() -> Int ! Counter.Ops {
    counter.get_value()
}

test "handler captures local variable" {
    let x = 42
    with handler Counter {
        fn get_value() -> Int {
            x
        }
    } {
        let result = read_counter()
        assert_eq(result, 42)
    }
}

test "nested handlers with different captures" {
    let a = 10
    let b = 20
    with handler Counter {
        fn get_value() -> Int {
            a
        }
    } {
        assert_eq(read_counter(), 10)
        with handler Counter {
            fn get_value() -> Int {
                b
            }
        } {
            assert_eq(read_counter(), 20)
        }
        assert_eq(read_counter(), 10)
    }
}
