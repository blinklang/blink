fn make_io_handler() -> Handler[IO] {
    handler IO {
        fn print(_msg: Str) {
        }
        fn log(_msg: Str) {
        }
    }
}

fn use_handler(h: Handler[IO]) {
    with h {
        io.println("via param")
    }
}

test "handler returned from function" {
    let h = make_io_handler()
    with h {
        io.println("inside handler from return")
    }
    assert(true)
}

test "handler let binding" {
    let h: Handler[IO] = handler IO {
        fn print(_msg: Str) {
        }
    }
    with h {
        io.println("inside handler from let")
    }
    assert(true)
}

test "handler as function param" {
    let h = make_io_handler()
    use_handler(h)
    assert(true)
}
