// Regression tests for rde75m:
// `infer_expr_type` previously returned CT_VOID for chained
// `.unwrap` / `.unwrap_or` / `.unwrap_err` on a MethodCall whose receiver was
// a Call (not an Ident or Map.get). In if-expr tail position, that drove
// emit_if_expr down the void-fallback path, producing `const void s = 0;`
// and segfaulting on subsequent string ops like strcmp(NULL, ...).

fn produce_some() -> Option[Str] { Some("hello") }
fn produce_none() -> Option[Str] { None }

fn produce_ok() -> Result[Str, Str] { Ok("ok-val") }
fn produce_err() -> Result[Str, Str] { Err("err-val") }

test "Option.unwrap on Call receiver in if-expr tail" {
    let s = if 1 == 1 { produce_some().unwrap() } else { "fallback" }
    assert_eq(s, "hello")
}

test "Result.unwrap on Call receiver in if-expr tail" {
    let s = if 1 == 1 { produce_ok().unwrap() } else { "fallback" }
    assert_eq(s, "ok-val")
}

test "Result.unwrap_err on Call receiver in if-expr tail" {
    let s = if 1 == 1 { produce_err().unwrap_err() } else { "fallback" }
    assert_eq(s, "err-val")
}

test "Option.unwrap on Call receiver as direct if-expr tail (no let)" {
    assert_eq(if 1 == 1 { produce_some().unwrap() } else { "fallback" }, "hello")
}
