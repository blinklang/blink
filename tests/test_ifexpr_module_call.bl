import std.term

test "if-expr with module-qualified function call" {
    let s = "hello"
    let x = if true { term.cyan(s) } else { s }
    assert(x.contains("hello"))
}

test "if-expr with module call in else branch" {
    let s = "world"
    let x = if false { s } else { term.red(s) }
    assert(x.contains("world"))
}

test "if-expr with module calls in both branches" {
    let s = "test"
    let x = if true { term.cyan(s) } else { term.red(s) }
    assert(x.contains("test"))
}
