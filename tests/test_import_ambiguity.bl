fn run_cmd(cmd: Str, label: Str) -> Int {
    let rc = shell_exec(cmd)
    if rc != 0 {
        io.println("FAIL: {label} (rc={rc})")
    }
    rc
}

fn check_output(path: Str, expected: Str, label: Str) {
    shell_exec("{path} > {path}_out.txt 2>&1 || true")
    let output = read_file("{path}_out.txt")
    if output.starts_with(expected) {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected '{expected}', got: {output}")
    }
}

fn main() {
    let base = ".tmp/_test_import_ambiguity"
    shell_exec("rm -rf {base}")
    let pact = "../../../bin/blink"

    // Create two libs with same pub fn name
    shell_exec("mkdir -p {base}/libA/src")
    write_file("{base}/libA/blink.toml", "[package]\nname = \"libA\"\nversion = \"0.1.0\"\n")
    write_file("{base}/libA/src/lib.bl", "pub fn process(x: Int) -> Int \{\n    x + 1\n}\n\npub fn only_a() -> Int \{\n    42\n}\n")

    shell_exec("mkdir -p {base}/libB/src")
    write_file("{base}/libB/blink.toml", "[package]\nname = \"libB\"\nversion = \"0.1.0\"\n")
    write_file("{base}/libB/src/lib.bl", "pub fn process(x: Int) -> Int \{\n    x * 2\n}\n\npub fn only_b() -> Int \{\n    99\n}\n")

    shell_exec("mkdir -p {base}/app/src")
    write_file(
        "{base}/app/blink.toml",
        "[package]\nname = \"app\"\nversion = \"1.0.0\"\n\n[dependencies]\nlibA = \{ path = \"../libA\" }\nlibB = \{ path = \"../libB\" }\n"
    )

    // Test 1: Two imports with same name — E1005 error
    write_file(
        "{base}/app/src/t1.bl",
        "import libA\nimport libB\n\nfn main() \{\n    io.println(\"\{process(5)\}\")\n}\n"
    )
    shell_exec("mkdir -p {base}/app/build")
    let rc1 = shell_exec("cd {base}/app && {pact} build src/t1.bl -o build/t1 > ../err1.txt 2>&1")
    if rc1 == 0 {
        io.println("FAIL: ambiguous import should produce error")
    } else {
        let err = read_file("{base}/err1.txt")
        if err.contains("ambiguous") || err.contains("E1005") {
            io.println("PASS: ambiguous import detected")
        } else {
            io.println("FAIL: expected ambiguity error, got: {err}")
        }
    }

    // Test 2: Non-conflicting unique names from single module
    write_file(
        "{base}/app/src/t2.bl",
        "import libA\n\nfn main() \{\n    io.println(\"\{only_a()\}\")\n}\n"
    )
    let rc2 = run_cmd("cd {base}/app && {pact} build src/t2.bl -o build/t2 2>&1", "build single module non-conflicting")
    if rc2 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t2", "42", "single module non-conflicting import")

    // Test 3: Two modules with NO conflicting names — no ambiguity
    shell_exec("mkdir -p {base}/libC/src")
    write_file("{base}/libC/blink.toml", "[package]\nname = \"libC\"\nversion = \"0.1.0\"\n")
    write_file("{base}/libC/src/lib.bl", "pub fn greet() -> Int \{\n    100\n}\n")
    shell_exec("mkdir -p {base}/libD/src")
    write_file("{base}/libD/blink.toml", "[package]\nname = \"libD\"\nversion = \"0.1.0\"\n")
    write_file("{base}/libD/src/lib.bl", "pub fn farewell() -> Int \{\n    200\n}\n")
    write_file(
        "{base}/app/blink.toml",
        "[package]\nname = \"app\"\nversion = \"1.0.0\"\n\n[dependencies]\nlibC = \{ path = \"../libC\" }\nlibD = \{ path = \"../libD\" }\n"
    )
    write_file(
        "{base}/app/src/t3.bl",
        "import libC\nimport libD\n\nfn main() \{\n    io.println(\"\{greet() + farewell()\}\")\n}\n"
    )
    let rc3 = run_cmd("cd {base}/app && {pact} build src/t3.bl -o build/t3 2>&1", "build two modules no conflict")
    if rc3 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t3", "300", "two modules no conflicting names")

    shell_exec("rm -rf {base}")
}
