// From/TryFrom for sized integer types.
// Spec §03c_protocols.md:271-497.

// ── Widening: From (infallible) ──────────────────────────────────────────

test "From: I8 widens to I16" {
    let x: I8 = 42
    let y: I16 = I16.from(x)
    assert_eq(y.to_int(), 42)
}

test "From: I8 widens to I32" {
    let x: I8 = -5
    let y: I32 = I32.from(x)
    assert_eq(y.to_int(), -5)
}

test "From: I8 widens to Int" {
    let x: I8 = 100
    let y: Int = Int.from(x)
    assert_eq(y, 100)
}

test "From: I16 widens to I32" {
    let x: I16 = 1000
    let y: I32 = I32.from(x)
    assert_eq(y.to_int(), 1000)
}

test "From: I16 widens to Int" {
    let x: I16 = -32000
    let y: Int = Int.from(x)
    assert_eq(y, -32000)
}

test "From: I32 widens to Int" {
    let x: I32 = -2000000000
    let y: Int = Int.from(x)
    assert_eq(y, -2000000000)
}

test "From: U8 widens to U16" {
    let x: U8 = 200
    let y: U16 = U16.from(x)
    assert_eq(y.to_int(), 200)
}

test "From: U8 widens to U32" {
    let x: U8 = 200
    let y: U32 = U32.from(x)
    assert_eq(y.to_int(), 200)
}

test "From: U8 widens to U64" {
    let x: U8 = 200
    let y: U64 = U64.from(x)
    assert_eq(y.to_int(), 200)
}

test "From: U8 widens to I16" {
    let x: U8 = 250
    let y: I16 = I16.from(x)
    assert_eq(y.to_int(), 250)
}

test "From: U8 widens to I32" {
    let x: U8 = 250
    let y: I32 = I32.from(x)
    assert_eq(y.to_int(), 250)
}

test "From: U8 widens to Int" {
    let x: U8 = 250
    let y: Int = Int.from(x)
    assert_eq(y, 250)
}

test "From: U16 widens to U32" {
    let x: U16 = 60000
    let y: U32 = U32.from(x)
    assert_eq(y.to_int(), 60000)
}

test "From: U16 widens to U64" {
    let x: U16 = 60000
    let y: U64 = U64.from(x)
    assert_eq(y.to_int(), 60000)
}

test "From: U16 widens to I32" {
    let x: U16 = 60000
    let y: I32 = I32.from(x)
    assert_eq(y.to_int(), 60000)
}

test "From: U16 widens to Int" {
    let x: U16 = 60000
    let y: Int = Int.from(x)
    assert_eq(y, 60000)
}

test "From: U32 widens to U64" {
    let x: U32 = 4000000000
    let y: U64 = U64.from(x)
    assert_eq(y.to_int(), 4000000000)
}

test "From: U32 widens to Int" {
    let x: U32 = 4000000000
    let y: Int = Int.from(x)
    assert_eq(y, 4000000000)
}

// ── Into: auto-derived from From ─────────────────────────────────────────

test "Into: I8 to I16 via .into()" {
    let x: I8 = 7
    let y: I16 = x.into()
    assert_eq(y.to_int(), 7)
}

test "Into: U8 to Int via .into()" {
    let x: U8 = 99
    let y: Int = x.into()
    assert_eq(y, 99)
}

// ── Narrowing: TryFrom (fallible) ────────────────────────────────────────

test "TryFrom: Int to I8 in range succeeds" {
    let r = I8.try_from(100)
    assert(r.is_ok())
}

test "TryFrom: Int to I8 above max fails" {
    let r = I8.try_from(200)
    assert(r.is_err())
}

test "TryFrom: Int to I8 below min fails" {
    let r = I8.try_from(-200)
    assert(r.is_err())
}

test "TryFrom: Int to I16 in range succeeds" {
    let r = I16.try_from(30000)
    assert(r.is_ok())
}

test "TryFrom: Int to I16 above max fails" {
    let r = I16.try_from(40000)
    assert(r.is_err())
}

test "TryFrom: Int to I32 in range succeeds" {
    let r = I32.try_from(2000000000)
    assert(r.is_ok())
}

test "TryFrom: Int to I32 above max fails" {
    let r = I32.try_from(3000000000)
    assert(r.is_err())
}

test "TryFrom: Int to U8 in range succeeds" {
    let r = U8.try_from(200)
    assert(r.is_ok())
}

test "TryFrom: Int to U8 above max fails" {
    let r = U8.try_from(300)
    assert(r.is_err())
}

test "TryFrom: Int to U8 negative fails" {
    let r = U8.try_from(-1)
    assert(r.is_err())
}

test "TryFrom: Int to U16 negative fails" {
    let r = U16.try_from(-1)
    assert(r.is_err())
}

test "TryFrom: Int to U32 above max fails" {
    let r = U32.try_from(5000000000)
    assert(r.is_err())
}

test "TryFrom: Int to U64 negative fails" {
    let r = U64.try_from(-1)
    assert(r.is_err())
}

test "TryFrom error carries source/target type names" {
    let r = I8.try_from(500)
    match r {
        Ok(_) => assert(false)
        Err(e) => {
            assert_eq(e.source_type, "Int")
            assert_eq(e.target_type, "I8")
        }
    }
}

// ── Narrowing across sized types ─────────────────────────────────────────

test "TryFrom: I32 to I8 in range succeeds" {
    let x: I32 = 50
    let r = I8.try_from(x)
    assert(r.is_ok())
}

test "TryFrom: I32 to I8 out of range fails" {
    let x: I32 = 500
    let r = I8.try_from(x)
    assert(r.is_err())
}

test "TryFrom: U64 to U8 in range succeeds" {
    let x: U64 = 100
    let r = U8.try_from(x)
    assert(r.is_ok())
}

test "TryFrom: U64 to U8 out of range fails" {
    let x: U64 = 1000
    let r = U8.try_from(x)
    assert(r.is_err())
}
