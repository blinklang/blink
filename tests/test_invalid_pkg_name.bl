// Tests E1011 InvalidPackageName: [package].name must match [a-z][a-z0-9_]*

fn main() {
    let base = ".tmp/_test_invalid_pkg_name"
    shell_exec("rm -rf {base}")
    let blink = "../../../bin/blink"

    // --- Test 1: hyphen in name ---
    shell_exec("mkdir -p {base}/badhyphen/src")
    write_file("{base}/badhyphen/blink.toml", "[package]\nname = \"bad-name\"\nversion = \"0.1.0\"\n")
    write_file("{base}/badhyphen/src/badname.bl", "pub fn x() -> Int \{ 1 \}\n")
    write_file("{base}/badhyphen/src/main.bl", "fn main() \{ io.println(\"x\") }\n")
    shell_exec("cd {base}/badhyphen && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err1 = read_file("{base}/badhyphen/err.txt")
    if err1.contains("E1011") || err1.contains("invalid") {
        io.println("PASS: hyphen in package name rejected with E1011")
    } else {
        io.println("FAIL: expected E1011 for hyphen, got: {err1}")
    }

    // --- Test 2: leading digit ---
    shell_exec("mkdir -p {base}/baddigit/src")
    write_file("{base}/baddigit/blink.toml", "[package]\nname = \"1bad\"\nversion = \"0.1.0\"\n")
    write_file("{base}/baddigit/src/main.bl", "fn main() \{ io.println(\"x\") }\n")
    shell_exec("cd {base}/baddigit && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err2 = read_file("{base}/baddigit/err.txt")
    if err2.contains("E1011") || err2.contains("invalid") {
        io.println("PASS: leading digit in package name rejected with E1011")
    } else {
        io.println("FAIL: expected E1011 for leading digit, got: {err2}")
    }

    // --- Test 3: uppercase ---
    shell_exec("mkdir -p {base}/badupper/src")
    write_file("{base}/badupper/blink.toml", "[package]\nname = \"BadName\"\nversion = \"0.1.0\"\n")
    write_file("{base}/badupper/src/main.bl", "fn main() \{ io.println(\"x\") }\n")
    shell_exec("cd {base}/badupper && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err3 = read_file("{base}/badupper/err.txt")
    if err3.contains("E1011") || err3.contains("invalid") {
        io.println("PASS: uppercase in package name rejected with E1011")
    } else {
        io.println("FAIL: expected E1011 for uppercase, got: {err3}")
    }

    // --- Test 4: valid name passes ---
    shell_exec("mkdir -p {base}/goodname/src")
    write_file("{base}/goodname/blink.toml", "[package]\nname = \"good_name_42\"\nversion = \"0.1.0\"\n")
    write_file("{base}/goodname/src/good_name_42.bl", "pub fn x() -> Int \{ 42 \}\n")
    write_file("{base}/goodname/src/main.bl", "fn main() \{ io.println(\"42\") }\n")
    shell_exec("cd {base}/goodname && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err4 = read_file("{base}/goodname/err.txt")
    if err4.contains("E1011") || err4.contains("invalid") {
        io.println("FAIL: valid package name 'good_name_42' should not emit E1011, got: {err4}")
    } else {
        io.println("PASS: valid package name 'good_name_42' accepted")
    }

    shell_exec("rm -rf {base}")
}
