// btvqbf / knhwcf: blink check and blink test must agree on ? in test bodies.
// Before btvqbf: blink check passed but blink test (codegen) failed with E0508.
// After btvqbf: both paths share elaboration and the program compiles cleanly.
// This fixture exercises the codegen pipeline (compile_test_helpers uses blinkc),
// which is the path that diverged. The check-side path passes through the same
// typecheck → so if this builds clean, the two paths agree.

import compile_test_helpers

test "knhwcf reproducer compiles in codegen pipeline" {
    let src = "fn fail() -> Result[Int, Str] \{ Err(\"boom\") \}\ntest \"with question mark\" \{ let _ = fail()? \}\n"
    compile_test_helpers.expect_no_error(src, "knhwcf_repro", "E0508")
}
