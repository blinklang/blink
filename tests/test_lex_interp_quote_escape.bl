fn id(s: Str) -> Str { s }

fn main() {
    // Escaped double-quote inside an interpolation expression should
    // not terminate the outer string literal. Both `"foo"` and `\"foo\"`
    // forms must be accepted inside `{ ... }`.
    let a = "{id(\"foo\")}"
    assert_eq(a, "foo")

    let b = "prefix-{id(\"bar\")}-suffix"
    assert_eq(b, "prefix-bar-suffix")

    // Mix escaped and unescaped quotes — both denote a literal "
    let c = "{id(\"x\") + id("y")}"
    assert_eq(c, "xy")

    // Nested interpolations: \" inside the inner string is just an escape
    let d = "{id("{id(\"z\")}")}"
    assert_eq(d, "z")
}
