import std.db_row.{Row}

fn make_rows() -> List[Row] {
    let r1 = Row { data: ["Alice", "30"], columns: ["name", "age"] }
    let r2 = Row { data: ["Bob", "25"], columns: ["name", "age"] }
    [r1, r2]
}

test "list elem type does not leak through struct method returning list" {
    let rows = make_rows()
    let alice = rows.get(0).unwrap()
    let cols = alice.column_names()
    let first_col = cols.get(0).unwrap()
    assert_eq(first_col, "name")
}
