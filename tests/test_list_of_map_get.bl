// Regression test for bug 08mp8h:
// List[Map[K,V]].get(i).unwrap() must preserve the inner Map[K,V] type
// so that chained method calls (e.g. .get on the map) resolve correctly.

fn main() {
    let mut s: List[Map[Str, Int]] = []
    let mut m: Map[Str, Int] = Map()
    m.insert("a", 1)
    s.push(m)

    let f = s.get(0).unwrap()
    let key = "a"
    io.println("{f.get(key).unwrap()}")

    // Expected: 1
}
