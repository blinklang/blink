type Sensor { value: Int }

trait Readable {
    fn read(self) -> Int
}

impl Readable for Sensor {
    fn read(self) -> Int {
        self.value
    }
}

fn get_reading(s: Sensor) -> Int {
    // "time" shadows the time module namespace
    // time.read() is both a module function and a trait method on Sensor
    let time = s
    let result = if true { time.read() } else { 0 }
    result
}

test "local var shadowing module name - method call in if-expr" {
    let s = Sensor { value: 42 }
    assert_eq(get_reading(s), 42)
}
