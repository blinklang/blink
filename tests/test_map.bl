test "basic map operations" {
    let m: Map[Str, Int] = Map()
    m.insert("a", 1)
    m.insert("b", 2)
    m.insert("c", 3)

    assert_eq(m.len(), 3)
    assert_eq(m.get("a").unwrap(), 1)
    assert_eq(m.get("b").unwrap(), 2)
    assert_eq(m.contains_key("a"), true)
    assert_eq(m.contains_key("z"), false)
}

test "update existing key" {
    let m: Map[Str, Int] = Map()
    m.insert("a", 1)
    m.insert("a", 42)
    assert_eq(m.get("a").unwrap(), 42)
}

test "remove key" {
    let m: Map[Str, Int] = Map()
    m.insert("a", 1)
    m.insert("b", 2)
    m.insert("c", 3)
    m.remove("b")
    assert_eq(m.len(), 2)
    assert_eq(m.contains_key("b"), false)
}

test "keys and values" {
    let m: Map[Str, Int] = Map()
    m.insert("a", 1)
    m.insert("c", 3)
    assert_eq(m.keys().len(), 2)
    assert_eq(m.values().len(), 2)
}

test "string value map" {
    let m2: Map[Str, Str] = Map()
    m2.insert("hello", "world")
    m2.insert("foo", "bar")
    assert_eq(m2.get("hello").unwrap(), "world")
    assert_eq(m2.len(), 2)
}
