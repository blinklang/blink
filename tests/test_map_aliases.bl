type Point {
    x: Int
    y: Int
}

test "insert as alias for set with ints" {
    let m: Map[Str, Int] = Map()
    m.insert("a", 1)
    m.insert("b", 2)
    assert_eq(m.get("a"), 1)
    assert_eq(m.get("b"), 2)
    assert_eq(m.len(), 2)
}

test "insert as alias for set with strings" {
    let m: Map[Str, Str] = Map()
    m.insert("hello", "world")
    m.insert("foo", "bar")
    assert_eq(m.get("hello"), "world")
    assert_eq(m.get("foo"), "bar")
}

test "contains_key as alias for has" {
    let m: Map[Str, Int] = Map()
    m.set("x", 10)
    assert_eq(m.contains_key("x"), true)
    assert_eq(m.contains_key("y"), false)
}

test "get_opt returns Some for existing key" {
    let m: Map[Str, Int] = Map()
    m.set("a", 42)
    let result = m.get_opt("a")
    assert_eq(result.is_some(), 1)
    assert_eq(result.unwrap(), 42)
}

test "get_opt returns None for missing key" {
    let m: Map[Str, Int] = Map()
    let result = m.get_opt("missing")
    assert_eq(result.is_none(), 1)
    let v = result ?? 0
    assert_eq(v, 0)
}

test "get_opt with string values" {
    let m: Map[Str, Str] = Map()
    m.set("key", "value")
    let result = m.get_opt("key")
    assert_eq(result.unwrap(), "value")
    let missing = m.get_opt("nope")
    assert_eq(missing.is_none(), 1)
}

test "get_opt with struct values" {
    let m: Map[Str, Point] = Map()
    m.set("origin", Point{x: 0, y: 0})
    m.set("p1", Point{x: 3, y: 4})
    let result = m.get_opt("p1")
    assert_eq(result.is_some(), 1)
    let p = result.unwrap()
    assert_eq(p.x, 3)
    assert_eq(p.y, 4)
    let missing = m.get_opt("p2")
    assert_eq(missing.is_none(), 1)
}

test "insert with struct values" {
    let m: Map[Str, Point] = Map()
    m.insert("pt", Point{x: 5, y: 10})
    let p = m.get("pt")
    assert_eq(p.x, 5)
    assert_eq(p.y, 10)
}
