test "get_opt on Map[Str, List[Str]] with coalesce" {
    let m: Map[Str, List[Str]] = Map()
    m.insert("k", ["a", "b"])
    let v = m.get_opt("k") ?? []
    assert_eq(v.get(0).unwrap(), "a")
    assert_eq(v.get(1).unwrap(), "b")
}

test "get_opt on Map[Str, List[Str]] with match" {
    let m: Map[Str, List[Str]] = Map()
    m.insert("k", ["hello"])
    match m.get_opt("k") {
        Some(lst) => {
            assert_eq(lst.get(0).unwrap(), "hello")
        }
        None => {
            assert_eq(1, 0)
        }
    }
}

test "get_opt on Map[Str, List[Str]] returns None for missing" {
    let m: Map[Str, List[Str]] = Map()
    let v = m.get_opt("missing") ?? []
    assert_eq(v.len(), 0)
}

test "get_opt on Map[Str, List[Int]] with coalesce" {
    let m: Map[Str, List[Int]] = Map()
    m.insert("nums", [10, 20, 30])
    let v = m.get_opt("nums") ?? []
    assert_eq(v.get(0).unwrap(), 10)
    assert_eq(v.len(), 3)
}

fn lookup_list(m: Map[Str, List[Str]], key: Str) -> List[Str] {
    m.get_opt(key) ?? []
}

test "get_opt on Map[Str, List[Str]] passed as function param" {
    let m: Map[Str, List[Str]] = Map()
    m.insert("colors", ["red", "blue"])
    let result = lookup_list(m, "colors")
    assert_eq(result.get(0).unwrap(), "red")
    assert_eq(result.get(1).unwrap(), "blue")
    let empty = lookup_list(m, "missing")
    assert_eq(empty.len(), 0)
}
