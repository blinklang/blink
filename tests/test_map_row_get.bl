import std.db_row.{Row}

fn lookup(m: Map[Str, Row], key: Str) -> Row {
    m.get(key).unwrap()
}

test "Map[Str, Row] get returns Row struct" {
    let m: Map[Str, Row] = Map()
    m.insert("alice", Row { data: ["alice", "30"], columns: ["name", "age"] })

    let result = lookup(m, "alice")
    assert_eq(result.get("name").unwrap(), "alice")
    assert_eq(result.get_int("age").unwrap(), 30)
}

test "Map[Str, Row] get preserves column access" {
    let m: Map[Str, Row] = Map()
    m.insert("a", Row { data: ["x", "10"], columns: ["name", "val"] })
    m.insert("b", Row { data: ["y", "20"], columns: ["name", "val"] })

    let a = m.get("a").unwrap()
    let b = m.get("b").unwrap()
    assert_eq(a.get("name").unwrap(), "x")
    assert_eq(b.get("val").unwrap(), "20")
}
