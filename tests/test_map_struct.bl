type Point {
    x: Int
    y: Int
}

test "map with struct values" {
    let m: Map[Str, Point] = Map()
    let p = Point { x: 10, y: 20 }
    m.set("origin", p)

    let got = m.get("origin")
    assert_eq(got.x, 10)
    assert_eq(got.y, 20)
}

test "map struct update" {
    let m: Map[Str, Point] = Map()
    m.set("a", Point { x: 1, y: 2 })
    m.set("a", Point { x: 3, y: 4 })

    let got = m.get("a")
    assert_eq(got.x, 3)
    assert_eq(got.y, 4)
}

test "map struct multiple keys" {
    let m: Map[Str, Point] = Map()
    m.set("p1", Point { x: 1, y: 2 })
    m.set("p2", Point { x: 3, y: 4 })

    let p1 = m.get("p1")
    let p2 = m.get("p2")
    assert_eq(p1.x, 1)
    assert_eq(p2.x, 3)
}
