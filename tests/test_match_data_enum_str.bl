type NetError {
    Timeout(message: Str)
    ConnectionRefused(message: Str)
    Code(code: Int)
}

fn get_error_message(e: NetError) -> Str {
    match e {
        NetError.Timeout(m) => m
        NetError.ConnectionRefused(m) => m
        NetError.Code(c) => "{c}"
    }
}

fn get_error_code(e: NetError) -> Int {
    match e {
        NetError.Timeout(_m) => -1
        NetError.ConnectionRefused(_m) => -2
        NetError.Code(c) => c
    }
}

test "match data enum returns string field" {
    let e1 = NetError.Timeout("timed out")
    assert_eq(get_error_message(e1), "timed out")

    let e2 = NetError.ConnectionRefused("refused")
    assert_eq(get_error_message(e2), "refused")

    let e3 = NetError.Code(404)
    assert_eq(get_error_message(e3), "404")
}

test "match data enum returns int field" {
    let e1 = NetError.Code(500)
    assert_eq(get_error_code(e1), 500)

    let e2 = NetError.Timeout("oops")
    assert_eq(get_error_code(e2), -1)
}
