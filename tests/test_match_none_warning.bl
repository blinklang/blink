fn check_option(opt: Option[Int]) -> Str {
    match opt {
        Some(v) => "got {v}"
        None => "nothing"
    }
}

fn check_bare_ok(res: Result[Int, Str]) -> Int {
    match res {
        Ok(v) => v
        Err(_e) => -1
    }
}

test "match None arm no false warning" {
    let r = check_option(None)
    assert_eq(r, "nothing")
    let r2 = check_option(Some(42))
    assert_eq(r2, "got 42")
}

test "match Ok/Err arms no false warning" {
    let r = check_bare_ok(Ok(1))
    assert_eq(r, 1)
    let r2 = check_bare_ok(Err("fail"))
    assert_eq(r2, -1)
}
