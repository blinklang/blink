pub type Item { fd: I32, name: Str }

fn make() -> Option[List[Item]] {
    Some([Item { fd: 7, name: "a" }, Item { fd: 9, name: "b" }])
}

fn empty() -> Option[List[Item]] {
    None
}

fn main() {
    match make() {
        Some(out) => {
            let p = out.get(0).unwrap()
            assert_eq(p.fd, 7)
            assert_eq(p.name, "a")
            assert_eq(out.len(), 2)
        }
        None => assert(false)
    }
    match empty() {
        Some(_) => assert(false)
        None => assert(true)
    }
}
