// Phase 5 of the runtime-contracts project: @modifies parse-and-validate.
//
// `@modifies(args)` is reserved syntax for SMT frame conditions later. Today
// it has no runtime effect; we only ensure the surface area stays
// SMT-promotable. The existing annotation-arg parser already gates calls,
// expressions, and wildcards (E1100). What we add here is acceptance tests
// proving the supported forms parse cleanly and a rejection test for
// kv-pair argument forms which are not meaningful for @modifies.

import compile_test_helpers

// ── Acceptance: simple paths are allowed ───────────────────────────────

test "@modifies(simple ident) is accepted" {
    let src = "@modifies(x)\nfn bump(x: Int) -> Int \{ x + 1 }\nfn main() \{ bump(0) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_mod_ident")
    assert(!out.contains("E1308"))
    assert(!out.contains("E1100"))
}

test "@modifies(nothing) is accepted as a frame-pure marker" {
    let src = "@modifies(nothing)\nfn pure_id(x: Int) -> Int \{ x }\nfn main() \{ pure_id(0) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_mod_nothing")
    assert(!out.contains("E1308"))
    assert(!out.contains("E1100"))
}

// ── Rejection: parser-gated call forms ────────────────────────────────

test "@modifies rejects a function-call argument at parse time" {
    let src = "@modifies(f())\nfn bad(x: Int) -> Int \{ x }\nfn main() \{ bad(0) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_mod_call")
    assert(out.contains("E1100"))
}

test "@modifies rejects wildcard at parse time" {
    let src = "@modifies(*)\nfn bad(x: Int) -> Int \{ x }\nfn main() \{ bad(0) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_mod_star")
    assert(out.contains("E1100"))
}

// ── Rejection: validator catches kv-pair form ─────────────────────────

test "@modifies rejects kv-pair argument form" {
    let src = "@modifies(x: y)\nfn bad(x: Int) -> Int \{ x }\nfn main() \{ bad(0) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_mod_kvp")
    assert(out.contains("E1308"))
}
