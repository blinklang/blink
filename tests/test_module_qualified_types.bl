import std.net

fn connect_test(host: Str, port: Int) -> Result[net.TcpSocket, net.NetError] {
    net.tcp_connect(host, port)
}

fn maybe_socket() -> Option[net.TcpSocket] {
    None
}

test "module-qualified types in Result return" {
    let result = connect_test("localhost", 1)
    assert(result.is_err())
}

test "module-qualified type in Option" {
    let result = maybe_socket()
    assert(result.is_none())
}
