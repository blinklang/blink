fn if_with_wrapped_cond(a: Int) -> Int {
    if
        a == 1
    {
        return 1
    }
    0
}

fn while_with_wrapped_cond(n: Int) -> Int {
    let mut i = 0
    let mut acc = 0
    while
        i < n
    {
        acc = acc + i
        i = i + 1
    }
    acc
}

fn else_if_chain_wrapped(score: Int) -> Str {
    if
        score >= 90
    {
        "gold"
    } else if
        score >= 70
    {
        "silver"
    } else {
        "bronze"
    }
}

fn nested_if_wrapped(a: Int, b: Int) -> Int {
    if a > 0 {
        if
            b > 0
        {
            return 1
        }
        return 2
    }
    0
}

test "if-cond with leading newline parses and evaluates" {
    assert_eq(if_with_wrapped_cond(1), 1)
    assert_eq(if_with_wrapped_cond(2), 0)
}

test "while-cond with leading newline parses and evaluates" {
    assert_eq(while_with_wrapped_cond(0), 0)
    assert_eq(while_with_wrapped_cond(5), 10)
}

test "else-if chain with wrapped conds" {
    assert_eq(else_if_chain_wrapped(95), "gold")
    assert_eq(else_if_chain_wrapped(75), "silver")
    assert_eq(else_if_chain_wrapped(50), "bronze")
}

test "nested if with inner wrapped cond" {
    assert_eq(nested_if_wrapped(1, 1), 1)
    assert_eq(nested_if_wrapped(1, -1), 2)
    assert_eq(nested_if_wrapped(-1, 1), 0)
}
