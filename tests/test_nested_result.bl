fn outer() -> Result[Result[Str, Int], Str] {
    Ok(Ok("hello"))
}

fn outer_err() -> Result[Result[Str, Int], Str] {
    Err("outer error")
}

fn outer_inner_err() -> Result[Result[Str, Int], Str] {
    Ok(Err(42))
}

test "nested Result Ok(Ok(value))" {
    let r = outer()
    match r {
        Ok(inner) => {
            match inner {
                Ok(v) => assert_eq(v, "hello")
                Err(_e) => assert(false)
            }
        }
        Err(_e) => assert(false)
    }
}

test "nested Result Err(value)" {
    let r = outer_err()
    match r {
        Ok(_inner) => assert(false)
        Err(e) => assert_eq(e, "outer error")
    }
}

test "nested Result Ok(Err(value))" {
    let r = outer_inner_err()
    match r {
        Ok(inner) => {
            match inner {
                Ok(_v) => assert(false)
                Err(e) => assert_eq(e, 42)
            }
        }
        Err(_e) => assert(false)
    }
}
