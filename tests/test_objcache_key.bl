// Cache-key derivation: every documented field, when changed in
// isolation, must move the key. Keys are 16-hex SHA-256 digests
// computed by `bin/blink cache key` from a manifest fed on stdin.
// Identical manifests must produce identical keys.

fn key_for(manifest: Str) -> Str {
    let res = process_run("bin/blink", ["cache", "key", manifest])
    res.out.trim()
}

let base = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:gcc\nflags:\ntarget:\n"

test "identical manifests produce identical keys" {
    let k1 = key_for(base)
    let k2 = key_for(base)
    assert_eq(k1.len(), 16)
    assert_eq(k1, k2)
}

test "src_sha change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:zzzz\nimports:\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:gcc\nflags:\ntarget:\n"
    let k1 = key_for(base)
    let k2 = key_for(alt)
    assert_eq(k1.len(), 16)
    assert_eq(k2.len(), 16)
    assert(k1 != k2)
}

test "imports change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:bar=99\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:gcc\nflags:\ntarget:\n"
    assert(key_for(base) != key_for(alt))
}

test "runtime_sha change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:ZZ\nblinkc_sha:cc\ncc_id:gcc\nflags:\ntarget:\n"
    assert(key_for(base) != key_for(alt))
}

test "blinkc_sha change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:bb\nblinkc_sha:ZZ\ncc_id:gcc\nflags:\ntarget:\n"
    assert(key_for(base) != key_for(alt))
}

test "cc_id change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:clang\nflags:\ntarget:\n"
    assert(key_for(base) != key_for(alt))
}

test "flags change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:gcc\nflags:-O2\ntarget:\n"
    assert(key_for(base) != key_for(alt))
}

test "target change moves the key" {
    let alt = "schema:1\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:gcc\nflags:\ntarget:aarch64-linux-musl\n"
    assert(key_for(base) != key_for(alt))
}

test "schema bump moves the key" {
    let alt = "schema:2\nmod:foo\nsrc_sha:aaaa\nimports:\nruntime_sha:bb\nblinkc_sha:cc\ncc_id:gcc\nflags:\ntarget:\n"
    assert(key_for(base) != key_for(alt))
}
