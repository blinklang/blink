// Phase 2 of the runtime-contracts project: old(expr) parsing.
//
// `old(e)` is a real AST node — `NodeKind.OldExpr` — recognized only
// inside contract-annotation arguments (@requires/@ensures/@where).
// Outside @ensures it is rejected with E1305. Nested `old(old(_))` is
// also rejected.

import compile_test_helpers

// ── Acceptance: old(_) is allowed inside @ensures ─────────────────────

test "old(x) is accepted inside @ensures" {
    let src = "@ensures(result == old(x))\nfn ov_id(x: Int) -> Int \{ x }\nfn main() \{ ov_id(1) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_basic")
    assert(!out.contains("E1305"))
    assert(!out.contains("E1300"))
}

test "@ensures may reference old() and result together" {
    let src = "@ensures(result >= old(x))\nfn ov_at_least(x: Int) -> Int \{ x + 1 }\nfn main() \{ ov_at_least(0) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_both")
    assert(!out.contains("E1304"))
    assert(!out.contains("E1305"))
}

test "multiple old() expressions in one @ensures are accepted" {
    let src = "@ensures(old(a) + old(b) == result)\nfn ov_add(a: Int, b: Int) -> Int \{ a + b }\nfn main() \{ ov_add(1, 2) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_multi")
    assert(!out.contains("E1305"))
}

test "old() over a field access is accepted" {
    let src = "type Pt \{ x: Int, y: Int }\n@ensures(result == old(p.x))\nfn ov_xfst(p: Pt) -> Int \{ p.x }\nfn main() \{ ov_xfst(Pt \{ x: 1, y: 2 }) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_field")
    assert(!out.contains("E1305"))
}

// ── Rejection: old() outside @ensures ─────────────────────────────────

test "E1305: old() rejected inside @requires" {
    let src = "@requires(old(x) > 0)\nfn ov_check(x: Int) -> Int \{ x }\nfn main() \{ ov_check(1) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_in_req")
    assert(out.contains("E1305"))
}

test "E1305: old() rejected inside @where" {
    let src = "type Bad = Int @where(old(self) > 0)\nfn main() \{ }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_in_where")
    assert(out.contains("E1305"))
}

test "E1305: nested old(old(x)) rejected" {
    let src = "@ensures(old(old(x)) == result)\nfn ov_bad(x: Int) -> Int \{ x }\nfn main() \{ ov_bad(1) }\n"
    let out = compile_test_helpers.compile_and_capture(src, "_old_nested")
    assert(out.contains("E1305"))
}
