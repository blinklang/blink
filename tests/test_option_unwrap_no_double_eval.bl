fn lookup(m: Map[Str, Str], key: Str, fallback: Str) -> Str {
    let opt = m.get(key)
    if opt.is_some() {
        opt.unwrap()
    } else {
        fallback
    }
}

fn lookup_chained(m: Map[Str, Str], key: Str, fallback: Str) -> Str {
    if m.get(key).is_some() {
        m.get(key).unwrap()
    } else {
        fallback
    }
}

test "Option.unwrap on Map.get via let binding" {
    let mut m = Map()
    m.insert("a", "apple")
    m.insert("b", "banana")

    assert_eq(lookup(m, "a", "miss"), "apple")
    assert_eq(lookup(m, "b", "miss"), "banana")
    assert_eq(lookup(m, "c", "miss"), "miss")
}

test "Option.unwrap on chained Map.get (no double-eval segfault)" {
    let mut m = Map()
    m.insert("x", "xray")
    m.insert("y", "yankee")

    assert_eq(lookup_chained(m, "x", "miss"), "xray")
    assert_eq(lookup_chained(m, "y", "miss"), "yankee")
    assert_eq(lookup_chained(m, "z", "miss"), "miss")
}

test "Option.unwrap on direct Map.get hits all keys" {
    let mut m = Map()
    m.insert("k1", "v1")
    m.insert("k2", "v2")
    m.insert("k3", "v3")

    let mut hits = 0
    let keys = ["k1", "k2", "k3", "miss1", "miss2"]
    for k in keys {
        let opt = m.get(k)
        if opt.is_some() {
            let v = opt.unwrap()
            if v.len() > 0 {
                hits = hits + 1
            }
        }
    }
    assert_eq(hits, 3)
}
