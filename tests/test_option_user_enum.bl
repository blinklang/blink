type Cmd { Quit, Continue }

fn make_some() -> Option[Cmd] {
    Some(Cmd.Quit)
}

fn make_none() -> Option[Cmd] {
    None
}

test "Option[UserEnum] Some carries enum tag" {
    let m = make_some()
    assert_eq(m.is_some(), 1)
}

test "Option[UserEnum] None is none" {
    let m = make_none()
    assert_eq(m.is_some(), 0)
}

test "Option[UserEnum] unwrap returns enum value" {
    let m = make_some()
    let v = m.unwrap()
    match v {
        Cmd.Quit => assert_eq(1, 1)
        Cmd.Continue => assert_eq(0, 1)
    }
}
