// Tests E1010 OrphanFile: a source file with no enclosing blink.toml
// cannot use bare external imports (only std.* / pkg.* / absolute paths).

fn main() {
    let base = ".tmp/_test_orphan_file"
    shell_exec("rm -rf {base}")
    shell_exec("mkdir -p {base}")
    let blink = "../../bin/blink"
    // Note: cd only goes 2 levels deep (.tmp/_test_orphan_file/), so ../../ is correct.

    // --- Test 1: bare external import from orphan file → E1010 ---
    write_file("{base}/orphan.bl", "import notpkg\n\nfn main() \{\n    io.println(\"unreachable\")\n}\n")
    shell_exec("cd {base} && {blink} check orphan.bl > err.txt 2>&1; true")
    let err1 = read_file("{base}/err.txt")
    if err1.contains("OrphanFile") {
        io.println("PASS: orphan file with bare external import emits OrphanFile/E1010")
    } else {
        io.println("FAIL: expected OrphanFile for orphan bare import, got: {err1}")
    }

    // --- Test 2: orphan file with only std import is allowed ---
    write_file("{base}/orphan_std.bl", "import std.path.\{path_join\}\n\nfn main() \{\n    io.println(path_join(\"a\", \"b\"))\n}\n")
    shell_exec("cd {base} && {blink} check orphan_std.bl > err2.txt 2>&1; true")
    let err2 = read_file("{base}/err2.txt")
    if err2.contains("OrphanFile") {
        io.println("FAIL: orphan file with std-only imports should not emit OrphanFile, got: {err2}")
    } else {
        io.println("PASS: orphan file with std-only imports compiles without OrphanFile")
    }

    shell_exec("rm -rf {base}")
}
