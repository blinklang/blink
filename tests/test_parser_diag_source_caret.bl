fn run_human(path: Str, src: Str) -> Str {
    write_file(path, src)
    let args = [path, "/dev/null"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    fs.remove(path)
    output
}

test "diagnostic output includes source line and caret" {
    let src = "fn main() \{\n  let x = 1\n  let y = 2\n  let z = let\n\}\n"
    let output = run_human(".tmp/_test_src_caret.bl", src)
    assert(output.contains("|"))
    assert(output.contains("^"))
    assert(output.contains("let z = let"))
}

test "source line gutter shows correct line number" {
    let src = "fn main() \{\n  let a = 1\n  let b = 2\n  let c = 3\n  let d = 4\n  let e = 5\n  let f = 6\n  let g = 7\n  let h = 8\n  let i = 9\n  let j = 10\n  let bad = let\n\}\n"
    let output = run_human(".tmp/_test_src_lineno.bl", src)
    assert(output.contains("12 |"))
    assert(output.contains("^"))
    assert(output.contains("let bad = let"))
}

test "caret aligns under error column" {
    let src = "fn foo( let\nfn main() \{\}\n"
    let output = run_human(".tmp/_test_caret_align.bl", src)
    assert(output.contains("|"))
    assert(output.contains("^"))
}
