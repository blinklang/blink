fn run_human(path: Str, src: Str) -> Str {
    write_file(path, src)
    let args = [path, "/dev/null"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    fs.remove(path)
    output
}

test "UnexpectedToken message contains token name not raw number" {
    let src = "fn foo( let x = 1 \}\n"
    let output = run_human(".tmp/_test_tok_names.bl", src)
    assert(output.contains("UnexpectedToken"))
    assert(output.contains("let"))
    assert(!output.contains("token kind "))
    assert(!output.contains("got 29"))
    assert(!output.contains("got 57"))
}

test "unexpected top-level token shows name not number" {
    let src = "42\nfn main() \{\}\n"
    let output = run_human(".tmp/_test_tok_toplevel.bl", src)
    assert(output.contains("UnexpectedToken"))
    assert(!output.contains("unexpected token 40"))
    assert(!output.contains("unexpected token 57"))
    assert(!output.contains(": 40"))
    assert(!output.contains(": 57"))
}
