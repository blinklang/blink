fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "inline module emits E1015" {
    let src = "mod schema \{ fn validate() \{ \} \}\nfn main() \{ \}\n"
    expect_compile_error(src, "parse_mod", "E1015")
}

test "unexpected token at top level emits E1100" {
    let src = "42\nfn main() \{ \}\n"
    expect_compile_error(src, "parse_unexp", "E1100")
}

test "keyword as identifier emits E1103" {
    let src = "fn main() \{ let match = 42 \}\n"
    expect_compile_error(src, "parse_kw", "E1103")
}

test "empty braces emits E1107" {
    let src = "fn main() \{ let _m = \{\} \}\n"
    expect_compile_error(src, "parse_empty", "E1107")
}

test "embed nonexistent file emits E1108" {
    let src = "const data: Str = #embed(\"nonexistent_file_xyz.txt\")\nfn main() \{ \}\n"
    expect_compile_error(src, "parse_embed", "E1108")
}
