test "already resolved" {
    shell_exec("rm -rf /tmp/_blink_test_diamond")
    shell_exec("mkdir -p /tmp/_blink_test_diamond/liba/shared/src")
    shell_exec("mkdir -p /tmp/_blink_test_diamond/libb")

    // root depends on liba and libb; both depend on shared
    write_file("/tmp/_blink_test_diamond/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nliba = \{ path = \"liba\" \}\nlibb = \{ path = \"libb\" \}\n")
    write_file("/tmp/_blink_test_diamond/liba/blink.toml", "[package]\nname = \"liba\"\nversion = \"0.1.0\"\n\n[dependencies]\nshared = \{ path = \"shared\" \}\n")
    write_file("/tmp/_blink_test_diamond/liba/shared/blink.toml", "[package]\nname = \"shared\"\nversion = \"0.5.0\"\n")
    write_file("/tmp/_blink_test_diamond/liba/shared/src/shared.bl", "pub fn common() -> Int \{ 42 \}\n")
    // libb also has a copy of shared at a different relative path
    shell_exec("cp -r /tmp/_blink_test_diamond/liba/shared /tmp/_blink_test_diamond/libb/shared")
    write_file("/tmp/_blink_test_diamond/libb/blink.toml", "[package]\nname = \"libb\"\nversion = \"0.2.0\"\n\n[dependencies]\nshared = \{ path = \"shared\" \}\n")

    pathdeps_clear()
    let rc = resolve_path_deps("/tmp/_blink_test_diamond")
    assert_eq(rc, 0)
    // shared should appear only once even though referenced by both A and B
    let mut shared_count = 0
    let mut i = 0
    while i < pathdeps_count() {
        if pathdeps_get_name(i) == "shared" {
            shared_count = shared_count + 1
        }
        i = i + 1
    }
    assert_eq(shared_count, 1)
}

test "hash determinism" {
    shell_exec("rm -rf /tmp/_blink_test_hash1 /tmp/_blink_test_hash2")
    shell_exec("mkdir -p /tmp/_blink_test_hash1/mylib/src")
    shell_exec("mkdir -p /tmp/_blink_test_hash2/mylib/src")

    let manifest_content = "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nmylib = \{ path = \"mylib\" \}\n"
    let dep_manifest = "[package]\nname = \"mylib\"\nversion = \"0.1.0\"\n"
    let lib_content = "pub fn hello() -> Str \{ \"world\" \}\n"

    write_file("/tmp/_blink_test_hash1/blink.toml", manifest_content)
    write_file("/tmp/_blink_test_hash1/mylib/blink.toml", dep_manifest)
    write_file("/tmp/_blink_test_hash1/mylib/src/mylib.bl", lib_content)

    write_file("/tmp/_blink_test_hash2/blink.toml", manifest_content)
    write_file("/tmp/_blink_test_hash2/mylib/blink.toml", dep_manifest)
    write_file("/tmp/_blink_test_hash2/mylib/src/mylib.bl", lib_content)

    pathdeps_clear()
    resolve_path_deps("/tmp/_blink_test_hash1")
    let hash1 = pathdeps_get_hash(0)

    pathdeps_clear()
    resolve_path_deps("/tmp/_blink_test_hash2")
    let hash2 = pathdeps_get_hash(0)

    assert_eq(hash1, hash2)
    assert_eq(hash1.len(), 64)
}

test "capabilities" {
    shell_exec("rm -rf /tmp/_blink_test_caps")
    shell_exec("mkdir -p /tmp/_blink_test_caps/netlib/src")

    write_file("/tmp/_blink_test_caps/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nnetlib = \{ path = \"netlib\" \}\n")
    write_file("/tmp/_blink_test_caps/netlib/blink.toml", "[package]\nname = \"netlib\"\nversion = \"0.1.0\"\n\n[capabilities]\nrequired = [\"Net.Connect\", \"Net.DNS\"]\n")
    write_file("/tmp/_blink_test_caps/netlib/src/netlib.bl", "pub fn fetch() -> Int \{ 0 \}\n")

    pathdeps_clear()
    let rc = resolve_path_deps("/tmp/_blink_test_caps")
    assert_eq(rc, 0)
    assert_eq(pathdeps_get_caps(0), "Net.Connect,Net.DNS")
}

test "cleanup" {
    shell_exec("rm -rf /tmp/_blink_test_single /tmp/_blink_test_trans /tmp/_blink_test_cycle /tmp/_blink_test_missingdir /tmp/_blink_test_nomanifest /tmp/_blink_test_diamond /tmp/_blink_test_hash1 /tmp/_blink_test_hash2 /tmp/_blink_test_caps /tmp/_blink_hash")
}
