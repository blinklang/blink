import pkg.pathdeps.{resolved_names, resolved_versions, resolved_sources, resolved_hashes, resolved_caps, pathdeps_clear, pathdeps_count, pathdeps_get_name, pathdeps_get_version, pathdeps_get_source, pathdeps_get_hash, pathdeps_get_caps, resolve_path_deps}

test "clear" {
    resolved_names.push("test")
    resolved_versions.push("1.0")
    resolved_sources.push("path:/x")
    resolved_hashes.push("abc")
    resolved_caps.push("")

    pathdeps_clear()
    assert_eq(pathdeps_count(), 0)
    assert_eq(pathdeps_get_name(0), "")
}

test "query bounds" {
    pathdeps_clear()
    assert_eq(pathdeps_get_name(-1), "")
    assert_eq(pathdeps_get_version(-1), "")
    assert_eq(pathdeps_get_source(-1), "")
    assert_eq(pathdeps_get_hash(-1), "")
    assert_eq(pathdeps_get_caps(-1), "")
    assert_eq(pathdeps_get_name(99), "")
}

test "single path dep" {
    shell_exec("rm -rf /tmp/_blink_test_single")
    shell_exec("mkdir -p /tmp/_blink_test_single/mylib/src")

    write_file("/tmp/_blink_test_single/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nmylib = \{ path = \"mylib\" \}\n")
    write_file("/tmp/_blink_test_single/mylib/blink.toml", "[package]\nname = \"mylib\"\nversion = \"0.1.0\"\n")
    write_file("/tmp/_blink_test_single/mylib/src/mylib.bl", "pub fn hello() -> Str \{ \"hi\" \}\n")

    pathdeps_clear()
    let rc = resolve_path_deps("/tmp/_blink_test_single")
    assert_eq(rc, 0)
    assert_eq(pathdeps_count(), 1)
    assert_eq(pathdeps_get_name(0), "mylib")
    assert_eq(pathdeps_get_version(0), "0.1.0")
    assert(pathdeps_get_source(0).starts_with("path:"))
    // Hash should be a 64-char hex string
    let hash = pathdeps_get_hash(0)
    assert_eq(hash.len(), 64)
}

test "transitive deps" {
    shell_exec("rm -rf /tmp/_blink_test_trans")
    shell_exec("mkdir -p /tmp/_blink_test_trans/libb/libc/src")
    shell_exec("mkdir -p /tmp/_blink_test_trans/libb/src")

    write_file("/tmp/_blink_test_trans/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nlibb = \{ path = \"libb\" \}\n")
    write_file("/tmp/_blink_test_trans/libb/blink.toml", "[package]\nname = \"libb\"\nversion = \"0.2.0\"\n\n[dependencies]\nlibc = \{ path = \"libc\" \}\n")
    write_file("/tmp/_blink_test_trans/libb/src/libb.bl", "pub fn b() -> Int \{ 2 \}\n")
    write_file("/tmp/_blink_test_trans/libb/libc/blink.toml", "[package]\nname = \"libc\"\nversion = \"0.3.0\"\n")
    write_file("/tmp/_blink_test_trans/libb/libc/src/libc.bl", "pub fn c() -> Int \{ 3 \}\n")

    pathdeps_clear()
    let rc = resolve_path_deps("/tmp/_blink_test_trans")
    assert_eq(rc, 0)
    assert_eq(pathdeps_count(), 2)

    // B should be resolved first, then C (depth-first from B)
    assert_eq(pathdeps_get_name(0), "libb")
    assert_eq(pathdeps_get_name(1), "libc")
    assert_eq(pathdeps_get_version(0), "0.2.0")
    assert_eq(pathdeps_get_version(1), "0.3.0")
}

test "cycle detection" {
    shell_exec("rm -rf /tmp/_blink_test_cycle")
    shell_exec("mkdir -p /tmp/_blink_test_cycle/liba")
    shell_exec("mkdir -p /tmp/_blink_test_cycle/libb")

    write_file("/tmp/_blink_test_cycle/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nliba = \{ path = \"liba\" \}\n")
    // liba depends on libb, libb depends on liba -> cycle
    write_file("/tmp/_blink_test_cycle/liba/blink.toml", "[package]\nname = \"liba\"\nversion = \"0.1.0\"\n\n[dependencies]\nlibb = \{ path = \"../libb\" \}\n")
    write_file("/tmp/_blink_test_cycle/libb/blink.toml", "[package]\nname = \"libb\"\nversion = \"0.1.0\"\n\n[dependencies]\nliba = \{ path = \"../liba\" \}\n")

    pathdeps_clear()
    let rc = resolve_path_deps("/tmp/_blink_test_cycle")
    assert_eq(rc, 1)
}

