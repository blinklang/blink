// Tests E1009 PackageEntryNotFound: when [package].name is "foo" but
// src/foo.bl does not exist, the compiler reports a single expected path.

fn main() {
    let base = ".tmp/_test_pkg_entry_missing"
    shell_exec("rm -rf {base}")
    let blink = "../../../bin/blink"

    shell_exec("mkdir -p {base}/missinglib/src")
    shell_exec("mkdir -p {base}/app/src")
    // Manifest says name = "missinglib", but no src/missinglib.bl is written
    write_file("{base}/missinglib/blink.toml", "[package]\nname = \"missinglib\"\nversion = \"0.1.0\"\n")
    // Write a sibling file (NOT the entry) so the package isn't completely empty
    write_file("{base}/missinglib/src/other.bl", "pub fn other() -> Int \{ 1 \}\n")

    write_file("{base}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n\n[dependencies]\nmissinglib = \{ path = \"../missinglib\" \}\n")
    write_file("{base}/app/src/main.bl", "import missinglib\n\nfn main() \{\n    io.println(\"unreachable\")\n}\n")

    shell_exec("cd {base}/app && {blink} build src/main.bl -o build/app > err.txt 2>&1; true")
    let err = read_file("{base}/app/err.txt")
    if err.contains("PackageEntryNotFound") {
        io.println("PASS: missing entry file emits PackageEntryNotFound/E1009")
    } else {
        io.println("FAIL: expected PackageEntryNotFound for missing entry file, got: {err}")
    }
    if err.contains("missinglib.bl") {
        io.println("PASS: E1009 names the expected entry path")
    } else {
        io.println("FAIL: E1009 should name 'missinglib.bl', got: {err}")
    }

    shell_exec("rm -rf {base}")
}
