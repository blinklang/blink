// Tests that bare `import <pkg>` resolves to <pkg-root>/src/<pkg>.bl.

fn main() {
    let base = ".tmp/_test_pkg_entry_resolution"
    shell_exec("rm -rf {base}")
    let blink = "../../../bin/blink"

    shell_exec("mkdir -p {base}/foolib/src")
    shell_exec("mkdir -p {base}/app/src")
    write_file("{base}/foolib/blink.toml", "[package]\nname = \"foolib\"\nversion = \"0.1.0\"\n")
    write_file("{base}/foolib/src/foolib.bl", "pub fn hello() -> Str \{\n    \"hello-from-foolib\"\n}\n")

    write_file("{base}/app/blink.toml", "[package]\nname = \"app\"\nversion = \"0.1.0\"\n\n[dependencies]\nfoolib = \{ path = \"../foolib\" \}\n")
    write_file("{base}/app/src/main.bl", "import foolib.\{hello\}\n\nfn main() \{\n    io.println(hello())\n}\n")

    shell_exec("cd {base}/app && {blink} build src/main.bl -o build/app > out.txt 2>&1; true")
    let rc_out = read_file("{base}/app/out.txt")
    if file_exists("{base}/app/build/app") == 1 {
        shell_exec("{base}/app/build/app > {base}/app/run.txt 2>&1 || true")
        let run_out = read_file("{base}/app/run.txt")
        if run_out.starts_with("hello-from-foolib") {
            io.println("PASS: bare `import foolib` resolves to src/foolib.bl")
        } else {
            io.println("FAIL: expected 'hello-from-foolib', got: {run_out}")
        }
    } else {
        io.println("FAIL: build did not produce binary, output: {rc_out}")
    }

    shell_exec("rm -rf {base}")
}
