fn run_cmd(cmd: Str, label: Str) -> Int {
    let rc = shell_exec(cmd)
    if rc != 0 {
        io.println("FAIL: {label} (rc={rc})")
    }
    rc
}

fn check_output(path: Str, expected: Str, label: Str) {
    shell_exec("{path} > {path}_out.txt 2>&1 || true")
    let output = read_file("{path}_out.txt")
    if output.starts_with(expected) {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected '{expected}', got: {output}")
    }
}

fn main() {
    let base = ".tmp/_test_qualified_import"
    shell_exec("rm -rf {base}")
    let pact = "../../../bin/blink"

    shell_exec("mkdir -p {base}/mylib/src")
    write_file("{base}/mylib/blink.toml", "[package]\nname = \"mylib\"\nversion = \"0.1.0\"\n")
    write_file(
        "{base}/mylib/src/lib.bl",
        "pub fn add(a: Int, b: Int) -> Int \{\n    a + b\n}\n\npub fn multiply(a: Int, b: Int) -> Int \{\n    a * b\n}\n\npub fn subtract(a: Int, b: Int) -> Int \{\n    a - b\n}\n\nfn internal_helper() -> Int \{\n    999\n}\n\npub type Point \{\n    x: Int\n    y: Int\n}\n\npub let MAX = 100\n\npub let mut counter: Int = 0\n"
    )

    shell_exec("mkdir -p {base}/app/src")
    write_file(
        "{base}/app/blink.toml",
        "[package]\nname = \"app\"\nversion = \"1.0.0\"\n\n[dependencies]\nmylib = \{ path = \"../mylib\" }\n"
    )

    // Test 1: Basic qualified access — mylib.add(2, 3)
    write_file(
        "{base}/app/src/t1.bl",
        "import mylib\n\nfn main() \{\n    io.println(\"\{mylib.add(2, 3)\}\")\n}\n"
    )
    let rc1 = run_cmd("cd {base}/app && {pact} build src/t1.bl -o build/t1 2>&1", "build qualified add")
    if rc1 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t1", "5", "qualified access: mylib.add works")

    // Test 2: Mixed usage — qualified + unqualified in same file
    write_file(
        "{base}/app/src/t2.bl",
        "import mylib\n\nfn main() \{\n    io.println(\"\{mylib.add(2, 3)\}\")\n    io.println(\"\{multiply(4, 5)\}\")\n}\n"
    )
    let rc2 = run_cmd("cd {base}/app && {pact} build src/t2.bl -o build/t2 2>&1", "build mixed usage")
    if rc2 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t2", "5", "mixed: qualified + unqualified")

    // Test 3: Qualified access marks module used (no W0602 unused import warning)
    write_file(
        "{base}/app/src/t3.bl",
        "import mylib\n\nfn main() \{\n    io.println(\"\{mylib.add(1, 2)\}\")\n}\n"
    )
    shell_exec("mkdir -p {base}/app/build")
    shell_exec("cd {base}/app && {pact} build src/t3.bl -o build/t3 > ../out3.txt 2>&1")
    let out3 = read_file("{base}/out3.txt")
    if out3.contains("not used") {
        io.println("FAIL: qualified access should mark module used, got: {out3}")
    } else {
        io.println("PASS: qualified access marks module used")
    }

    // Test 4: Selective + qualified — import mylib.{add} then mylib.multiply() should work
    write_file(
        "{base}/app/src/t4.bl",
        "import mylib.\{add\}\n\nfn main() \{\n    io.println(\"\{add(2, 3)\}\")\n    io.println(\"\{mylib.multiply(4, 5)\}\")\n}\n"
    )
    let rc4 = run_cmd("cd {base}/app && {pact} build src/t4.bl -o build/t4 2>&1", "build selective+qualified")
    if rc4 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t4", "5", "selective+qualified: add bare + mylib.multiply qualified")

    // Test 5: Qualified type in struct construction — mylib.Point { x: 1, y: 2 }
    write_file(
        "{base}/app/src/t5.bl",
        "import mylib\n\nfn main() \{\n    let p = mylib.Point \{ x: 1, y: 2 \}\n    io.println(\"\{p.x\}\")\n}\n"
    )
    let rc5 = run_cmd("cd {base}/app && {pact} build src/t5.bl -o build/t5 2>&1", "build qualified struct")
    if rc5 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t5", "1", "qualified type: mylib.Point construction")

    // Test 6: Qualified type in annotation — let p: mylib.Point = ...
    write_file(
        "{base}/app/src/t6.bl",
        "import mylib\n\nfn main() \{\n    let p: mylib.Point = mylib.Point \{ x: 3, y: 4 \}\n    io.println(\"\{p.y\}\")\n}\n"
    )
    let rc6 = run_cmd("cd {base}/app && {pact} build src/t6.bl -o build/t6 2>&1", "build qualified type annotation")
    if rc6 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t6", "4", "qualified type annotation: mylib.Point")

    // Test 7: Qualified constant access — mylib.MAX
    write_file(
        "{base}/app/src/t7.bl",
        "import mylib\n\nfn main() \{\n    io.println(\"\{mylib.MAX\}\")\n}\n"
    )
    let rc7 = run_cmd("cd {base}/app && {pact} build src/t7.bl -o build/t7 2>&1", "build qualified constant")
    if rc7 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t7", "100", "qualified constant: mylib.MAX")

    // Test 8: Qualified constant in expression — mylib.MAX + 1
    write_file(
        "{base}/app/src/t8.bl",
        "import mylib\n\nfn main() \{\n    io.println(\"\{mylib.MAX + 1\}\")\n}\n"
    )
    let rc8 = run_cmd("cd {base}/app && {pact} build src/t8.bl -o build/t8 2>&1", "build qualified constant expr")
    if rc8 != 0 {
        shell_exec("rm -rf {base}")
        return
    }
    check_output("{base}/app/build/t8", "101", "qualified constant in expression: mylib.MAX + 1")

    // Test 9: Assignment to pub let mut — no W0602
    write_file(
        "{base}/app/src/t9.bl",
        "import mylib\n\nfn main() \{\n    counter = 42\n    io.println(\"\{counter\}\")\n}\n"
    )
    shell_exec("cd {base}/app && {pact} build src/t9.bl -o build/t9 > ../out9.txt 2>&1")
    let out9 = read_file("{base}/out9.txt")
    if out9.contains("not used") {
        io.println("FAIL: assignment to pub let mut should mark module used, got: {out9}")
    } else {
        io.println("PASS: assignment to pub let mut marks module used")
    }
    check_output("{base}/app/build/t9", "42", "pub let mut assignment: counter = 42")

    shell_exec("rm -rf {base}")
}
