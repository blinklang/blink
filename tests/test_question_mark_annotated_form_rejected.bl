// Test bodies have an implicit return type only — either Void, or
// Result[Void, TestError] when the body contains `?`. An explicit
// return-type annotation is rejected with E0515.

import compile_test_helpers

test "annotated test return type emits E0515" {
    let src = "test \"x\" -> Result[Void, Str] \{ () \}\n"
    compile_test_helpers.expect_compile_error(src, "annotated_test_return", "E0515")
}
