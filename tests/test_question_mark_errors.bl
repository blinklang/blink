import compile_test_helpers

test "? on plain Int emits E0502" {
    let src = "fn main() -> Result[Int, Str] \{ let x = 42\nlet y = x?\nOk(y) \}\n"
    compile_test_helpers.expect_compile_error(src, "qmark_plain", "E0502")
}

test "? on Result in non-Result fn emits E0508" {
    let src = "fn try_it() -> Result[Int, Str] \{ Ok(42) \}\nfn main() \{ let _v = try_it()? \}\n"
    compile_test_helpers.expect_compile_error(src, "qmark_result", "E0508")
}

test "? on Option in non-Option fn emits E0509" {
    let src = "fn find() -> Option[Int] \{ Some(42) \}\nfn main() \{ let _v = find()? \}\n"
    compile_test_helpers.expect_compile_error(src, "qmark_option", "E0509")
}

test "? with mismatched error types emits E0512" {
    let src = "type ErrorA \{ msg: Str \}\ntype ErrorB \{ msg: Str \}\nfn try_a() -> Result[Int, ErrorA] \{ Ok(42) \}\nfn main() -> Result[Int, ErrorB] \{ let _v = try_a()?\nOk(0) \}\n"
    compile_test_helpers.expect_compile_error(src, "qmark_mismatch", "E0512")
}
