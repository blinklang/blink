// btvqbf: elaboration does NOT propagate into nested closures.
// A `?` inside a closure passed to for_each must still be rejected with
// E0508 against the closure's own return type — not silently elaborated
// to the enclosing test body. (Spec §3c.2 / panel Q6.)

import compile_test_helpers

test "? inside HOF closure inside test still rejects" {
    let src = "fn boom() -> Result[Int, Str] \{ Err(\"x\") \}\nfn each(items: List[Int], body: fn(Int) -> Void) \{ for i in items \{ body(i) \} \}\ntest \"x\" \{ each([1], fn(_i) \{ let _ = boom()?\n() \}) \}\n"
    compile_test_helpers.expect_compile_error(src, "qm_test_closure", "E0508")
}
