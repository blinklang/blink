// `?` on an Err type without a Display impl must emit E0514.
// Test bodies that use `?` are elaborated to Result[Void, TestError] and
// render the propagated error via Display.display(e).

import compile_test_helpers

test "? on Err without Display emits E0514" {
    let src = "type NoDisp \{ msg: Str \}\nfn boom() -> Result[Int, NoDisp] \{ Err(NoDisp \{ msg: \"x\" \}) \}\ntest \"x\" \{ let _ = boom()? \}\n"
    compile_test_helpers.expect_compile_error(src, "qm_test_no_display", "E0514")
}
