import pkg.resolver.{res_names, res_versions, res_sources, res_hashes, res_caps, resolver_clear, resolver_count, resolver_get_name, resolver_get_version, resolver_get_source, resolver_get_hash, resolver_get_caps, resolve, resolve_and_lock}
import pkg.lockfile.{lockfile_clear, lockfile_load, lockfile_pkg_count, lock_pkg_names, lock_pkg_versions, lock_pkg_sources, lock_pkg_caps}

test "clear" {
    res_names.push("test")
    res_versions.push("1.0")
    res_sources.push("path:/x")
    res_hashes.push("abc")
    res_caps.push("")

    resolver_clear()
    assert_eq(resolver_count(), 0)
    assert_eq(resolver_get_name(0), "")
}

test "query bounds" {
    resolver_clear()
    assert_eq(resolver_get_name(-1), "")
    assert_eq(resolver_get_version(-1), "")
    assert_eq(resolver_get_source(99), "")
    assert_eq(resolver_get_hash(99), "")
    assert_eq(resolver_get_caps(99), "")
}

test "single path dep" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_single")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_single/mylib/src")

    write_file("/tmp/_blink_test_resolve_single/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nmylib = \{ path = \"mylib\" \}\n")
    write_file("/tmp/_blink_test_resolve_single/mylib/blink.toml", "[package]\nname = \"mylib\"\nversion = \"0.1.0\"\n")
    write_file("/tmp/_blink_test_resolve_single/mylib/src/mylib.bl", "pub fn hello() -> Str \{ \"hi\" \}\n")

    resolver_clear()
    let rc = resolve("/tmp/_blink_test_resolve_single")
    assert_eq(rc, 0)
    assert_eq(resolver_count(), 1)
    assert_eq(resolver_get_name(0), "mylib")
    assert_eq(resolver_get_version(0), "0.1.0")
    assert(resolver_get_source(0).starts_with("path:"))
}

test "single git dep" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_git")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_git/project")

    // Create a git repo to use as dependency
    shell_exec("mkdir -p /tmp/_blink_test_resolve_git/gitlib/src")
    write_file("/tmp/_blink_test_resolve_git/gitlib/blink.toml", "[package]\nname = \"gitlib\"\nversion = \"2.0.0\"\n")
    write_file("/tmp/_blink_test_resolve_git/gitlib/src/gitlib.bl", "pub fn greet() -> Str \{ \"hello\" \}\n")
    shell_exec("cd /tmp/_blink_test_resolve_git/gitlib && git init && git add -A && git commit -m 'init' && git tag v2.0")

    write_file("/tmp/_blink_test_resolve_git/project/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\ngitlib = \{ git = \"file:///tmp/_blink_test_resolve_git/gitlib\", tag = \"v2.0\" \}\n")

    resolver_clear()
    let rc = resolve("/tmp/_blink_test_resolve_git/project")
    assert_eq(rc, 0)
    assert_eq(resolver_count(), 1)
    assert_eq(resolver_get_name(0), "gitlib")
    assert_eq(resolver_get_version(0), "2.0.0")
    assert(resolver_get_source(0).starts_with("git:"))
}

test "diamond same version" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_diamond")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_diamond/liba/shared/src")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_diamond/libb")

    write_file("/tmp/_blink_test_resolve_diamond/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nliba = \{ path = \"liba\" \}\nlibb = \{ path = \"libb\" \}\n")
    write_file("/tmp/_blink_test_resolve_diamond/liba/blink.toml", "[package]\nname = \"liba\"\nversion = \"0.1.0\"\n\n[dependencies]\nshared = \{ path = \"shared\" \}\n")
    write_file("/tmp/_blink_test_resolve_diamond/liba/shared/blink.toml", "[package]\nname = \"shared\"\nversion = \"0.5.0\"\n")
    write_file("/tmp/_blink_test_resolve_diamond/liba/shared/src/shared.bl", "pub fn common() -> Int \{ 42 \}\n")
    shell_exec("cp -r /tmp/_blink_test_resolve_diamond/liba/shared /tmp/_blink_test_resolve_diamond/libb/shared")
    write_file("/tmp/_blink_test_resolve_diamond/libb/blink.toml", "[package]\nname = \"libb\"\nversion = \"0.2.0\"\n\n[dependencies]\nshared = \{ path = \"shared\" \}\n")

    resolver_clear()
    let rc = resolve("/tmp/_blink_test_resolve_diamond")
    assert_eq(rc, 0)

    // shared should appear once
    let mut shared_count = 0
    let mut i = 0
    while i < resolver_count() {
        if resolver_get_name(i) == "shared" {
            shared_count = shared_count + 1
        }
        i = i + 1
    }
    assert_eq(shared_count, 1)
}

test "diamond conflict" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_conflict")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_conflict/liba/shared/src")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_conflict/libb/shared/src")

    write_file("/tmp/_blink_test_resolve_conflict/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nliba = \{ path = \"liba\" \}\nlibb = \{ path = \"libb\" \}\n")
    write_file("/tmp/_blink_test_resolve_conflict/liba/blink.toml", "[package]\nname = \"liba\"\nversion = \"0.1.0\"\n\n[dependencies]\nshared = \{ path = \"shared\" \}\n")
    write_file("/tmp/_blink_test_resolve_conflict/liba/shared/blink.toml", "[package]\nname = \"shared\"\nversion = \"0.5.0\"\n")
    write_file("/tmp/_blink_test_resolve_conflict/liba/shared/src/shared.bl", "pub fn f() -> Int \{ 1 \}\n")
    write_file("/tmp/_blink_test_resolve_conflict/libb/blink.toml", "[package]\nname = \"libb\"\nversion = \"0.2.0\"\n\n[dependencies]\nshared = \{ path = \"shared\" \}\n")
    write_file("/tmp/_blink_test_resolve_conflict/libb/shared/blink.toml", "[package]\nname = \"shared\"\nversion = \"0.9.0\"\n")
    write_file("/tmp/_blink_test_resolve_conflict/libb/shared/src/shared.bl", "pub fn f() -> Int \{ 2 \}\n")

    resolver_clear()
    let rc = resolve("/tmp/_blink_test_resolve_conflict")
    assert_eq(rc, 1)
}

test "transitive chain" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_chain")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_chain/liba/libb/src")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_chain/liba/src")

    write_file("/tmp/_blink_test_resolve_chain/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nliba = \{ path = \"liba\" \}\n")
    write_file("/tmp/_blink_test_resolve_chain/liba/blink.toml", "[package]\nname = \"liba\"\nversion = \"0.1.0\"\n\n[dependencies]\nlibb = \{ path = \"libb\" \}\n")
    write_file("/tmp/_blink_test_resolve_chain/liba/src/a.bl", "pub fn a() -> Int \{ 1 \}\n")
    write_file("/tmp/_blink_test_resolve_chain/liba/libb/blink.toml", "[package]\nname = \"libb\"\nversion = \"0.2.0\"\n")
    write_file("/tmp/_blink_test_resolve_chain/liba/libb/src/b.bl", "pub fn b() -> Int \{ 2 \}\n")

    resolver_clear()
    let rc = resolve("/tmp/_blink_test_resolve_chain")
    assert_eq(rc, 0)
    assert_eq(resolver_count(), 2)
    assert_eq(resolver_get_name(0), "liba")
    assert_eq(resolver_get_name(1), "libb")
}

test "resolve and lock" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_lock")
    shell_exec("mkdir -p /tmp/_blink_test_resolve_lock/mylib/src")

    write_file("/tmp/_blink_test_resolve_lock/blink.toml", "[package]\nname = \"root\"\nversion = \"1.0.0\"\n\n[dependencies]\nmylib = \{ path = \"mylib\" \}\n")
    write_file("/tmp/_blink_test_resolve_lock/mylib/blink.toml", "[package]\nname = \"mylib\"\nversion = \"0.3.0\"\n\n[capabilities]\nrequired = [\"Net.Connect\"]\n")
    write_file("/tmp/_blink_test_resolve_lock/mylib/src/mylib.bl", "pub fn fetch() -> Int \{ 0 \}\n")

    let rc = resolve_and_lock("/tmp/_blink_test_resolve_lock", "0.0.0-test")
    assert_eq(rc, 0)

    // Verify lockfile was written (resolver writes blink.lock)
    let mut lock_path = "/tmp/_blink_test_resolve_lock/blink.lock"
    let mut exists = file_exists(lock_path)
    if exists == 0 {
        lock_path = "/tmp/_blink_test_resolve_lock/blink.lock"
        exists = file_exists(lock_path)
    }
    assert_eq(exists, 1)

    // Load and verify lockfile contents
    lockfile_clear()
    let load_rc = lockfile_load(lock_path)
    assert_eq(load_rc, 0)
    assert_eq(lockfile_pkg_count(), 1)
    assert_eq(lock_pkg_names.get(0).unwrap(), "mylib")
    assert_eq(lock_pkg_versions.get(0).unwrap(), "0.3.0")
    assert(lock_pkg_sources.get(0).unwrap().starts_with("path:"))
    assert_eq(lock_pkg_caps.get(0).unwrap(), "Net.Connect")
}

test "cleanup" {
    shell_exec("rm -rf /tmp/_blink_test_resolve_single /tmp/_blink_test_resolve_git /tmp/_blink_test_resolve_diamond /tmp/_blink_test_resolve_conflict /tmp/_blink_test_resolve_chain /tmp/_blink_test_resolve_lock /tmp/_blink_hash /tmp/_blink_commit /tmp/_blink_home")
    shell_exec("rm -rf ~/.blink/cache/git/*_blink_test_*")
}
