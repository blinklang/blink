fn find_user(name: Str) -> Result[Option[Str], Str] {
    if name == "" {
        Err("empty name")
    } else {
        Ok(Some(name))
    }
}

test "Result[Option[Str], Str] Ok(Some) round-trips" {
    let r = find_user("alice")
    match r {
        Ok(opt) => {
            let val = opt ?? "default"
            assert_eq(val, "alice")
        }
        Err(_e) => assert(false)
    }
}

test "Result[Option[Str], Str] Err round-trips" {
    let r = find_user("")
    match r {
        Ok(_opt) => assert(false)
        Err(e) => assert_eq(e, "empty name")
    }
}
