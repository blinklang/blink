// Test: set-but-not-read warnings (W0601)
// Expected: W0601 for overwritten values that are never read

fn test_overwrite_before_read() ! IO {
    let mut x = 10
    x = 20
    io.println("{x}")
}

fn test_multiple_overwrites() ! IO {
    let mut x = 1
    x = 2
    x = 3
    io.println("{x}")
}

fn test_no_warning_when_read() ! IO {
    let mut x = 10
    io.println("{x}")
    x = 20
    io.println("{x}")
}

fn test_no_warning_underscore() ! IO {
    let mut _x = 10
    _x = 20
    io.println("{_x}")
}

fn test_compound_assign_ok() ! IO {
    let mut x = 10
    x = x + 5
    io.println("{x}")
}

fn test_loop_reassign() ! IO {
    let mut total = 0
    let items = [1, 2, 3]
    for item in items {
        total = total + item
    }
    io.println("{total}")
}

// W0601 must NOT fire when a let mut is read through a captured closure.
// Reassignments after the closure is defined are observable by later calls.
fn test_no_warning_closure_capture() ! IO {
    let mut n = 1
    let g = fn(x: Int) -> Int { x + n }
    io.println(g(3).to_string())
    n = 10
    io.println(g(3).to_string())
}

// Nested closure capturing a mut closure should also suppress W0601 on the
// captured let mut binding.
fn test_no_warning_nested_closure_capture() ! IO {
    let mut inner = fn(x: Int) -> Int { x + 1 }
    let outer = fn(y: Int) -> Int { inner(y) * 2 }
    io.println(outer(5).to_string())
    inner = fn(x: Int) -> Int { x + 100 }
    io.println(outer(5).to_string())
}

fn main() ! IO {
    test_overwrite_before_read()
    test_multiple_overwrites()
    test_no_warning_when_read()
    test_no_warning_underscore()
    test_compound_assign_ok()
    test_loop_reassign()
    test_no_warning_closure_capture()
    test_no_warning_nested_closure_capture()
}
