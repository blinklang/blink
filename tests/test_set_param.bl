fn check_contains(s: Set[Str], key: Str) -> Bool {
    s.contains(key)
}

fn add_item(s: Set[Str], key: Str) {
    s.insert(key)
}

test "set as function parameter" {
    let mut s = Set()
    s.insert("hello")
    s.insert("world")

    assert_eq(check_contains(s, "hello"), true)
    assert_eq(check_contains(s, "missing"), false)

    add_item(s, "new")
    assert_eq(s.len(), 3)
}
