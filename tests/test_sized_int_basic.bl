// Tests basic arithmetic and comparison for all sized integer types:
// I8, I16, I32, U8, U16, U32, U64
// These tests define the expected behavior before implementation (TDD / red phase).

fn main() {
    // ── I32 ──────────────────────────────────────────────────────────────
    let a32: I32 = 10
    let b32: I32 = 3
    let c32: I32 = a32 + b32
    assert(c32 == 13)
    let d32: I32 = a32 - b32
    assert(d32 == 7)
    let e32: I32 = a32 * b32
    assert(e32 == 30)
    let f32: I32 = a32 / b32
    assert(f32 == 3)
    let g32: I32 = a32 % b32
    assert(g32 == 1)
    assert(a32 > b32)
    assert(b32 < a32)
    assert(a32 >= a32)
    assert(b32 <= b32)
    assert(a32 != b32)

    // Negative values
    let neg32: I32 = -5
    let neg_sum: I32 = neg32 + b32
    assert(neg_sum == -2)
    assert(neg32 < b32)

    // ── I16 ──────────────────────────────────────────────────────────────
    let a16: I16 = 20
    let b16: I16 = 7
    let c16: I16 = a16 + b16
    assert(c16 == 27)
    let d16: I16 = a16 - b16
    assert(d16 == 13)
    let e16: I16 = a16 * b16
    assert(e16 == 140)
    let f16: I16 = a16 / b16
    assert(f16 == 2)
    let g16: I16 = a16 % b16
    assert(g16 == 6)
    assert(a16 > b16)
    assert(b16 < a16)
    assert(a16 >= a16)
    assert(b16 <= b16)
    assert(a16 != b16)

    // Negative values
    let neg16: I16 = -10
    let neg_sum16: I16 = neg16 + b16
    assert(neg_sum16 == -3)
    assert(neg16 < b16)

    // ── I8 ───────────────────────────────────────────────────────────────
    let a8: I8 = 15
    let b8: I8 = 4
    let c8: I8 = a8 + b8
    assert(c8 == 19)
    let d8: I8 = a8 - b8
    assert(d8 == 11)
    let e8: I8 = a8 * b8
    assert(e8 == 60)
    let f8: I8 = a8 / b8
    assert(f8 == 3)
    let g8: I8 = a8 % b8
    assert(g8 == 3)
    assert(a8 > b8)
    assert(b8 < a8)
    assert(a8 >= a8)
    assert(b8 <= b8)
    assert(a8 != b8)

    // Negative values
    let neg8: I8 = -20
    let neg_sum8: I8 = neg8 + b8
    assert(neg_sum8 == -16)
    assert(neg8 < b8)

    // ── U8 ───────────────────────────────────────────────────────────────
    let ua8: U8 = 50
    let ub8: U8 = 10
    let uc8: U8 = ua8 + ub8
    assert(uc8 == 60)
    let ud8: U8 = ua8 - ub8
    assert(ud8 == 40)
    let ub8_5: U8 = 5
    let ue8: U8 = ua8 * ub8_5  // 250, in range
    assert(ue8 == 250)
    let ue8_wrap: U8 = ua8.wrapping_mul(ub8)  // 500 wraps to 244
    assert(ue8_wrap == 244)
    let uf8: U8 = ua8 / ub8
    assert(uf8 == 5)
    let ug8: U8 = ua8 % ub8
    assert(ug8 == 0)
    assert(ua8 > ub8)
    assert(ub8 < ua8)
    assert(ua8 >= ua8)
    assert(ub8 <= ub8)
    assert(ua8 != ub8)

    // ── U16 ──────────────────────────────────────────────────────────────
    let ua16: U16 = 100
    let ub16: U16 = 30
    let uc16: U16 = ua16 + ub16
    assert(uc16 == 130)
    let ud16: U16 = ua16 - ub16
    assert(ud16 == 70)
    let ue16: U16 = ua16 * ub16
    assert(ue16 == 3000)
    let uf16: U16 = ua16 / ub16
    assert(uf16 == 3)
    let ug16: U16 = ua16 % ub16
    assert(ug16 == 10)
    assert(ua16 > ub16)
    assert(ub16 < ua16)
    assert(ua16 >= ua16)
    assert(ub16 <= ub16)
    assert(ua16 != ub16)

    // ── U32 ──────────────────────────────────────────────────────────────
    let ua32: U32 = 80
    let ub32: U32 = 25
    let uc32: U32 = ua32 + ub32
    assert(uc32 == 105)
    let ud32: U32 = ua32 - ub32
    assert(ud32 == 55)
    let ue32: U32 = ua32 * ub32
    assert(ue32 == 2000)
    let uf32: U32 = ua32 / ub32
    assert(uf32 == 3)
    let ug32: U32 = ua32 % ub32
    assert(ug32 == 5)
    assert(ua32 > ub32)
    assert(ub32 < ua32)
    assert(ua32 >= ua32)
    assert(ub32 <= ub32)
    assert(ua32 != ub32)

    // ── U64 ──────────────────────────────────────────────────────────────
    let ua64: U64 = 90
    let ub64: U64 = 12
    let uc64: U64 = ua64 + ub64
    assert(uc64 == 102)
    let ud64: U64 = ua64 - ub64
    assert(ud64 == 78)
    let ue64: U64 = ua64 * ub64
    assert(ue64 == 1080)
    let uf64: U64 = ua64 / ub64
    assert(uf64 == 7)
    let ug64: U64 = ua64 % ub64
    assert(ug64 == 6)
    assert(ua64 > ub64)
    assert(ub64 < ua64)
    assert(ua64 >= ua64)
    assert(ub64 <= ub64)
    assert(ua64 != ub64)

    io.println("All sized int basic tests passed!")
}
