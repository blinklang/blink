// Tests conversion methods between sized integer types and Int.
// Covers: to_i8, to_i16, to_i32, to_u8, to_u16, to_u32, to_u64, to_int
// Includes wrapping behavior on narrowing conversions.
// TDD red phase — implementation does not yet exist.

fn main() {
    // ── Identity-preserving conversions from I32 ──────────────────────
    let v: I32 = 100
    let as_i8: I8 = v.to_i8()
    assert(as_i8 == 100)
    let as_i16: I16 = v.to_i16()
    assert(as_i16 == 100)
    let as_u8: U8 = v.to_u8()
    assert(as_u8 == 100)
    let as_u16: U16 = v.to_u16()
    assert(as_u16 == 100)
    let as_u32: U32 = v.to_u32()
    assert(as_u32 == 100)
    let as_u64: U64 = v.to_u64()
    assert(as_u64 == 100)
    let as_int: Int = v.to_int()
    assert(as_int == 100)

    // ── I32 -> Int round-trip ─────────────────────────────────────────
    let x: I32 = 42
    let y: Int = x.to_int()
    assert(y == 42)

    // ── Narrowing wrapping: I32(128) -> I8 wraps to -128 ─────────────
    // I8 range is -128..127; 128 overflows and wraps to -128
    let big_i32: I32 = 128
    let wrapped_i8: I8 = big_i32.to_i8()
    assert(wrapped_i8 == -128)

    // I32(200) -> I8: 200 - 256 = -56
    let i32_200: I32 = 200
    let wrapped_i8_200: I8 = i32_200.to_i8()
    assert(wrapped_i8_200 == -56)

    // ── Narrowing wrapping: I32(256) -> U8 wraps to 0 ────────────────
    let two56: I32 = 256
    let w_u8: U8 = two56.to_u8()
    assert(w_u8 == 0)

    // I32(300) -> U8: 300 % 256 = 44
    let i32_300: I32 = 300
    let w_u8_300: U8 = i32_300.to_u8()
    assert(w_u8_300 == 44)

    // I32(257) -> U8 wraps to 1
    let i32_257: I32 = 257
    let w_u8_257: U8 = i32_257.to_u8()
    assert(w_u8_257 == 1)

    // ── Int -> sized conversions ──────────────────────────────────────
    let n: Int = 42
    let ni32: I32 = n.to_i32()
    assert(ni32 == 42)
    let ni8: I8 = n.to_i8()
    assert(ni8 == 42)
    let ni16: I16 = n.to_i16()
    assert(ni16 == 42)
    let nu8: U8 = n.to_u8()
    assert(nu8 == 42)
    let nu16: U16 = n.to_u16()
    assert(nu16 == 42)
    let nu32: U32 = n.to_u32()
    assert(nu32 == 42)
    let nu64: U64 = n.to_u64()
    assert(nu64 == 42)

    // ── Widening: I8 -> I16, I16 -> I32, I32 -> Int (no wrapping) ────
    let small_i8: I8 = 50
    let wide_i16: I16 = small_i8.to_i16()
    assert(wide_i16 == 50)
    let wide_i32: I32 = wide_i16.to_i32()
    assert(wide_i32 == 50)
    let wide_int: Int = wide_i32.to_int()
    assert(wide_int == 50)

    // ── Negative I8 -> I16 sign-extends ──────────────────────────────
    let neg_i8: I8 = -10
    let neg_to_i16: I16 = neg_i8.to_i16()
    assert(neg_to_i16 == -10)
    let neg_to_i32: I32 = neg_i8.to_i32()
    assert(neg_to_i32 == -10)
    let neg_to_int: Int = neg_i8.to_int()
    assert(neg_to_int == -10)

    // ── U8 -> U16 -> U32 -> U64 widening ─────────────────────────────
    let small_u8: U8 = 200
    let wide_u16: U16 = small_u8.to_u16()
    assert(wide_u16 == 200)
    let wide_u32: U32 = wide_u16.to_u32()
    assert(wide_u32 == 200)
    let wide_u64: U64 = wide_u32.to_u64()
    assert(wide_u64 == 200)

    // ── Cross-sign conversions with wrapping ──────────────────────────
    // U8(255) -> I8 wraps to -1
    let max_u8: U8 = 255
    let to_i8_wrap: I8 = max_u8.to_i8()
    assert(to_i8_wrap == -1)

    // I8(-1) -> U8 wraps to 255
    let neg1_i8: I8 = -1
    let to_u8_wrap: U8 = neg1_i8.to_u8()
    assert(to_u8_wrap == 255)

    io.println("All sized int conversion tests passed!")
}
