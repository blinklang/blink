// Tests that sized int types require explicit conversion — no implicit coercion.
// This file should compile and pass: it exercises the happy path where
// conversions are always explicit via .to_int(), .to_i32(), etc.
// TDD red phase — will fail until sized int arithmetic + conversions are implemented.

fn add_ints(a: Int, b: Int) -> Int {
    a + b
}

fn add_i32s(a: I32, b: I32) -> I32 {
    a + b
}

fn main() {
    // ── Explicit conversion I32 -> Int required ───────────────────────
    let x: I32 = 5
    let y: Int = x.to_int()
    assert(y == 5)

    // ── Arithmetic stays within the same sized type ───────────────────
    let a: I32 = 10
    let b: I32 = 3
    let c: I32 = a + b
    assert(c == 13)

    // ── Explicit conversion Int -> I32 required ───────────────────────
    let n: Int = 100
    let m: I32 = n.to_i32()
    assert(m == 100)

    // ── Pass converted value to a function expecting Int ─────────────
    let p: I32 = 20
    let q: I32 = 7
    let sum_as_int: Int = add_ints(p.to_int(), q.to_int())
    assert(sum_as_int == 27)

    // ── Pass converted value to a function expecting I32 ─────────────
    let r: Int = 15
    let s: Int = 8
    let sum_as_i32: I32 = add_i32s(r.to_i32(), s.to_i32())
    assert(sum_as_i32 == 23)

    // ── Chain conversions ─────────────────────────────────────────────
    let base: Int = 42
    let as_i32: I32 = base.to_i32()
    let as_i16: I16 = as_i32.to_i16()
    let as_i8: I8 = as_i16.to_i8()
    let back_to_int: Int = as_i8.to_int()
    assert(back_to_int == 42)

    // ── U types explicit conversion chain ─────────────────────────────
    let ubase: Int = 77
    let as_u8: U8 = ubase.to_u8()
    let as_u16: U16 = as_u8.to_u16()
    let as_u32: U32 = as_u16.to_u32()
    let as_u64: U64 = as_u32.to_u64()
    let back: Int = as_u64.to_int()
    assert(back == 77)

    io.println("All no-implicit-conversion tests passed!")
}
