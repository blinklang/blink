// Sized-integer arithmetic overflow trapping.
// Spec §03_types.md:739-760: arithmetic overflow is checked by default.
//
// This test covers in-range arithmetic that must NOT panic, and verifies
// that wrapping_* methods return the wrapped value without panic.
// Overflow panic cases live in .tmp/ as run-and-expect-failure MVCEs.

fn main() {
    // ── in-range arithmetic on every sized type ──────────────────────────
    let i8a: I8 = 100
    let i8b: I8 = 27
    assert((i8a + i8b) == 127)        // I8 max, in range
    assert((i8a - i8b) == 73)
    assert((i8b * 4) == 108)          // 27*4 = 108, in range
    assert((i8a / i8b) == 3)
    assert((i8a % i8b) == 19)

    let i16a: I16 = 30000
    let i16b: I16 = 2000
    assert((i16a + i16b) == 32000)    // in range
    assert((i16a - i16b) == 28000)

    let i32a: I32 = 1000000
    let i32b: I32 = 999
    assert((i32a + i32b) == 1000999)
    assert((i32a * 2) == 2000000)

    let u8a: U8 = 250
    let u8b: U8 = 5
    assert((u8a + u8b) == 255)        // U8 max, in range
    assert((u8a - u8b) == 245)
    assert((u8b * 50) == 250)
    assert((u8a / u8b) == 50)

    let u16a: U16 = 60000
    let u16b: U16 = 5535
    assert((u16a + u16b) == 65535)    // U16 max, in range

    let u32a: U32 = 2000000000
    let u32b: U32 = 1000000000
    assert((u32a + u32b) == 3000000000)  // in range

    let u64a: U64 = 1000000000000
    let u64b: U64 = 2000000000000
    assert((u64a + u64b) == 3000000000000)

    // ── unary negation, in-range ─────────────────────────────────────────
    let i8_pos: I8 = 100
    assert((-i8_pos) == -100)
    let i32_pos: I32 = 2000000000
    assert((-i32_pos) == -2000000000)

    // ── wrapping_* methods: must NOT panic, return wrapped value ─────────
    let u8_max: U8 = 255
    assert(u8_max.wrapping_add(1) == 0)     // wraps to 0
    assert(u8_max.wrapping_add(2) == 1)
    let i8_max: I8 = 127
    assert(i8_max.wrapping_add(1) == -128)  // wraps to I8.MIN

    let u8_min: U8 = 0
    assert(u8_min.wrapping_sub(1) == 255)
    let i8_min: I8 = -128
    assert(i8_min.wrapping_sub(1) == 127)

    let u8_half: U8 = 128
    assert(u8_half.wrapping_mul(2) == 0)    // 128*2 = 256 wraps to 0
    let i8_64: I8 = 64
    assert(i8_64.wrapping_mul(2) == -128)   // 128 wraps to -128

    let i8_min_neg: I8 = -128
    assert(i8_min_neg.wrapping_neg() == -128)  // INT_MIN.wrapping_neg() == INT_MIN

    io.println("sized int overflow in-range tests OK")
}
