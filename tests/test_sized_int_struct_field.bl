// Tests sized integer types as struct fields.
// Covers field access, arithmetic on field values, and multiple sized int field types.
// TDD red phase — will fail until sized int struct field support is implemented.

type Point {
    x: I32
    y: I32
}

type Pixel {
    r: U8
    g: U8
    b: U8
    a: U8
}

type Counts {
    small: I8
    medium: I16
    large: I32
    big: U64
}

type Rect {
    x: I32
    y: I32
    width: U32
    height: U32
}

fn main() {
    // ── Basic I32 struct fields ───────────────────────────────────────
    let p = Point { x: 10, y: 20 }
    assert(p.x == 10)
    assert(p.y == 20)
    let sum: I32 = p.x + p.y
    assert(sum == 30)
    let diff: I32 = p.y - p.x
    assert(diff == 10)

    // ── Negative I32 struct fields ────────────────────────────────────
    let neg_p = Point { x: -5, y: 15 }
    assert(neg_p.x == -5)
    assert(neg_p.y == 15)
    let neg_sum: I32 = neg_p.x + neg_p.y
    assert(neg_sum == 10)

    // ── U8 struct fields (Pixel / RGBA) ──────────────────────────────
    let px = Pixel { r: 255, g: 128, b: 0, a: 255 }
    assert(px.r == 255)
    assert(px.g == 128)
    assert(px.b == 0)
    assert(px.a == 255)

    // ── Mixed sized int struct fields ─────────────────────────────────
    let c = Counts { small: 10, medium: 1000, large: 100000, big: 999999 }
    assert(c.small == 10)
    assert(c.medium == 1000)
    assert(c.large == 100000)
    assert(c.big == 999999)

    // ── Rect with mixed I32 / U32 fields ─────────────────────────────
    let r = Rect { x: -10, y: -20, width: 800, height: 600 }
    assert(r.x == -10)
    assert(r.y == -20)
    assert(r.width == 800)
    assert(r.height == 600)

    // Area calculation using converted types
    let area: Int = r.width.to_int() * r.height.to_int()
    assert(area == 480000)

    // ── Field comparison ──────────────────────────────────────────────
    let p1 = Point { x: 3, y: 4 }
    let p2 = Point { x: 1, y: 2 }
    assert(p1.x > p2.x)
    assert(p1.y > p2.y)
    assert(p2.x < p1.x)

    io.println("All sized int struct field tests passed!")
}
