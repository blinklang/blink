// Phase 6: stdlib annotation slice. Demonstrates that the @ensures on
// close_to is a real, executing runtime check by exercising the
// passing path across many calls.

import compile_test_helpers

test "close_to runtime: many passing calls do not trip the @ensures" {
    let src = "import std.float.\{close_to}\nfn main() \{\n    let mut i = 0\n    while i < 100 \{ close_to(1.0, 1.0, 0.001); i = i + 1 }\n}\n"
    let r = compile_test_helpers.compile_and_run(src, "_close_to_pass")
    assert(r.exit_code == 0)
}

test "close_to runtime: negative-tolerance path still returns false (no abort)" {
    let src = "import std.float.\{close_to}\nfn main() \{\n    let r = close_to(1.0, 1.0, 0.0 - 1.0)\n    if r \{ io.println(\"FAIL\") } else \{ io.println(\"OK\") }\n}\n"
    let r = compile_test_helpers.compile_and_run(src, "_close_to_neg")
    assert(r.exit_code == 0)
    assert(r.out.contains("OK"))
}
