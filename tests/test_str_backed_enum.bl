import std.json

type Status {
    Open = "open"
    InProgress = "in_progress"
    Done = "done"
    Cancelled = "cancelled"
}

test "to_str returns string value" {
    assert_eq(Status.Open.to_str(), "open")
    assert_eq(Status.InProgress.to_str(), "in_progress")
    assert_eq(Status.Done.to_str(), "done")
    assert_eq(Status.Cancelled.to_str(), "cancelled")
}

test "from_str returns Some for valid strings" {
    let s = Status.from_str("open")
    match s {
        Some(v) => assert_eq(v.to_str(), "open")
        None => assert(false)
    }
    let s2 = Status.from_str("in_progress")
    match s2 {
        Some(v) => assert_eq(v.to_str(), "in_progress")
        None => assert(false)
    }
}

test "from_str returns None for invalid strings" {
    let s = Status.from_str("invalid")
    match s {
        Some(_) => assert(false)
        None => assert(true)
    }
    let s2 = Status.from_str("Open")
    match s2 {
        Some(_) => assert(false)
        None => assert(true)
    }
}

test "match on string-backed enum" {
    let s = Status.InProgress
    let result = match s {
        Status.Open => "is open"
        Status.InProgress => "is in progress"
        Status.Done => "is done"
        Status.Cancelled => "is cancelled"
    }
    assert_eq(result, "is in progress")
}

@derive(Serialize, Deserialize)
type Priority {
    Low = "low"
    Medium = "medium"
    High = "high"
}

test "serialize uses string value" {
    assert_eq(Priority.Low.to_json(), "\"low\"")
    assert_eq(Priority.High.to_json(), "\"high\"")
}

test "deserialize uses string value" {
    let p = Priority.from_json("\"medium\"")
    match p {
        Ok(v) => assert_eq(v.to_json(), "\"medium\"")
        Err(_) => assert(false)
    }
}

test "deserialize rejects variant name" {
    let p = Priority.from_json("\"Low\"")
    match p {
        Ok(_) => assert(false)
        Err(_) => assert(true)
    }
}
