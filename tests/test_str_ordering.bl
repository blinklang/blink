test "less than basic" {
    assert("apple" < "banana")
    assert(("banana" < "apple") == false)
    assert(("apple" < "apple") == false)
}

test "less than or equal" {
    assert("apple" <= "apple")
    assert("apple" <= "banana")
    assert(("banana" <= "apple") == false)
}

test "greater than basic" {
    assert("banana" > "apple")
    assert(("apple" > "banana") == false)
    assert(("apple" > "apple") == false)
}

test "greater than or equal" {
    assert("apple" >= "apple")
    assert("banana" >= "apple")
    assert(("apple" >= "banana") == false)
}

test "same prefix different length" {
    assert("app" < "apple")
    assert("apple" > "app")
    assert(("apple" < "app") == false)
    assert(("app" > "apple") == false)
    assert("app" <= "apple")
    assert("apple" >= "app")
}

test "empty string ordering" {
    assert("" < "a")
    assert("a" > "")
    assert("" <= "")
    assert("" >= "")
    assert(("" < "") == false)
    assert(("" > "") == false)
    assert(("a" < "") == false)
}
