type MyRecord {
    name: Str
    value: Int
}

trait Lookup {
    fn get_name(self) -> Option[Str]
}

impl Lookup for MyRecord {
    fn get_name(self) -> Option[Str] {
        if self.name != "" {
            Some(self.name)
        } else {
            None
        }
    }
}

test "trait method returning Option[Str] on struct" {
    let r = MyRecord { name: "hello", value: 42 }
    let result = r.get_name()
    assert(result.is_some())
    assert_eq(result.unwrap(), "hello")
}

test "trait method returning Option[Str] None case" {
    let r = MyRecord { name: "", value: 0 }
    let result = r.get_name()
    assert(result.is_none())
}
