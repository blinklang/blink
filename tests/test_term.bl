import std.term

test "is_tty returns Bool" {
    let result = term.is_tty()
    assert(result == true || result == false)
}

test "is_stderr_tty returns Bool" {
    let result = term.is_stderr_tty()
    assert(result == true || result == false)
}

test "terminal_width returns positive" {
    let w = term.terminal_width()
    assert(w > 0)
}

test "terminal_height returns positive" {
    let h = term.terminal_height()
    assert(h > 0)
}

test "bold wraps with ANSI codes" {
    let s = term.bold("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[1m") != 0)
    assert(s.contains("{e}[0m") != 0)
    assert(s.contains("hi") != 0)
}

test "dim wraps with ANSI codes" {
    let s = term.dim("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[2m") != 0)
    assert(s.contains("hi") != 0)
}

test "red wraps with ANSI 31" {
    let s = term.red("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[31m") != 0)
    assert(s.contains("{e}[0m") != 0)
}

test "green wraps with ANSI 32" {
    let s = term.green("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[32m") != 0)
}

test "yellow wraps with ANSI 33" {
    let s = term.yellow("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[33m") != 0)
}

test "blue wraps with ANSI 34" {
    let s = term.blue("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[34m") != 0)
}

test "magenta wraps with ANSI 35" {
    let s = term.magenta("test")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[35m") != 0)
}

test "cyan wraps with ANSI 36" {
    let s = term.cyan("test")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[36m") != 0)
}

test "underline wraps with ANSI 4" {
    let s = term.underline("hi")
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[4m") != 0)
    assert(s.contains("{e}[0m") != 0)
}

test "strip_ansi removes color codes" {
    let colored = term.red("hello")
    let plain = term.strip_ansi(colored)
    assert_eq(plain, "hello")
}

test "strip_ansi on plain text is identity" {
    assert_eq(term.strip_ansi("hello"), "hello")
}

test "colors are composable" {
    let s = term.bold(term.red("text"))
    let e = Char.from_code_point(27)
    assert(s.contains("{e}[1m") != 0)
    assert(s.contains("{e}[31m") != 0)
    assert(s.contains("text") != 0)
}

test "strip_ansi on composed styles" {
    let s = term.bold(term.red("hello"))
    assert_eq(term.strip_ansi(s), "hello")
}
