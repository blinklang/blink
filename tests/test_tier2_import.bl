fn check_no_error(base: Str, blink: Str, src: Str, forbidden: Str, label: Str) {
    shell_exec("cd {base} && {blink} check {src} 2>err.txt; true")
    let output = read_file("{base}/err.txt")
    if output.contains(forbidden) != 0 {
        io.println("FAIL: {label} — got unexpected '{forbidden}' in output: {output}")
    } else {
        io.println("PASS: {label}")
    }
}

fn check_has_error(base: Str, blink: Str, src: Str, expected_err: Str, label: Str) {
    shell_exec("cd {base} && {blink} check {src} 2>err.txt; true")
    let output = read_file("{base}/err.txt")
    if output.contains(expected_err) != 0 {
        io.println("PASS: {label}")
    } else {
        io.println("FAIL: {label} — expected error containing '{expected_err}', got: {output}")
    }
}

fn main() {
    let base = ".tmp/_test_tier2"
    shell_exec("rm -rf {base}")
    let blink = "../../../bin/blink"

    // --- Test 1: Tier 1 import with blink.toml (no dep needed) ---
    shell_exec("mkdir -p {base}/t1/src")
    write_file("{base}/t1/blink.toml", "[package]\nname = \"test_t1\"\nversion = \"0.1.0\"\n")
    write_file("{base}/t1/src/main.bl", "import std.json\n\nfn main() \{\n    io.println(\"ok\")\n}\n")
    check_no_error("{base}/t1", blink, "src/main.bl", "PackageNotDeclared", "tier1 with blink.toml — no E1052")

    // --- Test 2: Tier 2 import without dep → E1052 ---
    shell_exec("mkdir -p {base}/t2/src")
    write_file("{base}/t2/blink.toml", "[package]\nname = \"test_t2\"\nversion = \"0.1.0\"\n")
    write_file("{base}/t2/src/main.bl", "import std.http\n\nfn main() \{\n    io.println(\"ok\")\n}\n")
    check_has_error("{base}/t2", blink, "src/main.bl", "PackageNotDeclared", "tier2 without dep produces E1052")

    // --- Test 3: Tier 2 import with dep declared → no E1052 ---
    shell_exec("mkdir -p {base}/t3/src")
    write_file("{base}/t3/blink.toml", "[package]\nname = \"test_t3\"\nversion = \"0.1.0\"\n\n[dependencies]\nstd/http = \"0.1\"\n")
    write_file("{base}/t3/src/main.bl", "import std.http\n\nfn main() \{\n    io.println(\"ok\")\n}\n")
    check_no_error("{base}/t3", blink, "src/main.bl", "PackageNotDeclared", "tier2 with dep — no E1052")

    // --- Test 4: No blink.toml → backward compat (no E1052) ---
    shell_exec("mkdir -p {base}/t4")
    write_file("{base}/t4/main.bl", "import std.http\n\nfn main() \{\n    io.println(\"ok\")\n}\n")
    check_no_error("{base}/t4", blink, "main.bl", "PackageNotDeclared", "no blink.toml — backward compat")

    // --- Test 5: Tier 2 submodule without dep → E1052 ---
    shell_exec("mkdir -p {base}/t5/src")
    write_file("{base}/t5/blink.toml", "[package]\nname = \"test_t5\"\nversion = \"0.1.0\"\n")
    write_file("{base}/t5/src/main.bl", "import std.http_client\n\nfn main() \{\n    io.println(\"ok\")\n}\n")
    check_has_error("{base}/t5", blink, "src/main.bl", "PackageNotDeclared", "tier2 submodule without dep produces E1052")

    shell_exec("rm -rf {base}")
}
