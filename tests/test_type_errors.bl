fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "wrong arg count emits E0300" {
    let src = "fn add(a: Int, b: Int) -> Int \{ a + b \}\nfn main() \{ add(1, 2, 3) \}\n"
    expect_compile_error(src, "type_err_argc", "E0300")
}

test "return type mismatch emits E0300" {
    let src = "fn give_int() -> Int \{ \"hello\" \}\nfn main() \{ give_int() \}\n"
    expect_compile_error(src, "type_err_ret", "E0300")
}

test "nonexistent method emits E0505" {
    let src = "fn main() \{ let x = 42\n x.nonexistent_method()\n \}\n"
    expect_compile_error(src, "type_err_method", "E0505")
}

test "unknown type name emits E0507" {
    let src = "fn main() \{ let _x: Piont = 42\n \}\n"
    expect_compile_error(src, "type_err_unknown", "E0507")
}
