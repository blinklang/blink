import compile_test_helpers

test "wrong arg count emits E0300" {
    let src = "fn add(a: Int, b: Int) -> Int \{ a + b \}\nfn main() \{ add(1, 2, 3) \}\n"
    compile_test_helpers.expect_compile_error(src, "type_err_argc", "E0300")
}

test "return type mismatch emits E0300" {
    let src = "fn give_int() -> Int \{ \"hello\" \}\nfn main() \{ give_int() \}\n"
    compile_test_helpers.expect_compile_error(src, "type_err_ret", "E0300")
}

test "nonexistent method emits E0505" {
    let src = "fn main() \{ let x = 42\n x.nonexistent_method()\n \}\n"
    compile_test_helpers.expect_compile_error(src, "type_err_method", "E0505")
}

test "unknown type name emits E0507" {
    let src = "fn main() \{ let _x: Piont = 42\n \}\n"
    compile_test_helpers.expect_compile_error(src, "type_err_unknown", "E0507")
}
