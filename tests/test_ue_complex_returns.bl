effect Storage {
    effect Read {
        fn get_names() -> List[Str]
        fn find_name(prefix: Str) -> Option[Str]
    }
    effect Write {
        fn add_name(name: Str) -> Int
    }
}

fn fetch_names() -> List[Str] ! Storage.Read {
    storage.get_names()
}

fn find(prefix: Str) -> Option[Str] ! Storage.Read {
    storage.find_name(prefix)
}

test "ue effect returning List[Str]" {
    with handler Storage {
        fn get_names() -> List[Str] {
            ["alice", "bob", "charlie"]
        }
        fn find_name(prefix: Str) -> Option[Str] {
            if prefix == "al" {
                Some("alice")
            } else {
                None
            }
        }
        fn add_name(_name: Str) -> Int {
            1
        }
    } {
        let names = fetch_names()
        assert_eq(names.len(), 3)
        assert_eq(names.get(0).unwrap(), "alice")
        assert_eq(names.get(1).unwrap(), "bob")
    }
}

test "ue effect returning Option[Str]" {
    with handler Storage {
        fn get_names() -> List[Str] {
            []
        }
        fn find_name(prefix: Str) -> Option[Str] {
            if prefix == "al" {
                Some("alice")
            } else {
                None
            }
        }
        fn add_name(_name: Str) -> Int {
            0
        }
    } {
        let found = find("al")
        assert(found.is_some())
        assert_eq(found.unwrap(), "alice")

        let not_found = find("zz")
        assert(not_found.is_none())
    }
}

test "ue effect returning Int from Write" {
    with handler Storage {
        fn get_names() -> List[Str] {
            []
        }
        fn find_name(_prefix: Str) -> Option[Str] {
            None
        }
        fn add_name(_name: Str) -> Int {
            42
        }
    } {
        let id = storage.add_name("dave")
        assert_eq(id, 42)
    }
}

effect Fallible {
    effect Read {
        fn fetch(key: Str) -> Result[Str, Str]
    }
    effect Write {
        fn store(key: Str, value: Str) -> Result[Int, Str]
    }
}

fn do_fetch(key: Str) -> Result[Str, Str] ! Fallible.Read {
    fallible.fetch(key)
}

fn do_store(key: Str, value: Str) -> Result[Int, Str] ! Fallible.Write {
    fallible.store(key, value)
}

test "ue effect returning Result[Str, Str] Ok" {
    with handler Fallible {
        fn fetch(key: Str) -> Result[Str, Str] {
            if key == "found" {
                Ok("value")
            } else {
                Err("not found")
            }
        }
        fn store(_key: Str, _value: Str) -> Result[Int, Str] {
            Ok(1)
        }
    } {
        let r = do_fetch("found")
        assert(r.is_ok())
        assert_eq(r.unwrap(), "value")
    }
}

test "ue effect returning Result[Str, Str] Err" {
    with handler Fallible {
        fn fetch(key: Str) -> Result[Str, Str] {
            if key == "found" {
                Ok("value")
            } else {
                Err("not found")
            }
        }
        fn store(_key: Str, _value: Str) -> Result[Int, Str] {
            Ok(1)
        }
    } {
        let r = do_fetch("missing")
        assert(r.is_err())
        assert_eq(r.unwrap_err(), "not found")
    }
}

test "ue effect returning Result[Int, Str]" {
    with handler Fallible {
        fn fetch(_key: Str) -> Result[Str, Str] {
            Ok("")
        }
        fn store(_key: Str, _value: Str) -> Result[Int, Str] {
            Ok(42)
        }
    } {
        let r = do_store("k", "v")
        assert(r.is_ok())
        assert_eq(r.unwrap(), 42)
    }
}

fn try_fetch(k: Str) -> Result[Str, Str] ! Fallible.Read {
    let val = fallible.fetch(k)?
    Ok(val)
}

test "ue effect Result with ? operator" {
    with handler Fallible {
        fn fetch(key: Str) -> Result[Str, Str] {
            if key == "ok" {
                Ok("hello")
            } else {
                Err("fail")
            }
        }
        fn store(_key: Str, _value: Str) -> Result[Int, Str] {
            Ok(1)
        }
    } {
        let ok_r = try_fetch("ok")
        assert(ok_r.is_ok())
        assert_eq(ok_r.unwrap(), "hello")

        let err_r = try_fetch("bad")
        assert(err_r.is_err())
        assert_eq(err_r.unwrap_err(), "fail")
    }
}
