type Item {
    name: Str
    count: Int
}

effect Store {
    effect Lookup {
        fn find(name: Str) -> Option[Item]
    }
}

fn lookup(name: Str) -> Option[Item] ! Store.Lookup {
    store.find(name)
}

test "ue handler returning Option[Struct]" {
    with handler Store {
        fn find(name: Str) -> Option[Item] {
            if name == "apple" {
                Some(Item { name: "apple", count: 5 })
            } else {
                None
            }
        }
    } {
        let result = lookup("apple")
        assert(result.is_some())
        let item = result.unwrap()
        assert_eq(item.name, "apple")
        assert_eq(item.count, 5)

        let missing = lookup("banana")
        assert(missing.is_none())
    }
}
