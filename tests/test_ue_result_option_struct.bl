type Item {
    name: Str
    count: Int
}

type LookupError {
    NotFound
    Other(msg: Str)
}

effect Store {
    effect Read {
        fn find(name: Str) -> Result[Option[Item], LookupError]
    }
}

fn lookup(name: Str) -> Result[Option[Item], LookupError] ! Store.Read {
    store.find(name)
}

test "ue Result[Option[Struct], Enum] Ok Some" {
    with handler Store {
        fn find(name: Str) -> Result[Option[Item], LookupError] {
            if name == "apple" {
                Ok(Some(Item { name: "apple", count: 5 }))
            } else {
                Ok(None)
            }
        }
    } {
        let result = lookup("apple")
        assert(result.is_ok())
        let opt = result.unwrap()
        assert(opt.is_some())
        let item = opt.unwrap()
        assert_eq(item.name, "apple")
        assert_eq(item.count, 5)
    }
}

test "ue Result[Option[Struct], Enum] Ok None" {
    with handler Store {
        fn find(name: Str) -> Result[Option[Item], LookupError] {
            if name == "apple" {
                Ok(Some(Item { name: "apple", count: 5 }))
            } else {
                Ok(None)
            }
        }
    } {
        let result = lookup("banana")
        assert(result.is_ok())
        let opt = result.unwrap()
        assert(opt.is_none())
    }
}

test "ue Result[Option[Struct], Enum] Err" {
    with handler Store {
        fn find(_name: Str) -> Result[Option[Item], LookupError] {
            Err(LookupError.Other("db down"))
        }
    } {
        let result = lookup("anything")
        assert(result.is_err())
    }
}

fn try_lookup(name: Str) -> Result[Option[Item], LookupError] ! Store.Read {
    let opt = store.find(name)?
    Ok(opt)
}

test "ue Result[Option[Struct], Enum] with ? operator" {
    with handler Store {
        fn find(name: Str) -> Result[Option[Item], LookupError] {
            if name == "ok" {
                Ok(Some(Item { name: "ok", count: 1 }))
            } else {
                Err(LookupError.NotFound)
            }
        }
    } {
        let ok_r = try_lookup("ok")
        assert(ok_r.is_ok())
        let opt = ok_r.unwrap()
        assert(opt.is_some())
        assert_eq(opt.unwrap().name, "ok")

        let err_r = try_lookup("bad")
        assert(err_r.is_err())
    }
}
