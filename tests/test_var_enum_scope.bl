type Direction {
    North
    South
    East
    West
}

type Color {
    Red
    Green
    Blue
}

fn dir_name(d: Direction) -> Str {
    match d {
        North => "north"
        South => "south"
        East => "east"
        West => "west"
    }
}

fn color_name(c: Color) -> Str {
    match c {
        Red => "red"
        Green => "green"
        Blue => "blue"
    }
}

test "enum var in nested scope" {
    let d = Direction.North
    if true {
        let inner = Direction.South
        assert_eq(dir_name(inner), "south")
    }
    assert_eq(dir_name(d), "north")
}

test "enum var shadowed in inner scope" {
    let d = Direction.North
    if true {
        let d = Direction.West
        assert_eq(dir_name(d), "west")
    }
    assert_eq(dir_name(d), "north")
}

test "different enum types in nested scopes" {
    let d = Direction.East
    if true {
        let c = Color.Blue
        assert_eq(color_name(c), "blue")
    }
    assert_eq(dir_name(d), "east")
}

test "enum var in match arms" {
    let d = Direction.North
    let result = match d {
        North => {
            let inner = Direction.South
            dir_name(inner)
        }
        _ => "other"
    }
    assert_eq(result, "south")
    assert_eq(dir_name(d), "north")
}

test "deeply nested enum scopes" {
    let d1 = Direction.North
    if true {
        let d2 = Direction.South
        if true {
            let d3 = Direction.East
            assert_eq(dir_name(d3), "east")
        }
        assert_eq(dir_name(d2), "south")
    }
    assert_eq(dir_name(d1), "north")
}
