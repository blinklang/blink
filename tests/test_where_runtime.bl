// Phase 4 of the runtime-contracts project: @where runtime codegen.
//
// `type Port = Int @where(self > 0 && self <= 65535)` should cause
// any boundary coercion (call arg, return, struct field write, let
// binding with declared refined type) to emit a runtime check that
// aborts the program with a "refinement violated" message when the
// predicate is false.

import compile_test_helpers

// ── Codegen smoke: the assertion appears in emitted C ──────────────────

test "@where: emitted C contains a refinement assert at call site" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn use_port(p: Port) -> Port \{ p }\nfn main() \{ use_port(80) }\n"
    let c_src = compile_test_helpers.compile_and_emit_c(src, "_where_emit")
    assert(c_src.contains("refinement violated"))
}

// ── Runtime: passing a valid value succeeds ────────────────────────────

test "@where runtime: valid value passes refinement check" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn use_port(p: Port) -> Port \{ p }\nfn main() \{ use_port(80) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_where_ok")
    assert(r.exit_code == 0)
}

// ── Runtime: passing an invalid value aborts ───────────────────────────

test "@where runtime: invalid value aborts" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn use_port(p: Port) -> Port \{ p }\nfn main() \{ use_port(70000) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_where_bad")
    assert(r.exit_code != 0)
}

// ── Runtime: zero is rejected (lower bound) ────────────────────────────

test "@where runtime: lower-bound violation aborts" {
    let src = "type Port = Int @where(self > 0 && self <= 65535)\nfn use_port(p: Port) -> Port \{ p }\nfn main() \{ use_port(0) }\n"
    let r = compile_test_helpers.compile_and_run(src, "_where_zero")
    assert(r.exit_code != 0)
}

// ── No @where on type → no overhead ────────────────────────────────────

test "@where: plain Int parameter emits no refinement check" {
    let src = "fn use_int(p: Int) -> Int \{ p }\nfn main() \{ use_int(0) }\n"
    let c_src = compile_test_helpers.compile_and_emit_c(src, "_where_plain")
    assert(!c_src.contains("refinement violated"))
}
