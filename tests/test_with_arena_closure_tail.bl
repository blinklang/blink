fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_test_{tag}.bl", src)
    let args = [".tmp/_test_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_test_{tag}.bl")
}

test "closure literal as with-arena tail emits E0702" {
    let src = "fn main() \{\n    let f = with arena \{\n        fn(x: Int) -> Int \{ x + 1 }\n    }\n    let _ = f\n}\n"
    expect_compile_error(src, "with_arena_closure_literal", "E0702")
}

test "closure-typed variable as with-arena tail emits E0702" {
    let src = "fn main() \{\n    let g = with arena \{\n        let h = fn(x: Int) -> Int \{ x * 2 }\n        h\n    }\n    let _ = g\n}\n"
    expect_compile_error(src, "with_arena_closure_var", "E0702")
}
