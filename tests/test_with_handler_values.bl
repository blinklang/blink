effect Metrics {
    effect Emit {
        fn counter(name: Str, value: Int)
    }
    effect Query {
        fn get_counter(name: Str) -> Int
    }
}

fn make_io_handler() -> Handler[IO] {
    handler IO {
        fn print(msg: Str) {
            io.println("[IO-FN] {msg}")
        }
    }
}

fn make_io_handler_2() -> Handler[IO] {
    handler IO {
        fn print(msg: Str) {
            io.println("[IO-FN-2] {msg}")
        }
    }
}

fn make_metrics_handler() -> Handler[Metrics] {
    handler Metrics {
        fn counter(name: Str, value: Int) {
            io.println("[METRICS] {name}={value}")
        }
        fn get_counter(_name: Str) -> Int {
            99
        }
    }
}

test "with single function call" {
    with make_io_handler() {
        io.println("from call")
    }
    io.println("restored")
    assert(true)
}

test "with variable from function return" {
    let h = make_io_handler()
    with h {
        io.println("from var")
    }
    io.println("restored")
    assert(true)
}

test "let from correct fn with two handler fns" {
    let h = make_io_handler()
    with h {
        io.println("correct io handler")
    }
    assert(true)
}

test "with multiple function calls different effects" {
    with make_io_handler(), make_metrics_handler() {
        io.println("multi-handler print")
        metrics.counter("test", 42)
    }
    io.println("restored")
    assert(true)
}

test "with variables from different functions" {
    let h1 = make_io_handler()
    let h2 = make_metrics_handler()
    with h1, h2 {
        io.println("from vars print")
        metrics.counter("test", 7)
    }
    io.println("restored")
    assert(true)
}

test "nested with from function calls" {
    with make_io_handler() {
        io.println("outer")
        with make_metrics_handler() {
            metrics.counter("inner", 1)
        }
        io.println("back to outer")
    }
    io.println("restored")
    assert(true)
}

test "mixed inline and function call handlers" {
    with make_io_handler(), handler Metrics {
        fn counter(name: Str, value: Int) {
            io.println("[INLINE-METRICS] {name}={value}")
        }
        fn get_counter(_name: Str) -> Int { 0 }
    } {
        io.println("mixed print")
        metrics.counter("mixed", 5)
    }
    io.println("restored")
    assert(true)
}

test "handler from fn then inline in same test" {
    with make_io_handler() {
        io.println("first block")
    }
    with handler IO {
        fn print(msg: Str) {
            io.println("[INLINE] {msg}")
        }
    } {
        io.println("second block")
    }
    io.println("restored")
    assert(true)
}

test "two different io handler fns used sequentially" {
    with make_io_handler() {
        io.println("handler 1")
    }
    with make_io_handler_2() {
        io.println("handler 2")
    }
    io.println("restored")
    assert(true)
}
