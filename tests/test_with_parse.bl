fn make_handler() -> Int {
    42
}

fn make_handler2() -> Int {
    43
}

test "single with handler" {
    let h = make_handler()

    with h {
        assert_eq(h, 42)
    }
}

test "multiple with handlers" {
    with make_handler(), make_handler2() {
        assert(true)
    }
}

fn expect_compile_error(src: Str, tag: Str, error_code: Str) {
    write_file(".tmp/_twp_{tag}.bl", src)
    let args = [".tmp/_twp_{tag}.bl", "/dev/null", "--format", "json"]
    let result = process_run("build/blinkc", args)
    let output = "{result.out}{result.err_out}"
    assert(output.contains(error_code))
    shell_exec("rm -f .tmp/_twp_{tag}.bl")
}

test "with arena, b = rhs without as emits clean diagnostic (no panic)" {
    let src = "fn main() \{\n    with arena, b = 42 \{\n    }\n}\n"
    expect_compile_error(src, "no_as", "E1100")
}

test "with arena, b = rhs as without binding name emits diagnostic (no panic)" {
    let src = "fn main() \{\n    with arena, b = 42 as \{\n    }\n}\n"
    expect_compile_error(src, "no_bind", "E1100")
}
