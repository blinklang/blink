@ffi("labs")
@trusted(audit: "n8b5tb-test", reviewer: "test", date: "2026-05-06")
fn c_labs_i64(n: I64) -> I64 ! FFI { }

test "Bytes.with_ptr return type honors closure -> Int ascription" {
    let buf = Bytes.new()
    buf.push(72)
    buf.push(105)
    let n: Int = buf.with_ptr(fn(_p) -> Int { buf.len() })
    assert_eq(n + 1, 3)
}

test "Bytes.with_ptr return type honors closure -> Bool ascription" {
    let buf = Bytes.new()
    buf.push(72)
    let b: Bool = buf.with_ptr(fn(_p) -> Bool { buf.len() > 0 })
    assert(b)
}

test "Bytes.with_ptr return type honors closure -> I64 with FFI body" {
    let buf = Bytes.new()
    buf.push(0)
    let rc: I64 = buf.with_ptr(fn(_p) -> I64 { c_labs_i64(-7) })
    assert_eq(rc, 7)
}
